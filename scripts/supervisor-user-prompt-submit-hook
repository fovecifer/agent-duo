#!/bin/bash
# Mark supervisor busy at the start of a user/submitted turn.
set -euo pipefail
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin${PATH:+:$PATH}"

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do SOURCE="$(readlink "$SOURCE")"; done
ROOT="$(cd "$(dirname "$SOURCE")/.." && pwd)"
# shellcheck source=lib/loop.sh
source "$ROOT/lib/loop.sh"

AGENT_DUO_ROOT="${AGENT_DUO_ROOT:-$PWD}"
ad_loop_user_prompt_submit "$AGENT_DUO_ROOT"
