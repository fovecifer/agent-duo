#!/usr/bin/env bash
# peer — 让同一 tmux 会话里的多个编码 agent(claude / codex)互相观察和发送指令
#
# 命令面按 loop engineering 三层组织:
#   transport: peek / tell / wait / esc / status
#   building blocks: agent / loop / verify / judge / task / report / gate / approval / budget
#   steering: ask / checkpoint / reframe
# 运行 `peer --help` 查看完整用法。
#
# 依赖环境变量:
#   AGENT_SESSION  tmux 会话名,默认 agents
#   AGENT_DUO_AGENT_ID  稳定自身身份;Codex/Claude 工具子进程可能没有 TMUX_PANE
#   AGENT_NAME     迁移兼容:当 pane/env 身份缺失时回退为自身身份
#   PEER_FORCE=1   跳过 tell/esc 的权限弹窗检测

set -euo pipefail

SESSION="${AGENT_SESSION:-agents}"

# 定位仓库根,source 纯函数库。
PEER_SRC="${BASH_SOURCE[0]}"
while [ -L "$PEER_SRC" ]; do PEER_SRC="$(readlink "$PEER_SRC")"; done
PEER_ROOT="$(cd "$(dirname "$PEER_SRC")/.." && pwd)"
# shellcheck source=lib/registry.sh
source "$PEER_ROOT/lib/registry.sh"

PEER_INSTR="$PEER_ROOT/docs/AGENT-INSTRUCTIONS.md"
APPROVAL_BROKER="$PEER_ROOT/lib/approval_broker.sh"
APPROVAL_HOOK="$PEER_ROOT/bin/agent-duo-approval-hook"
AGENT_DUO_ROOT="${AGENT_DUO_ROOT:-$PWD}"
AGENT_DUO_DIR="$AGENT_DUO_ROOT/.agent-duo"

SELF_PANE="${TMUX_PANE:-}"

print_top_help() {
  cat <<'EOF'
用法: peer <command> [args...]

Transport:
  peer peek [<id>] [行数]
  peer tell [--force] [<id>] "消息"   或   ... | peer tell [<id>]
  peer wait [<id>] [超时秒] [采样间隔秒] [连续稳定次数]
  peer wait <id> --round N [--timeout 秒] [--interval 秒]
  peer esc [<id>] [--force]
  peer status

Loop building-blocks:
  peer agent <ls|add|rm> ...
  peer loop <show|init|reset> ...
  peer verify <ls|show> ...
  peer judge <target-ref> --verdict V ...
  peer judge ls <id> [--json]
  peer gate <ls|open|resolve> ...
  peer approval <ls|approve|deny|status|check> ...
  peer budget status
  peer task <show|init|next> ...
  peer report --type <plan|checkpoint|request|result> --status <...>

Steering:
  peer ask [<id>] "消息" [--timeout N] [--interval N] [--force]
  peer checkpoint [<id>] [--json]
  peer reframe [<id>] "消息" [--force]

Internal:
  peer loopd
EOF
}

usage_agent() {
  cat <<'EOF'
用法:
  peer agent ls
  peer agent add --provider claude|codex --role <role> [--id <id>] [--worktree]
  peer agent rm [--force] <id>
EOF
}

usage_approval() {
  cat <<'EOF'
用法:
  peer approval ls [--all]
  peer approval approve <id>
  peer approval deny <id> [--reason "..."]
  peer approval status [<id>]
  peer approval check [<id>] [--nonce <n>]
EOF
}

usage_loop() {
  cat <<'EOF'
用法:
  peer loop show <id>
  peer loop init [<id>] --mission "..." --max-rounds N [--non-goal "..."] [--success "..."] [--round N] [--verify id:"cmd"] [--verify-satisfies id:"signal"] [--verify-timeout id:N] [--judge role:veto1,veto2] [--detail-trap-rounds N]
  peer loop reset [<id>] [--max-rounds N]
EOF
}

usage_task() {
  cat <<'EOF'
用法:
  peer task show [<id>]
  peer task next [<id>]
  peer task init [<id>] --task "..." [--round N] --step s1:"..." [--step s2:"..."]
EOF
}

usage_verify() {
  cat <<'EOF'
用法:
  peer verify ls <id> [--round N] [--json]
  peer verify show <id> [--round N] [--json]
EOF
}

usage_judge() {
  cat <<'EOF'
用法:
  peer judge <target-ref> --verdict V [--round R] [--status done] [--finding sev:note] [--delta ...] [--evidence-cmd ...] [--evidence-result ...] [--evidence-ref ...] [--step sN] [--goal ...] [--drift ...] [--next ...]
  peer judge ls <id> [--json]
EOF
}

usage_gate() {
  cat <<'EOF'
用法:
  peer gate ls [--all]
  peer gate open [<target>] --title "..." [--detail "..."] [--option "..."] [--round N]
  peer gate resolve [<gate-id>|<target-id>] --choice <choice> [--note "..."]
EOF
}

usage_budget() {
  cat <<'EOF'
用法:
  peer budget status
EOF
}

usage_report() {
  cat <<'EOF'
用法:
  peer report --type <plan|checkpoint|request|result>
              --status <in_progress|blocked|partial|done|failed|unknown>
              [--step sN] [--round N] [--delta ...] [--next ...]
              [--needs <approval|decision|info|scope|discovery>
                 [--needs-detail ...] [--needs-option ...]]

说明: verdict 已移到 peer judge <target-ref> --verdict V。
EOF
}

usage_ask() {
  cat <<'EOF'
用法:
  peer ask [<id>] "消息" [--timeout N] [--interval N] [--force]
EOF
}

usage_checkpoint() {
  cat <<'EOF'
用法:
  peer checkpoint [<id>] [--json]
EOF
}

usage_reframe() {
  cat <<'EOF'
用法:
  peer reframe [<id>] "消息" [--force]
EOF
}

static_preflight_dispatch() {
  if [[ "${1:-}" == "--force" ]]; then shift; fi

  local first="${1:-help}" second="${2:-}" arg
  case "$first" in
    help|--help|-h)
      print_top_help
      exit 0
      ;;
    agent)
      case "$second" in --help|-h|"") usage_agent; exit 0 ;; esac
      ;;
    approval)
      case "$second" in
        --help|-h|"") usage_approval; exit 0 ;;
        ls|approve|deny|status|check)
          case "${3:-}" in --help|-h) usage_approval; exit 0 ;; esac
          ;;
      esac
      ;;
    loop)
      case "$second" in --help|-h|"") usage_loop; exit 0 ;; init|show|reset) ;; *)
        echo "已移除: 'peer loop <id>' → 改用 'peer loop show <id>'" >&2
        exit 1
        ;;
      esac
      ;;
    task)
      case "$second" in --help|-h|"") usage_task; exit 0 ;; init|show|next) ;; *)
        echo "已移除: 'peer task <id>' → 改用 'peer task show <id>'" >&2
        exit 1
        ;;
      esac
      ;;
    verify)
      case "$second" in --help|-h|"") usage_verify; exit 0 ;; esac
      ;;
    judge)
      case "$second" in --help|-h|"") usage_judge; exit 0 ;; esac
      ;;
    gate)
      case "$second" in --help|-h|"") usage_gate; exit 0 ;; esac
      ;;
    budget)
      case "$second" in --help|-h|"") usage_budget; exit 0 ;; esac
      ;;
    report)
      case "$second" in --help|-h) usage_report; exit 0 ;; esac
      for arg in "$@"; do
        case "$arg" in
          --verdict|--target-ref|--finding)
            echo "已移除: 'peer report --verdict/--target-ref/--finding' → 改用 'peer judge <target-ref> --verdict V'" >&2
            exit 1
            ;;
        esac
      done
      ;;
    ask)
      case "$second" in --help|-h) usage_ask; exit 0 ;; esac
      ;;
    checkpoint)
      case "$second" in --help|-h) usage_checkpoint; exit 0 ;; esac
      ;;
    reframe)
      case "$second" in --help|-h) usage_reframe; exit 0 ;; esac
      ;;
    ls)
      echo "已移除: 'peer ls' → 改用 'peer agent ls'" >&2
      exit 1
      ;;
    add)
      echo "已移除: 'peer add' → 改用 'peer agent add ...'" >&2
      exit 1
      ;;
    rm)
      echo "已移除: 'peer rm' → 改用 'peer agent rm ...'" >&2
      exit 1
      ;;
    approvals)
      echo "已移除: 'peer approvals' → 改用 'peer approval ls'" >&2
      exit 1
      ;;
    approve)
      echo "已移除: 'peer approve' → 改用 'peer approval approve <id>'" >&2
      exit 1
      ;;
    deny)
      echo "已移除: 'peer deny' → 改用 'peer approval deny <id>'" >&2
      exit 1
      ;;
    broker-status)
      echo "已移除: 'peer broker-status' → 改用 'peer approval status [<id>]'" >&2
      exit 1
      ;;
    broker-check)
      echo "已移除: 'peer broker-check' → 改用 'peer approval check [<id>] [--nonce <n>]'" >&2
      exit 1
      ;;
  esac
}

static_preflight_dispatch "$@"

# 自识别:优先读自己 pane 的 @agent_id;缺失则回退启动注入的稳定身份,
# 最后回退 AGENT_NAME(迁移兼容)。
self_id() {
  local id=""
  if [[ -n "$SELF_PANE" ]]; then
    id="$(tmux display-message -p -t "$SELF_PANE" '#{@agent_id}' 2>/dev/null || true)"
  fi
  if [[ -z "$id" ]]; then
    id="${AGENT_DUO_AGENT_ID:-}"
  fi
  if [[ -z "$id" ]]; then
    id="${AGENT_NAME:-}"
  fi
  printf '%s' "$id"
}

self_role() {
  local role=""
  if [[ -n "$SELF_PANE" ]]; then
    role="$(tmux display-message -p -t "$SELF_PANE" '#{@agent_role}' 2>/dev/null || true)"
  fi
  if [[ -z "$role" ]]; then
    role="${AGENT_DUO_AGENT_ROLE:-}"
  fi
  if [[ -z "$role" ]]; then
    role="${AGENT_ROLE:-worker}"
  fi
  printf '%s' "$role"
}

ME="$(self_id)"
if [[ -z "$ME" ]]; then
  echo "错误: 无法确定自身身份(既无 pane @agent_id,也无 AGENT_DUO_AGENT_ID/AGENT_NAME)。请通过 start.sh 启动。" >&2
  exit 1
fi

# list_agents → 每行: pane_id<TAB>agent_id<TAB>role<TAB>provider(原样来自 tmux)。
list_agents() {
  tmux list-panes -s -t "$SESSION" \
    -F '#{pane_id}	#{@agent_id}	#{@agent_role}	#{@agent_provider}' 2>/dev/null
}

# agent_ids → 已注册(@agent_id 非空)的 id,每行一个。
agent_ids() {
  list_agents | awk -F'\t' '$2 != "" { print $2 }'
}

# pane_for_id <id> → 打印该 id 的 pane;找不到返回 1。
pane_for_id() {
  local want="$1"
  list_agents | awk -F'\t' -v w="$want" '$2==w { print $1; found=1 } END{ exit found?0:1 }'
}

# resolve_target_pane <maybe_id> → 打印目标 pane,出错时写 stderr 并 exit。
#   maybe_id 非空 → 必须是已注册 id;否则报错。
#   maybe_id 为空 → reg_pick_other(self, ids):两人取另一个;0 人/≥2 候选报错。
resolve_target_pane() {
  local maybe_id="$1"
  local pane other ids rc
  if [[ -n "$maybe_id" ]]; then
    if ! pane="$(pane_for_id "$maybe_id")"; then
      echo "错误: 找不到 agent '$maybe_id'。用 'peer agent ls' 查看在线 agent。" >&2
      exit 1
    fi
    printf '%s' "$pane"
    return 0
  fi
  ids="$(agent_ids)"
  if other="$(reg_pick_other "$ME" "$ids")"; then
    pane_for_id "$other"
    return 0
  fi
  rc=$?
  if [[ "$rc" == "2" ]]; then
    echo "错误: 会话里没有其他 agent 可作为目标。" >&2
  else
    echo "错误: 会话内有多个 agent,请指定目标。可用: $(printf '%s ' $(printf '%s\n' "$ids" | grep -vx -- "$ME"))" >&2
  fi
  exit 1
}

is_positive_int() {
  [[ "$1" =~ ^[1-9][0-9]*$ ]]
}

is_nonnegative_int() {
  [[ "$1" =~ ^[0-9]+$ ]]
}

is_role_token() {
  reg_is_role_token "$1"
}

is_verdict_token() {
  [[ "${1:-}" =~ ^[A-Za-z0-9_-]+$ ]]
}

is_report_type() {
  case "$1" in
    plan|checkpoint|request|result) return 0 ;;
    *) return 1 ;;
  esac
}

is_report_status() {
  case "$1" in
    in_progress|blocked|partial|done|failed|unknown) return 0 ;;
    *) return 1 ;;
  esac
}

# needs[].kind 枚举:决定 stall 路由到谁(见 worker-supervisor-contract §2.2)。
is_needs_kind() {
  case "$1" in
    approval|decision|info|scope|discovery) return 0 ;;
    *) return 1 ;;
  esac
}

# 工作型角色(受 broker 派发硬门保护):除 supervisor/daemon/loopd 外的所有角色。
# 单一真相:tell 门控与 add 提示都用它,避免两处豁免名单漂移。
role_is_gated() {
  case "$1" in
    supervisor|daemon|loopd) return 1 ;;
    *) return 0 ;;
  esac
}

run_approval_broker() {
  /bin/bash "$APPROVAL_BROKER" "$@"
}

# role_for_id <id> → 打印该 id 的 @agent_role;读不到时打印 "worker"(fail-closed)。
role_for_id() {
  local want="$1" role
  role="$(list_agents | awk -F'\t' -v w="$want" '$2==w { print $3; found=1 } END{ exit found?0:1 }')" || role=""
  [[ -n "$role" ]] || role="worker"
  printf '%s' "$role"
}

install_approval_session_settings() { # <agent_id> <provider> <worktree>
  local agent_id="$1" provider="$2" worktree="$3"
  run_approval_broker install \
    --agent-id "$agent_id" \
    --provider "$provider" \
    --hook "$APPROVAL_HOOK" \
    --root "$AGENT_DUO_ROOT" \
    --worktree "$worktree"
}

iso_ts() {
  date -u '+%Y-%m-%dT%H:%M:%SZ'
}

sha256_file() { # <file>
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$1" | awk '{print $1}'
  elif command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  else
    echo "错误: 需要 shasum 或 sha256sum 计算 report sha。" >&2
    exit 1
  fi
}

random_hex_tag() {
  local tag
  tag="$(od -An -N4 -tx1 /dev/urandom 2>/dev/null | tr -d ' \n' || true)"
  if [[ -z "$tag" ]]; then
    tag="$(printf '%04x' "$$")"
  fi
  printf '%s' "$tag"
}

codec_tag() {
  local tag=""
  if [[ -n "$SELF_PANE" ]]; then
    tag="$(tmux display-message -p -t "$SELF_PANE" '#{@agentduo_codec_tag}' 2>/dev/null || true)"
  fi
  if [[ -z "$tag" ]]; then
    tag="$(random_hex_tag)"
    if [[ -n "$SELF_PANE" ]]; then
      tmux set-option -p -t "$SELF_PANE" @agentduo_codec_tag "$tag" 2>/dev/null || true
    fi
  fi
  printf '%s' "$tag"
}

next_report_round() { # <state_dir>
  local dir="$1" max=0 f base n
  for f in "$dir"/r*.json; do
    [[ -e "$f" ]] || continue
    base="${f##*/}"
    base="${base#r}"
    base="${base%.json}"
    if is_positive_int "$base"; then
      n="$base"
      if (( n > max )); then max="$n"; fi
    fi
  done
  printf '%s' "$(( max + 1 ))"
}

report_round_for_id() { # <agent_id>
  local report round
  report="$AGENT_DUO_DIR/state/$1/report.json"
  if [[ ! -e "$report" ]]; then
    printf '0'
    return 0
  fi
  round="$(jq -r '.round // 0' "$report" 2>/dev/null || true)"
  if ! is_nonnegative_int "$round"; then
    round="0"
  fi
  printf '%s' "$round"
}

report_file_for_round() { # <agent_id> <round>
  printf '%s/state/%s/r%s.json' "$AGENT_DUO_DIR" "$1" "$2"
}

one_line() {
  printf '%s' "$1" | tr '\r\n' '  '
}

event_type_for_report() { # <report_type> <status>
  local report_type="$1" status="$2"
  if [[ "$report_type" == "request" || "$status" == "blocked" ]]; then
    printf 'blocked'
  else
    case "$report_type" in
      plan)       printf 'plan' ;;
      result)     printf 'result' ;;
      checkpoint) printf 'checkpoint' ;;
      *)          printf '%s' "$report_type" ;;
    esac
  fi
}

toml_string() { # <value>
  jq -Rn -r --arg s "$1" '$s | @json'
}

codex_hook_config() { # <event> <command> [matcher]
  local event="$1" command="$2" matcher="${3:-}" command_toml
  command_toml="$(toml_string "$command")"
  if [[ -n "$matcher" ]]; then
    printf 'hooks.%s=[{matcher="%s",hooks=[{type="command",command=%s}]}]' "$event" "$matcher" "$command_toml"
  else
    printf 'hooks.%s=[{hooks=[{type="command",command=%s}]}]' "$event" "$command_toml"
  fi
}

codex_shell_env_args() { # <agent_duo_bin_dir>
  local bin_dir="$1" tool_path
  tool_path="$bin_dir:${PATH:-}"
  printf -- '-c shell_environment_policy.inherit=all -c %s' \
    "$(printf '%q' "shell_environment_policy.set.PATH=$(toml_string "$tool_path")")"
}

codex_tmux_access_args() {
  local sock_dir
  if [[ -n "${TMUX:-}" ]]; then
    sock_dir="${TMUX%%,*}"
    sock_dir="${sock_dir%/*}"
  else
    sock_dir="${TMUX_TMPDIR:-/tmp}/tmux-$(id -u)"
  fi
  if [[ -d "$sock_dir" ]]; then
    sock_dir="$(cd "$sock_dir" && pwd -P)"
  fi
  printf -- '--sandbox workspace-write --add-dir %s -c %s' \
    "$(printf '%q' "$sock_dir")" \
    "$(printf '%q' "network.allow_unix_sockets=[$(toml_string "$sock_dir")]")"
}

json_escape() {
  local s="${1:-}"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  s="${s//$'\b'/\\b}"
  s="${s//$'\f'/\\f}"
  # 其余 < 0x20 控制字符按 JSON 规范转为 \u00XX，否则会产出非法 JSON 让下游 jq 解析失败。
  # 极少见(NUL 无法存于 bash 变量);多字节 UTF-8 字符码 > 0x1f，原样保留。
  if [[ "$s" == *[$'\x01'-$'\x1f']* ]]; then
    local out="" i ch code
    for (( i=0; i<${#s}; i++ )); do
      ch="${s:i:1}"
      printf -v code '%d' "'$ch"
      if (( code >= 1 && code <= 31 )); then
        printf -v ch '\\u%04x' "$code"
      fi
      out+="$ch"
    done
    s="$out"
  fi
  printf '%s' "$s"
}

json_str() {
  printf '"'
  json_escape "${1:-}"
  printf '"'
}

json_nullable_str() {
  if [[ -z "${1:-}" ]]; then
    printf 'null'
  else
    json_str "$1"
  fi
}

# build_needs_json <kind> <detail> [option...] → 打印 needs[] 数组(JSON)。
# kind 为空 → "[]"(无阻塞诉求);否则一条 {kind,detail,options[]}。options 始终是数组。
build_needs_json() {
  local kind="$1" detail="${2:-}"
  shift 2 2>/dev/null || shift $#
  if [[ -z "$kind" ]]; then
    printf '[]'
    return
  fi
  printf '[{"kind":'; json_str "$kind"
  printf ',"detail":'; json_nullable_str "$detail"
  printf ',"options":['
  local first=1 opt
  for opt in "$@"; do
    if [[ $first -eq 1 ]]; then first=0; else printf ','; fi
    json_str "$opt"
  done
  printf ']}]'
}

parse_finding_spec() { # <severity:note>|<note>; sets FINDING_SEVERITY FINDING_NOTE
  local spec="${1:-}"
  if [[ "$spec" == *:* ]]; then
    FINDING_SEVERITY="${spec%%:*}"
    FINDING_NOTE="${spec#*:}"
    [[ -n "$FINDING_SEVERITY" ]] || FINDING_SEVERITY="note"
  else
    FINDING_SEVERITY="note"
    FINDING_NOTE="$spec"
  fi
}

build_findings_json() { # [finding...]
  local first=1 finding
  printf '['
  for finding in "$@"; do
    parse_finding_spec "$finding"
    if [[ $first -eq 1 ]]; then first=0; else printf ','; fi
    printf '{"severity":'; json_str "$FINDING_SEVERITY"
    printf ',"note":'; json_str "$FINDING_NOTE"
    printf '}'
  done
  printf ']'
}

parse_target_ref() { # <worker>@<round|rround>; sets TARGET_WORKER TARGET_ROUND
  local ref="${1:-}" round_part
  if [[ "$ref" != *@* ]]; then
    echo "错误: --target-ref 必须形如 <worker>@<round>。" >&2
    return 1
  fi
  TARGET_WORKER="${ref%@*}"
  round_part="${ref##*@}"
  if [[ "$round_part" == r* ]]; then
    round_part="${round_part#r}"
  fi
  if [[ -z "$TARGET_WORKER" || -z "$round_part" ]]; then
    echo "错误: --target-ref 必须形如 <worker>@<round>。" >&2
    return 1
  fi
  if ! is_role_token "$TARGET_WORKER"; then
    echo "错误: --target-ref 的 worker 只能包含字母、数字、点、下划线和连字符,且必须以字母或数字开头。" >&2
    return 1
  fi
  if ! is_positive_int "$round_part"; then
    echo "错误: --target-ref 的 round 必须是正整数。" >&2
    return 1
  fi
  TARGET_ROUND="$round_part"
}

write_verdict_record_json() { # <path> <verdict> <by> <role> <target> <round> <findings_json> <ts>
  local path="$1" verdict="$2" by="$3" role="$4" target="$5" round_s="$6" findings_json="$7" ts="$8"
  {
    printf '{"verdict":'; json_str "$verdict"
    printf ',"by":'; json_str "$by"
    printf ',"role":'; json_str "$role"
    printf ',"target":'; json_str "$target"
    printf ',"target_round":%s' "$round_s"
    printf ',"findings":%s' "$findings_json"
    printf ',"ts":'; json_str "$ts"
    printf '}\n'
  } > "$path"
}

route_verdict_record() { # <target> <round> <reviewer_role> <verdict> <findings_json> <ts>
  local target="$1" round_s="$2" reviewer_role="$3" verdict="$4" findings_json="$5" ts="$6"
  local dir path tmp
  dir="$AGENT_DUO_DIR/state/$target/reviews"
  path="$dir/${reviewer_role}-r${round_s}.json"
  tmp="$dir/.${reviewer_role}-r${round_s}.json.$$"
  mkdir -p "$dir" || return 1
  rm -f "$tmp"
  if ! write_verdict_record_json "$tmp" "$verdict" "$ME" "$reviewer_role" "$target" "$round_s" "$findings_json" "$ts"; then
    rm -f "$tmp"
    return 1
  fi
  mv "$tmp" "$path"
}

parse_review_spec() { # <role:veto1,veto2>; sets REVIEW_ROLE REVIEW_VETO_CSV
  local spec="${1:-}" veto_csv verdict
  if [[ "$spec" != *:* ]]; then
    echo "错误: --judge 必须形如 <role>:<veto1,veto2>。" >&2
    return 1
  fi
  REVIEW_ROLE="${spec%%:*}"
  veto_csv="${spec#*:}"
  if ! is_role_token "$REVIEW_ROLE"; then
    echo "错误: --judge 的 role 只能包含字母、数字、点、下划线和连字符,且必须以字母或数字开头。" >&2
    return 1
  fi
  if [[ -z "$veto_csv" ]]; then
    echo "错误: --judge 的 veto-list 不能为空。" >&2
    return 1
  fi
  if [[ "$veto_csv" == ,* || "$veto_csv" == *, || "$veto_csv" == *,,* ]]; then
    echo "错误: --judge 的 veto-list 不能包含空 verdict。" >&2
    return 1
  fi
  IFS=',' read -r -a REVIEW_VETO_PARTS <<< "$veto_csv"
  if (( ${#REVIEW_VETO_PARTS[@]} == 0 )); then
    echo "错误: --judge 的 veto-list 不能为空。" >&2
    return 1
  fi
  for verdict in "${REVIEW_VETO_PARTS[@]}"; do
    if ! is_verdict_token "$verdict"; then
      echo "错误: --judge 的 verdict 只能包含字母、数字、下划线和连字符。" >&2
      return 1
    fi
  done
  REVIEW_VETO_CSV="$veto_csv"
}

build_acceptance_json() {
  local spec role veto_csv verdict first_review first_veto
  if (( ${#loop_reviews[@]} == 0 )); then
    printf '{}'
    return 0
  fi
  printf '{"reviews":['
  first_review=1
  for spec in ${loop_reviews[@]+"${loop_reviews[@]}"}; do
    parse_review_spec "$spec" || return 1
    role="$REVIEW_ROLE"
    veto_csv="$REVIEW_VETO_CSV"
    if [[ $first_review -eq 1 ]]; then first_review=0; else printf ','; fi
    printf '{"role":'; json_str "$role"
    printf ',"veto_on":['
    first_veto=1
    IFS=',' read -r -a REVIEW_VETO_PARTS <<< "$veto_csv"
    for verdict in "${REVIEW_VETO_PARTS[@]}"; do
      if [[ $first_veto -eq 1 ]]; then first_veto=0; else printf ','; fi
      json_str "$verdict"
    done
    printf ']}'
  done
  printf ']}'
}

write_report_json() {
  local path="$1" round_s="$2" agent_id="$3" role="$4" report_type="$5" status="$6"
  local goal_ref="$7" step_ref="$8" delta="$9" drift="${10}" next_text="${11}"
  local evidence_cmd="${12}" evidence_result="${13}" evidence_ref="${14}" needs_json="${15:-[]}"
  local verdict="${16:-}" target_ref="${17:-}" findings_json="${18:-[]}"
  {
    printf '{"protocol":"1","round":%s,' "$round_s"
    printf '"agent_id":'; json_str "$agent_id"; printf ','
    printf '"role":'; json_str "$role"; printf ','
    printf '"type":'; json_str "$report_type"; printf ','
    printf '"status":'; json_str "$status"; printf ','
    printf '"goal_ref":'; json_nullable_str "$goal_ref"; printf ','
    printf '"step_ref":'; json_nullable_str "$step_ref"; printf ','
    printf '"delta":'; json_str "$delta"; printf ','
    printf '"drift":'; json_nullable_str "$drift"; printf ','
    printf '"evidence":'
    if [[ -n "$evidence_cmd" || -n "$evidence_result" || -n "$evidence_ref" ]]; then
      printf '[{"cmd":'; json_str "$evidence_cmd"
      printf ',"result":'; json_str "$evidence_result"
      printf ',"ref":'; json_str "$evidence_ref"
      printf '}]'
    else
      printf '[]'
    fi
    printf ',"needs":%s,' "$needs_json"
    printf '"verdict":'; json_nullable_str "$verdict"; printf ','
    printf '"target_ref":'; json_nullable_str "$target_ref"; printf ','
    printf '"findings":%s,' "$findings_json"
    printf '"next":'; json_str "$next_text"
    printf '}\n'
  } > "$path"
}

_emit_report() {
  if [[ $# -lt 16 ]]; then
    echo "内部错误: _emit_report 参数不足。" >&2
    return 1
  fi

  local report_type="$1" report_status="$2" step_ref="$3" round="$4" delta="$5" next_text="$6" goal_ref="$7" drift="$8"
  local evidence_cmd="$9" evidence_result="${10}" evidence_ref="${11}" needs_kind="${12}" needs_detail="${13}"
  local verdict="${14}" target_ref="${15}" findings_json="${16}"
  shift 16
  local needs_options=("$@")
  local role verdict_target_worker="" verdict_target_round=""
  local state_dir events_dir effective_status task_file tmp_task step_status evidence_json task_candidate
  local report_file latest_file needs_json tmp_report sha ts tag ref event_ref gate_created_file queue
  local event_type summary gate_id gate_title event_id tmp_latest

  if ! is_report_type "$report_type"; then
    echo "错误: --type 必须是 plan、checkpoint、request 或 result。" >&2
    return 1
  fi
  if ! is_report_status "$report_status"; then
    echo "错误: --status 必须是 in_progress、blocked、partial、done、failed 或 unknown。" >&2
    return 1
  fi
  if [[ -n "$round" ]] && ! is_positive_int "$round"; then
    echo "错误: --round 必须是正整数。" >&2
    return 1
  fi
  if [[ -n "$needs_kind" ]] && ! is_needs_kind "$needs_kind"; then
    echo "错误: --needs 必须是 approval、decision、info、scope 或 discovery。" >&2
    return 1
  fi
  # detail/option 离开 kind 无处安放:fail-closed,别把阻塞诉求悄悄丢成空 needs[]。
  if [[ -z "$needs_kind" && ( -n "$needs_detail" || ${#needs_options[@]} -gt 0 ) ]]; then
    echo "错误: --needs-detail / --needs-option 需要同时指定 --needs <approval|decision|info|scope|discovery>。" >&2
    return 1
  fi

  role="$(self_role)"
  if [[ -n "$verdict" || -n "$target_ref" ]]; then
    if [[ -z "$verdict" || -z "$target_ref" ]]; then
      echo "错误: verdict 与 target-ref 必须同时指定。" >&2
      return 1
    fi
    if [[ "$report_type" != "result" ]]; then
      echo "错误: verdict 只能用于 result 报告。" >&2
      return 1
    fi
    if ! is_verdict_token "$verdict"; then
      echo "错误: --verdict 只能包含字母、数字、下划线和连字符。" >&2
      return 1
    fi
    if ! is_role_token "$role"; then
      echo "错误: 当前 agent role '$role' 不能用于 verdict 路由;role 必须以字母或数字开头,且只能包含字母、数字、点、下划线和连字符。" >&2
      return 1
    fi
    if ! parse_target_ref "$target_ref"; then
      return 1
    fi
    verdict_target_worker="$TARGET_WORKER"
    verdict_target_round="$TARGET_ROUND"
    target_ref="${verdict_target_worker}@${verdict_target_round}"
  fi

  state_dir="$AGENT_DUO_DIR/state/$ME"
  events_dir="$AGENT_DUO_DIR/events"
  if ! mkdir -p "$state_dir" "$events_dir"; then
    echo "错误: 创建 report 状态目录失败: .agent-duo/state/$ME" >&2
    return 1
  fi

  if [[ -z "$round" ]]; then
    round="$(next_report_round "$state_dir")"
  fi

  effective_status="$report_status"
  if [[ "$report_status" == "done" || "$report_status" == "partial" ]]; then
    if [[ -z "$evidence_cmd" && -z "$evidence_result" && -z "$evidence_ref" ]]; then
      effective_status="unknown"
    fi
  fi

  task_file="$state_dir/task.json"
  tmp_task=""
  if [[ -f "$task_file" ]]; then
    if [[ -n "$step_ref" ]]; then
      if ! task_step_exists "$task_file" "$step_ref"; then
        echo "错误: task.json 中不存在 step '$step_ref'。" >&2
        return 1
      fi
      step_status=""
      step_status="$(task_step_status_for_report "$report_type" "$report_status" "$effective_status" 2>/dev/null || true)"
      if [[ -n "$step_status" ]]; then
        evidence_json="$(task_evidence_json "$evidence_cmd" "$evidence_result" "$evidence_ref")"
        tmp_task="${state_dir}/.task.json.$$"
        if ! task_prepare_update "$task_file" "$tmp_task" "$step_ref" "$step_status" "$round" "$evidence_json"; then
          rm -f "$tmp_task"
          return 1
        fi
      fi
    fi
    task_candidate="$task_file"
    if [[ -n "$tmp_task" ]]; then task_candidate="$tmp_task"; fi
    if [[ "$report_type" == "result" && "$effective_status" == "done" ]]; then
      if ! task_all_steps_done "$task_candidate"; then
        effective_status="partial"
      fi
    fi
  fi

  report_file="$state_dir/r${round}.json"
  latest_file="$state_dir/report.json"
  if [[ -e "$report_file" ]]; then
    echo "错误: report round 已存在: .agent-duo/state/$ME/r${round}.json" >&2
    return 1
  fi

  # 写临时文件 + rename：保证读者只看到完整文件(原子可见性)。
  # 注意:不再 fsync —— 去掉 Python 运行时依赖后放弃了跨崩溃耐久性。单机断电/内核崩溃
  # 极端情形下，已返回成功的 report/event 可能丢失;原子性与正常读写不受影响。
  needs_json="$(build_needs_json "$needs_kind" "$needs_detail" ${needs_options[@]+"${needs_options[@]}"})"
  tmp_report="$state_dir/.r${round}.json.$$"
  if ! write_report_json "$tmp_report" "$round" "$ME" "$role" "$report_type" "$effective_status" \
    "$goal_ref" "$step_ref" "$delta" "$drift" "$next_text" \
    "$evidence_cmd" "$evidence_result" "$evidence_ref" "$needs_json" \
    "$verdict" "$target_ref" "$findings_json"; then
    rm -f "$tmp_report"
    echo "错误: 写 report 临时文件失败: .agent-duo/state/$ME/.r${round}.json.$$" >&2
    return 1
  fi
  if ! mv "$tmp_report" "$report_file"; then
    rm -f "$tmp_report" "$report_file"
    echo "错误: 写 report 文件失败: .agent-duo/state/$ME/r${round}.json" >&2
    return 1
  fi

  if ! sha="$(sha256_file "$report_file")"; then
    rm -f "$report_file"
    echo "错误: 计算 report sha 失败: .agent-duo/state/$ME/r${round}.json" >&2
    return 1
  fi
  ts="$(iso_ts)"
  tag="$(codec_tag)"
  ref=".agent-duo/state/$ME/r${round}.json"
  event_ref="$ref"
  gate_created_file=""

  queue="$events_dir/queue.jsonl"
  event_type="$(event_type_for_report "$report_type" "$effective_status")"
  summary="$(one_line "$delta")"
  if [[ -z "$summary" ]]; then summary="$(one_line "$next_text")"; fi
  # 阻塞诉求要带进 event summary,否则 Stop/loop 注入只能给 supervisor 一个泛化 request/blocked。
  if [[ -z "$summary" && -n "$needs_detail" ]]; then summary="$(one_line "$needs_detail")"; fi
  if [[ -z "$summary" && -n "$needs_kind" ]]; then summary="needs:${needs_kind}"; fi
  if [[ -z "$summary" ]]; then summary="${report_type}/${effective_status}"; fi
  if [[ "$needs_kind" == "decision" && "$event_type" == "blocked" ]]; then
    gate_id="$(new_gate_id "$round")"
    gate_title="$needs_detail"
    if [[ -z "$gate_title" ]]; then gate_title="Human decision required"; fi
    if ! create_gate_record "$gate_id" "$ts" "$ME" "$role" "$round" "$gate_title" "$needs_detail" "$ref" ${needs_options[@]+"${needs_options[@]}"}; then
      rm -f "$report_file"
      if [[ -n "$tmp_task" ]]; then rm -f "$tmp_task"; fi
      return 1
    fi
    gate_created_file="$(gate_path "$gate_id")"
    event_ref=".agent-duo/gates/${gate_id}.json"
  fi
  event_id="$(printf 'e%s-%s-%s' "$(date -u '+%Y%m%dT%H%M%SZ')" "$round" "$$")"
  if ! append_event_json "$queue" "$event_id" "$ts" "$ME" "$event_type" "$round" "$summary" "$event_ref"; then
    rm -f "$report_file"
    if [[ -n "$gate_created_file" ]]; then rm -f "$gate_created_file"; fi
    if [[ -n "$tmp_task" ]]; then rm -f "$tmp_task"; fi
    return 1
  fi
  if [[ -n "$tmp_task" ]]; then
    if ! mv "$tmp_task" "$task_file"; then
      rm -f "$tmp_task"
      echo "错误: 更新 task.json 失败: .agent-duo/state/$ME/task.json" >&2
      return 1
    fi
  fi
  if [[ -n "$gate_created_file" ]]; then
    if ! append_decision_log "$gate_id" "opened" "$ME" "$summary" "" ""; then
      echo "错误: 写 Human Decision Gate 审计日志失败: $gate_id" >&2
      return 1
    fi
  fi

  tmp_latest="$state_dir/.report.json.$$"
  rm -f "$tmp_latest"
  if ! ln -s "r${round}.json" "$tmp_latest"; then
    rm -f "$tmp_latest"
    echo "错误: 创建 latest report 临时链接失败: .agent-duo/state/$ME/.report.json.$$" >&2
    return 1
  fi
  if ! mv -f "$tmp_latest" "$latest_file"; then
    rm -f "$tmp_latest"
    echo "错误: 更新 latest report 链接失败: .agent-duo/state/$ME/report.json" >&2
    return 1
  fi

  if [[ -n "$verdict" ]]; then
    if ! route_verdict_record "$verdict_target_worker" "$verdict_target_round" "$role" "$verdict" "$findings_json" "$ts"; then
      echo "错误: 判决已记入本 agent report,但路由到 ${verdict_target_worker}/reviews/${role}-r${verdict_target_round}.json 失败;请保留同一 target-ref 重报;若原命令显式带了 --round,重试时换新 round 或省略 --round。" >&2
      return 1
    fi
  fi

  printf '«AGENTDUO:%s» agent_id=%s round=%s type=%s status=%s file=%s sha=%s ts=%s\n' \
    "$tag" "$ME" "$round" "$report_type" "$effective_status" "$ref" "$sha" "$ts"
}

task_file_for_id() { # <agent_id>
  printf '%s/state/%s/task.json' "$AGENT_DUO_DIR" "$1"
}

is_step_status() {
  case "$1" in
    pending|in_progress|blocked|done|failed|kept) return 0 ;;
    *) return 1 ;;
  esac
}

parse_step_spec() { # <id:desc>; sets STEP_ID STEP_DESC
  local spec="$1"
  if [[ "$spec" != *:* ]]; then
    echo "错误: --step 必须形如 <id>:<desc>。" >&2
    return 1
  fi
  STEP_ID="${spec%%:*}"
  STEP_DESC="${spec#*:}"
  if [[ -z "$STEP_ID" || -z "$STEP_DESC" ]]; then
    echo "错误: --step 的 id 和 desc 都不能为空。" >&2
    return 1
  fi
  if [[ ! "$STEP_ID" =~ ^[A-Za-z0-9._-]+$ ]]; then
    echo "错误: step id 只能包含字母、数字、点、下划线和连字符。" >&2
    return 1
  fi
}

write_task_json() { # <path> <agent_id> <task_title> <frozen_round> [step_spec...]
  local path="$1" agent_id="$2" task_title="$3" frozen_round="$4" spec first=1 now
  shift 4
  now="$(iso_ts)"
  {
    printf '{"protocol":"1",'
    printf '"agent_id":'; json_str "$agent_id"; printf ','
    printf '"task":'; json_str "$task_title"; printf ','
    printf '"frozen_at_round":%s,' "$frozen_round"
    printf '"current_step":null,'
    printf '"created_at":'; json_str "$now"; printf ','
    printf '"updated_at":'; json_str "$now"; printf ','
    printf '"steps":['
    for spec in "$@"; do
      parse_step_spec "$spec" || return 1
      if [[ $first -eq 1 ]]; then first=0; else printf ','; fi
      printf '{"id":'; json_str "$STEP_ID"
      printf ',"desc":'; json_str "$STEP_DESC"
      printf ',"deps":[],"done_when":null,"gate":null,"status":"pending","evidence":[]}'
    done
    printf ']}\n'
  } > "$path"
}

task_init() { # <agent_id> <task_title> <frozen_round> [step_spec...]
  local agent_id="$1" task_title="$2" frozen_round="$3" task_file task_dir tmp
  shift 3
  if [[ -z "$task_title" ]]; then
    echo "错误: peer task init 需要 --task。" >&2
    return 1
  fi
  if [[ $# -eq 0 ]]; then
    echo "错误: peer task init 至少需要一个 --step <id>:<desc>。" >&2
    return 1
  fi
  if ! is_positive_int "$frozen_round"; then
    echo "错误: --round 必须是正整数。" >&2
    return 1
  fi
  task_file="$(task_file_for_id "$agent_id")"
  task_dir="${task_file%/*}"
  mkdir -p "$task_dir"
  if [[ -e "$task_file" ]]; then
    echo "错误: task.json 已存在: .agent-duo/state/$agent_id/task.json" >&2
    return 1
  fi
  tmp="$task_dir/.task.json.$$"
  if ! write_task_json "$tmp" "$agent_id" "$task_title" "$frozen_round" "$@"; then
    rm -f "$tmp"
    return 1
  fi
  mv "$tmp" "$task_file"
}

task_print() { # <agent_id>
  local agent_id="$1" task_file
  task_file="$(task_file_for_id "$agent_id")"
  if [[ ! -f "$task_file" ]]; then
    echo "没有 task.json: .agent-duo/state/$agent_id/task.json" >&2
    return 1
  fi
  jq -r '
    "TASK\t\(.task // "")",
    "FROZEN_AT_ROUND\t\(.frozen_at_round // "")",
    "CURRENT_STEP\t\(.current_step // "")",
    (.steps[]? | "\(.id)\t\(.status // "pending")\t\(.desc // "")")
  ' "$task_file"
}

task_next() { # <agent_id>
  local agent_id="$1" task_file
  task_file="$(task_file_for_id "$agent_id")"
  if [[ ! -f "$task_file" ]]; then
    echo "没有 task.json: .agent-duo/state/$agent_id/task.json" >&2
    return 1
  fi
  jq -r '
    def one($s): [.steps[]? | select((.status // "pending") == $s)][0];
    (one("blocked") // one("in_progress") // one("pending")) as $step
    | if $step == null then "done" else "\($step.id)\t\($step.status // "pending")\t\($step.desc // "")" end
  ' "$task_file"
}

loop_file_for_id() { # <agent_id>
  printf '%s/state/%s/loop.json' "$AGENT_DUO_DIR" "$1"
}

is_validation_id() {
  [[ "${1:-}" =~ ^[A-Za-z0-9._-]+$ ]]
}

parse_validation_pair() { # <option_name> <id:value>; sets VALIDATION_ID VALIDATION_VALUE
  local opt="$1" spec="${2:-}"
  if [[ "$spec" != *:* ]]; then
    echo "错误: $opt 需要 id:value 格式。" >&2
    return 1
  fi
  VALIDATION_ID="${spec%%:*}"
  VALIDATION_VALUE="${spec#*:}"
  if ! is_validation_id "$VALIDATION_ID"; then
    echo "错误: $opt 的 id 只能包含字母、数字、点、下划线和连字符。" >&2
    return 1
  fi
  if [[ -z "$VALIDATION_VALUE" ]]; then
    echo "错误: $opt 的 value 不能为空。" >&2
    return 1
  fi
}

validation_id_in_list() { # <id> [id...]
  local needle="$1" item
  shift || true
  for item in "$@"; do
    [[ "$item" == "$needle" ]] && return 0
  done
  return 1
}

build_validation_json() {
  local spec id cmd timeout signal first_val first_signal seen_signal i
  local -a ids cmds
  ids=()
  cmds=()
  if (( ${#loop_validations[@]} == 0 )); then
    printf '[]'
    return 0
  fi
  for spec in "${loop_validations[@]}"; do
    parse_validation_pair "--verify" "$spec" || return 1
    id="$VALIDATION_ID"
    cmd="$VALIDATION_VALUE"
    if validation_id_in_list "$id" "${ids[@]+"${ids[@]}"}"; then
      echo "错误: --verify id 重复: $id" >&2
      return 1
    fi
    ids+=("$id")
    cmds+=("$cmd")
  done
  for spec in ${loop_validation_satisfies[@]+"${loop_validation_satisfies[@]}"}; do
    parse_validation_pair "--verify-satisfies" "$spec" || return 1
    if ! validation_id_in_list "$VALIDATION_ID" "${ids[@]+"${ids[@]}"}"; then
      echo "错误: --verify-satisfies 引用了不存在的 verify id: $VALIDATION_ID" >&2
      return 1
    fi
  done
  for spec in ${loop_validation_timeouts[@]+"${loop_validation_timeouts[@]}"}; do
    parse_validation_pair "--verify-timeout" "$spec" || return 1
    if ! validation_id_in_list "$VALIDATION_ID" "${ids[@]+"${ids[@]}"}"; then
      echo "错误: --verify-timeout 引用了不存在的 verify id: $VALIDATION_ID" >&2
      return 1
    fi
    if ! is_positive_int "$VALIDATION_VALUE"; then
      echo "错误: --verify-timeout 的秒数必须是正整数。" >&2
      return 1
    fi
  done

  printf '['
  first_val=1
  for (( i=0; i<${#ids[@]}; i++ )); do
    id="${ids[$i]}"
    cmd="${cmds[$i]}"
    timeout="${AGENT_DUO_VALIDATION_TIMEOUT:-120}"
    if ! is_positive_int "$timeout"; then
      timeout="120"
    fi
    for spec in ${loop_validation_timeouts[@]+"${loop_validation_timeouts[@]}"}; do
      parse_validation_pair "--verify-timeout" "$spec" >/dev/null || return 1
      if [[ "$VALIDATION_ID" == "$id" ]]; then
        timeout="$VALIDATION_VALUE"
      fi
    done
    if [[ $first_val -eq 1 ]]; then first_val=0; else printf ','; fi
    printf '{"id":'; json_str "$id"
    printf ',"cmd":'; json_str "$cmd"
    printf ',"timeout_seconds":%s' "$timeout"
    printf ',"satisfies":['
    first_signal=1
    seen_signal=0
    for spec in ${loop_validation_satisfies[@]+"${loop_validation_satisfies[@]}"}; do
      parse_validation_pair "--verify-satisfies" "$spec" >/dev/null || return 1
      if [[ "$VALIDATION_ID" == "$id" ]]; then
        signal="$VALIDATION_VALUE"
        if [[ $first_signal -eq 1 ]]; then first_signal=0; else printf ','; fi
        json_str "$signal"
        seen_signal=1
      fi
    done
    if [[ $seen_signal -eq 0 ]]; then
      json_str "$id"
    fi
    printf ']}'
  done
  printf ']'
}

write_loop_json() { # <path> <agent_id> <mission> <max_rounds> <frozen_round> <non_goals_json> <success_json> <validation_json> <acceptance_json> <detail_trap_rounds>
  local path="$1" agent_id="$2" mission="$3" max_rounds="$4" frozen_round="$5" non_goals_json="$6" success_json="$7" validation_json="$8" acceptance_json="$9" detail_trap_rounds="${10}" now
  now="$(iso_ts)"
  {
    printf '{"protocol":"1",'
    printf '"agent_id":'; json_str "$agent_id"; printf ','
    printf '"mission":'; json_str "$mission"; printf ','
    printf '"non_goals":%s,' "$non_goals_json"
    printf '"success_signals":%s,' "$success_json"
    printf '"validation":%s,' "$validation_json"
    printf '"acceptance":%s,' "$acceptance_json"
    printf '"detail_trap_rounds":%s,' "$detail_trap_rounds"
    printf '"max_rounds":%s,' "$max_rounds"
    printf '"frozen_at_round":%s,' "$frozen_round"
    printf '"status":"active",'
    printf '"stop":{"on_terminal":true,"reason":null,"stopped_at_round":null,"stopped_at":null},'
    printf '"created_at":'; json_str "$now"; printf ','
    printf '"updated_at":'; json_str "$now"
    printf '}\n'
  } > "$path"
}

loop_init() { # <agent_id> <mission> <max_rounds> <frozen_round> <non_goals_json> <success_json> <validation_json> <acceptance_json> <detail_trap_rounds>
  local agent_id="$1" mission="$2" max_rounds="$3" frozen_round="$4" non_goals_json="$5" success_json="$6" validation_json="$7" acceptance_json="$8" detail_trap_rounds="$9"
  local loop_file loop_dir tmp
  if [[ -z "$mission" ]]; then
    echo "错误: peer loop init 需要 --mission。" >&2
    return 1
  fi
  if ! is_positive_int "$max_rounds"; then
    echo "错误: --max-rounds 必须是正整数。" >&2
    return 1
  fi
  if ! is_positive_int "$frozen_round"; then
    echo "错误: --round 必须是正整数。" >&2
    return 1
  fi
  if ! is_positive_int "$detail_trap_rounds"; then
    echo "错误: --detail-trap-rounds 必须是正整数。" >&2
    return 1
  fi
  loop_file="$(loop_file_for_id "$agent_id")"
  loop_dir="${loop_file%/*}"
  mkdir -p "$loop_dir"
  if [[ -e "$loop_file" ]]; then
    echo "错误: loop.json 已存在: .agent-duo/state/$agent_id/loop.json" >&2
    return 1
  fi
  tmp="$loop_dir/.loop.json.$$"
  if ! write_loop_json "$tmp" "$agent_id" "$mission" "$max_rounds" "$frozen_round" "$non_goals_json" "$success_json" "$validation_json" "$acceptance_json" "$detail_trap_rounds"; then
    rm -f "$tmp"
    return 1
  fi
  mv "$tmp" "$loop_file"
}

loop_reset() { # <agent_id> [max_rounds]
  local agent_id="$1" max_override="${2:-}" loop_file loop_dir tmp loop_json
  local old_max old_frozen current_round new_frozen new_max report_file report_status
  loop_file="$(loop_file_for_id "$agent_id")"
  if [[ ! -f "$loop_file" ]]; then
    echo "错误: 没有 loop.json: .agent-duo/state/$agent_id/loop.json，请先 peer loop init。" >&2
    return 1
  fi
  if ! loop_json="$(jq -c '.' "$loop_file" 2>/dev/null)"; then
    echo "错误: 无法读取 .agent-duo/state/$agent_id/loop.json。" >&2
    return 1
  fi
  old_max="$(jq -r '.max_rounds // empty' <<EOF
$loop_json
EOF
)"
  old_frozen="$(jq -r '.frozen_at_round // empty' <<EOF
$loop_json
EOF
)"
  if [[ -n "$max_override" ]]; then
    if ! is_positive_int "$max_override"; then
      echo "错误: --max-rounds 必须是正整数。" >&2
      return 1
    fi
    new_max="$max_override"
  else
    new_max="$old_max"
  fi
  if ! is_positive_int "$new_max"; then
    echo "错误: loop.json 缺少有效 max_rounds；请用 --max-rounds N 指定新预算。" >&2
    return 1
  fi
  current_round="$(report_round_for_id "$agent_id")"
  if [[ "$current_round" == "0" ]]; then
    new_frozen="$old_frozen"
  else
    new_frozen="$current_round"
  fi
  if ! is_positive_int "$new_frozen"; then
    echo "错误: loop.json 缺少有效 frozen_at_round,且当前没有 report 可重冻。" >&2
    return 1
  fi
  loop_dir="${loop_file%/*}"
  tmp="$loop_dir/.loop.json.$$"
  if ! jq -c \
    --arg ts "$(iso_ts)" \
    --argjson frozen "$new_frozen" \
    --argjson max "$new_max" '
      (.stop.on_terminal // true) as $on_terminal
      | .status = "active"
      | .frozen_at_round = $frozen
      | .max_rounds = $max
      | .stop = {on_terminal:$on_terminal, reason:null, stopped_at_round:null, stopped_at:null}
      | .updated_at = $ts
    ' "$loop_file" > "$tmp"; then
    rm -f "$tmp"
    return 1
  fi
  mv "$tmp" "$loop_file"

  report_file="$AGENT_DUO_DIR/state/$agent_id/report.json"
  if [[ -e "$report_file" ]]; then
    report_status="$(jq -r '.status // "unknown"' "$report_file" 2>/dev/null || printf 'unknown')"
    if [[ "$report_status" == "done" || "$report_status" == "failed" ]]; then
      echo "提醒: '$agent_id' 最新 report 是 $report_status,下一 tick 会按同一 report 再次停止。" >&2
      echo "      先 'peer reframe --force $agent_id \"...\"' 让它写出新的非终态 report,再续跑。" >&2
    fi
  fi
  echo "已重置 loop: $agent_id(frozen_at_round=$new_frozen, max_rounds=$new_max, active)。"
}

loop_print() { # <agent_id>
  local agent_id="$1" loop_file current_round
  loop_file="$(loop_file_for_id "$agent_id")"
  if [[ ! -f "$loop_file" ]]; then
    echo "没有 loop.json: .agent-duo/state/$agent_id/loop.json" >&2
    return 1
  fi
  current_round="$(report_round_for_id "$agent_id")"
  jq -r --argjson current_round "$current_round" '
    (.frozen_at_round // 1) as $frozen
    | (.max_rounds // 0) as $max
    | ($current_round - $frozen + 1) as $used
    | "MISSION\t\(.mission // "")",
      "STATUS\t\(.status // "active")",
      "ROUND\t\($current_round)",
      "FROZEN_AT_ROUND\t\($frozen)",
      "MAX_ROUNDS\t\($max)",
      "DETAIL_TRAP_ROUNDS\t\(.detail_trap_rounds // 3)",
      "ROUNDS_USED\t\($used)",
      "REMAINING\t\($max - $used)",
      "STOP_REASON\t\(.stop.reason // "")",
      "NON_GOALS\t\((.non_goals // []) | join("; "))",
      "SUCCESS_SIGNALS\t\((.success_signals // []) | join("; "))",
      "VERIFY\t\((.validation // []) | map(((.id // "") | tostring) + ":" + ((.cmd // "") | tostring)) | join("; "))",
      "JUDGE\t\((.acceptance.reviews // []) | map(((.role // "") | tostring) + ":" + ((.veto_on // []) | join(","))) | join("; "))"
  ' "$loop_file"
}

loop_guard_command() { # <agent_id> <command_name>
  local agent_id="$1" command_name="${2:-ask}" loop_file loop_json status reason max_rounds frozen_round current_round rounds_used
  loop_file="$(loop_file_for_id "$agent_id")"
  [[ -e "$loop_file" ]] || return 0
  if ! loop_json="$(jq -c '.' "$loop_file" 2>/dev/null)"; then
    echo "警告: 无法读取 .agent-duo/state/$agent_id/loop.json，loop 边界本次 fail-open；broker 门仍会照常执行。" >&2
    return 0
  fi
  status="$(jq -r '.status // "active"' <<EOF
$loop_json
EOF
)"
  max_rounds="$(jq -r '.max_rounds // empty' <<EOF
$loop_json
EOF
)"
  frozen_round="$(jq -r '.frozen_at_round // empty' <<EOF
$loop_json
EOF
)"
  if [[ "$status" == "stopped" ]]; then
    reason="$(jq -r '.stop.reason // "unknown"' <<EOF
$loop_json
EOF
)"
    echo "错误: worker '$agent_id' 的 loop 已到界(reason=$reason),已拒绝继续派发。" >&2
    echo "      经人确认后用 'peer $command_name --force $agent_id \"...\"' 越界,或后续用 'peer loop reset $agent_id' 重新给预算。" >&2
    return 1
  fi
  if ! is_positive_int "$max_rounds" || ! is_positive_int "$frozen_round"; then
    echo "警告: .agent-duo/state/$agent_id/loop.json 边界字段无效，loop 边界本次 fail-open；broker 门仍会照常执行。" >&2
    return 0
  fi
  current_round="$(report_round_for_id "$agent_id")"
  rounds_used="$(( current_round - frozen_round + 1 ))"
  if (( rounds_used > 0 && rounds_used >= max_rounds )); then
    echo "错误: worker '$agent_id' 的 loop 已到界(reason=max_rounds, ${rounds_used}/${max_rounds}),已拒绝继续派发。" >&2
    echo "      经人确认后用 'peer $command_name --force $agent_id \"...\"' 越界,或后续用 'peer loop reset $agent_id' 重新给预算。" >&2
    return 1
  fi
}

loop_guard_ask() { # <agent_id>
  loop_guard_command "$1" "ask"
}

loop_guard_reframe() { # <agent_id>
  loop_guard_command "$1" "reframe"
}

report_summary_from_file() { # <report_file>
  jq -r '
    def clean: if . == null then "" else tostring | gsub("[\r\n\t]"; " ") end;
    (.delta | clean) as $delta
    | (.next | clean) as $next
    | ((.needs // [])[0] // {}) as $need
    | ($need.detail | clean) as $detail
    | ($need.kind | clean) as $kind
    | if $delta != "" then $delta
      elif $next != "" then $next
      elif $detail != "" then $detail
      elif $kind != "" then "needs:\($kind)"
      else "\(.type // "report")/\(.status // "unknown")"
      end
  ' "$1"
}

ask_print_report() { # <agent_id> <round>
  local agent_id="$1" round="$2" file ref status delta next_text needs summary
  file="$(report_file_for_round "$agent_id" "$round")"
  ref=".agent-duo/state/$agent_id/r${round}.json"
  if [[ ! -f "$file" ]]; then
    file="$AGENT_DUO_DIR/state/$agent_id/report.json"
    ref=".agent-duo/state/$agent_id/report.json"
  fi
  if [[ ! -f "$file" ]]; then
    echo "错误: 找不到新 report 文件: .agent-duo/state/$agent_id/r${round}.json" >&2
    return 1
  fi
  status="$(jq -r '.status // "unknown"' "$file")"
  delta="$(jq -r '.delta // ""' "$file")"
  next_text="$(jq -r '.next // ""' "$file")"
  needs="$(jq -c '.needs // []' "$file")"
  summary="$(report_summary_from_file "$file")"
  printf 'ROUND\t%s\n' "$round"
  printf 'STATUS\t%s\n' "$status"
  printf 'SUMMARY\t%s\n' "$summary"
  printf 'DELTA\t%s\n' "$delta"
  printf 'NEXT\t%s\n' "$next_text"
  printf 'NEEDS\t%s\n' "$needs"
  printf 'REF\t%s\n' "$ref"
}

check_target_dispatch_allowed() { # <target_id> <target_pane> [command_name]
  local target_id="$1" target="$2" command_name="${3:-tell}" gate_role bg_out bg_status
  # Broker 硬门:发给工作型角色(非 supervisor/daemon/loopd)时,broker 必须 fresh ready,否则拒发
  # (fail-closed)。worker/reviewer/自定义工作角色都受保护,与 lib/loop.sh 的 active-worker 模型一致。
  # 豁免:--force(FORCE_SEND)或 AGENT_DUO_NO_BROKER_GATE=1。approval check 探针不经 tell,天然豁免。
  gate_role="$(role_for_id "$target_id")"
  if role_is_gated "$gate_role" \
     && [[ "${FORCE_SEND:-0}" != "1" && "${AGENT_DUO_NO_BROKER_GATE:-0}" != "1" ]]; then
    bg_out="$(run_approval_broker status --agent-id "$target_id" --root "$AGENT_DUO_ROOT" 2>/dev/null)"
    case "$bg_out" in
      *'"status":"ready"'*) ;;  # fresh ready → 放行
      *)
        bg_status="$(printf '%s' "$bg_out" | grep -o '"status":"[^"]*"' | head -1)"
        echo "错误: '$target_id' 的 Approval Broker 非 fresh ready（${bg_status:-未知}），已拒绝派发。" >&2
        echo "      先运行 'peer approval check $target_id' 验证 broker 生效，或用 'peer $command_name --force $target_id ...' 强制发送。" >&2
        return 1
        ;;
    esac
  fi
  check_safe_to_send_keys "$target"
}

task_step_exists() { # <task_file> <step_id>
  jq -e --arg id "$2" 'any(.steps[]?; .id == $id)' "$1" >/dev/null 2>&1
}

task_all_steps_done() { # <task_file>
  jq -e '
    ((.steps // []) | length) > 0 and
    ([.steps[]? | select((.status // "pending") != "done" and (.status // "pending") != "kept")] | length) == 0
  ' "$1" >/dev/null 2>&1
}

task_evidence_json() { # <cmd> <result> <ref>
  local cmd="$1" result="$2" ref="$3"
  if [[ -z "$cmd" && -z "$result" && -z "$ref" ]]; then
    printf '[]'
    return
  fi
  printf '[{"cmd":'; json_str "$cmd"
  printf ',"result":'; json_str "$result"
  printf ',"ref":'; json_str "$ref"
  printf '}]'
}

task_step_status_for_report() { # <report_type> <report_status> <effective_status>
  local report_type="$1" report_status="$2" effective_status="$3"
  if [[ "$report_status" == "done" && "$effective_status" != "unknown" ]]; then
    printf 'done'
    return 0
  fi
  if [[ "$report_type" == "request" || "$effective_status" == "blocked" ]]; then
    printf 'blocked'
    return 0
  fi
  case "$effective_status" in
    in_progress|failed) printf '%s' "$effective_status" ;;
    *) return 1 ;;
  esac
}

task_prepare_update() { # <task_file> <tmp_file> <step_id> <step_status> <round> <evidence_json>
  local task_file="$1" tmp_file="$2" step_id="$3" step_status="$4" round_s="$5" evidence_json="$6"
  if ! task_step_exists "$task_file" "$step_id"; then
    echo "错误: task.json 中不存在 step '$step_id'。" >&2
    return 1
  fi
  if ! is_step_status "$step_status"; then
    echo "错误: 非法 step 状态 '$step_status'。" >&2
    return 1
  fi
  jq -c \
    --arg id "$step_id" \
    --arg status "$step_status" \
    --arg ts "$(iso_ts)" \
    --argjson round "$round_s" \
    --argjson evidence "$evidence_json" '
      .updated_at = $ts
      | .current_step = (if ($status == "done" or $status == "kept") then null else $id end)
      | .steps |= map(
          if .id == $id then
            .status = $status
            | .last_round = $round
            | if $status == "done" then .evidence = ((.evidence // []) + $evidence) else . end
          else . end
        )
    ' "$task_file" > "$tmp_file"
}

append_event_json() {
  local queue="$1" event_id="$2" ts="$3" agent="$4" event_type="$5" round_s="$6" summary="$7" ref="$8"
  # 先把整行拼好，再单次 printf 追加：queue.jsonl 是多进程共享(loopd / 各 agent /
  # approval broker)，多次 printf 共享 append 重定向会在并发下交错损坏行。
  local line
  line="$(
    printf '{"id":'; json_str "$event_id"
    printf ',"ts":'; json_str "$ts"
    printf ',"agent":'; json_str "$agent"
    printf ',"type":'; json_str "$event_type"
    printf ',"round":%s' "$round_s"
    printf ',"summary":'; json_str "$summary"
    printf ',"ref":'; json_str "$ref"
    printf '}'
  )"
  printf '%s\n' "$line" >> "$queue"
}

json_array() {
  local first=1 item
  printf '['
  for item in "$@"; do
    if [[ $first -eq 1 ]]; then first=0; else printf ','; fi
    json_str "$item"
  done
  printf ']'
}

gates_dir() {
  printf '%s/gates' "$AGENT_DUO_DIR"
}

logs_dir() {
  printf '%s/logs' "$AGENT_DUO_DIR"
}

validation_file_for_round() { # <agent_id> <round>
  printf '%s/state/%s/validation-r%s.json' "$AGENT_DUO_DIR" "$1" "$2"
}

validation_running_file_for_round() { # <agent_id> <round>
  printf '%s/state/%s/validation-r%s.running' "$AGENT_DUO_DIR" "$1" "$2"
}

verify_state_json() { # <agent_id> <round>
  local agent_id="$1" round_s="$2" loop_file validation_file running_file report_file
  local loop_json validation_json has_report is_running
  loop_file="$(loop_file_for_id "$agent_id")"
  if [[ ! -f "$loop_file" ]]; then
    echo "错误: 没有 loop.json: .agent-duo/state/$agent_id/loop.json，请先 peer loop init。" >&2
    return 1
  fi
  if ! loop_json="$(jq -c '.' "$loop_file" 2>/dev/null)"; then
    echo "错误: 无法读取 .agent-duo/state/$agent_id/loop.json。" >&2
    return 1
  fi
  if ! is_nonnegative_int "$round_s"; then
    echo "错误: --round 必须是非负整数。" >&2
    return 1
  fi
  validation_file="$(validation_file_for_round "$agent_id" "$round_s")"
  running_file="$(validation_running_file_for_round "$agent_id" "$round_s")"
  report_file="$AGENT_DUO_DIR/state/$agent_id/report.json"
  validation_json="null"
  if [[ -f "$validation_file" ]]; then
    validation_json="$(jq -c '.' "$validation_file" 2>/dev/null || printf 'null')"
  fi
  has_report=0
  [[ -e "$report_file" ]] && has_report=1
  is_running=0
  [[ -e "$running_file" && ! -f "$validation_file" ]] && is_running=1
  jq -cn \
    --arg agent "$agent_id" \
    --argjson round "$round_s" \
    --argjson loop "$loop_json" \
    --argjson validation "$validation_json" \
    --argjson has_report "$has_report" \
    --argjson is_running "$is_running" '
      ($loop.validation // []) as $defs
      | (if (($defs | length) == 0) then "no_gates"
         elif $validation != null then ($validation.status // "unknown")
         elif $is_running == 1 then "running"
         elif $has_report == 0 then "pending"
         else "not_run" end) as $round_status
      | {
          agent:$agent,
          round:$round,
          round_status:$round_status,
          gates: [
            $defs[]? as $gate
            | (($validation.results // []) | map(select((.id // "") == ($gate.id // ""))) | .[0] // null) as $result
            | {
                id:($gate.id // ""),
                cmd:($gate.cmd // ""),
                satisfies:(($gate.satisfies // []) | map(tostring)),
                status:(
                  if $result != null then ($result.status // "unknown")
                  elif $validation != null then "not_run"
                  elif $is_running == 1 then "running"
                  elif $has_report == 0 then "pending"
                  else "not_run" end
                ),
                result:$result
              }
          ]
        }
    '
}

verify_print_ls() { # <json>
  jq -r '
    if ((.gates // []) | length) == 0 then
      "没有 verify gate。"
    else
      (.gates[] | "\(.id)\t\(.status)")
    end
  ' <<< "$1"
}

verify_print_show() { # <json>
  jq -r '
    "VERIFY\t\(.agent) @ r\(.round) \(.round_status)",
    (if ((.gates // []) | length) == 0 then
      "没有 verify gate。"
    else
      (.gates[] |
        "GATE\t\(.id)\t\(.status)",
        "CMD\t\(.cmd)",
        "SATISFIES\t\((.satisfies // []) | join("; "))",
        "RESULT\t\(if .result == null then "-" else (.result | tostring) end)"
      )
    end)
  ' <<< "$1"
}

judge_records_json() { # <agent_id>
  local agent_id="$1" state_dir reviews_dir file base any
  state_dir="$AGENT_DUO_DIR/state/$agent_id"
  reviews_dir="$state_dir/reviews"
  if [[ ! -d "$state_dir" ]]; then
    echo "错误: 没有该 agent 的 state: .agent-duo/state/$agent_id" >&2
    return 1
  fi
  any=0
  for file in "$reviews_dir"/*.json; do
    [[ -f "$file" ]] || continue
    any=1
    base="${file##*/}"
    jq -c --arg ref ".agent-duo/state/$agent_id/reviews/$base" '
      {
        verdict:(.verdict // ""),
        by:(.by // ""),
        role:(.role // ""),
        target_round:(.target_round // 0),
        ts:(.ts // ""),
        ref:$ref
      }
    ' "$file" 2>/dev/null || true
  done | jq -s '
    sort_by([
      -((.target_round // 0) | tonumber),
      ((.ts // "") | explode | map(-.)),
      (.role // "")
    ])
  '
  if [[ "$any" == "0" ]]; then
    return 0
  fi
}

judge_print_records() { # <json>
  jq -r '
    if length == 0 then
      "没有 judge verdict。"
    else
      (.[] | "r\(.target_round)\t\(.role)\t\(.verdict)\tby=\(.by)\t\(.ref)")
    end
  ' <<< "$1"
}

checkpoints_log_file() {
  printf '%s/checkpoints.jsonl' "$(logs_dir)"
}

append_checkpoint_log() { # <agent_id> <round> <message>
  local agent_id="$1" round_s="$2" message="$3" line
  mkdir -p "$(logs_dir)"
  line="$(
    printf '{"ts":'; json_str "$(iso_ts)"
    printf ',"type":"reframe"'
    printf ',"agent":'; json_str "$agent_id"
    printf ',"by":'; json_str "$ME"
    printf ',"round":%s' "$round_s"
    printf ',"message":'; json_str "$message"
    printf '}'
  )"
  printf '%s\n' "$line" >> "$(checkpoints_log_file)"
}

checkpoint_detail_trap_rounds() { # <agent_id>
  local loop_file value
  loop_file="$(loop_file_for_id "$1")"
  value="3"
  if [[ -f "$loop_file" ]]; then
    value="$(jq -r '.detail_trap_rounds // 3' "$loop_file" 2>/dev/null || printf '3')"
  fi
  if ! is_positive_int "$value"; then
    value="3"
  fi
  printf '%s' "$value"
}

checkpoint_loop_json() { # <agent_id> <current_round>
  local agent_id="$1" current_round="$2" loop_file
  loop_file="$(loop_file_for_id "$agent_id")"
  if [[ ! -f "$loop_file" ]]; then
    printf 'null'
    return 0
  fi
  jq -c --argjson current_round "$current_round" '
    (.frozen_at_round // 1) as $frozen
    | (.max_rounds // 0) as $max
    | (if $current_round > 0 then ($current_round - $frozen + 1) else 0 end) as $used
    | {
        mission:(.mission // ""),
        non_goals:(.non_goals // []),
        success_signals:(.success_signals // []),
        status:(.status // "active"),
        max_rounds:$max,
        frozen_at_round:$frozen,
        detail_trap_rounds:(.detail_trap_rounds // 3),
        current_round:$current_round,
        rounds_used:$used,
        remaining:($max - $used),
        stop_reason:(.stop.reason // null)
      }
  ' "$loop_file" 2>/dev/null || printf 'null'
}

checkpoint_recent_json() { # <agent_id> <current_round>
  local agent_id="$1" current_round="$2" n start i file item first
  n="$(checkpoint_detail_trap_rounds "$agent_id")"
  if ! is_positive_int "$current_round" || [[ "$current_round" == "0" ]]; then
    printf '[]'
    return 0
  fi
  start="$(( current_round - n + 1 ))"
  if (( start < 1 )); then start=1; fi
  printf '['
  first=1
  i="$start"
  while (( i <= current_round )); do
    file="$(report_file_for_round "$agent_id" "$i")"
    if [[ -f "$file" ]]; then
      item="$(jq -c '{round:(.round // 0),status:(.status // "unknown"),delta:(.delta // ""),drift:(.drift // null)}' "$file" 2>/dev/null || true)"
      if [[ -n "$item" ]]; then
        if [[ $first -eq 1 ]]; then first=0; else printf ','; fi
        printf '%s' "$item"
      fi
    fi
    i="$(( i + 1 ))"
  done
  printf ']'
}

checkpoint_steps_json() { # <agent_id>
  local task_file
  task_file="$(task_file_for_id "$1")"
  if [[ ! -f "$task_file" ]]; then
    printf 'null'
    return 0
  fi
  jq -c '
    (.steps // []) as $steps
    | {
        task:(.task // ""),
        current_step:(.current_step // null),
        counts:{
          done:($steps | map(select(((.status // "pending") == "done") or ((.status // "pending") == "kept"))) | length),
          in_progress:($steps | map(select((.status // "pending") == "in_progress")) | length),
          blocked:($steps | map(select((.status // "pending") == "blocked")) | length),
          pending:($steps | map(select((.status // "pending") == "pending")) | length),
          failed:($steps | map(select((.status // "pending") == "failed")) | length)
        }
      }
  ' "$task_file" 2>/dev/null || printf 'null'
}

checkpoint_validation_json() { # <agent_id> <current_round>
  local agent_id="$1" current_round="$2" validation_file
  if ! is_positive_int "$current_round" || [[ "$current_round" == "0" ]]; then
    printf 'null'
    return 0
  fi
  validation_file="$(validation_file_for_round "$agent_id" "$current_round")"
  if [[ ! -f "$validation_file" ]]; then
    printf 'null'
    return 0
  fi
  jq -c '{round:(.round // 0),status:(.status // "unknown"),missing_signals:(.missing_signals // []),failed_validations:(.failed_validations // [])}' \
    "$validation_file" 2>/dev/null || printf 'null'
}

checkpoint_json() { # <agent_id>
  local agent_id="$1" current_round loop_json recent_json steps_json validation_json
  current_round="$(report_round_for_id "$agent_id")"
  loop_json="$(checkpoint_loop_json "$agent_id" "$current_round")"
  recent_json="$(checkpoint_recent_json "$agent_id" "$current_round")"
  steps_json="$(checkpoint_steps_json "$agent_id")"
  validation_json="$(checkpoint_validation_json "$agent_id" "$current_round")"
  jq -cn \
    --arg agent "$agent_id" \
    --argjson round "$current_round" \
    --argjson loop "$loop_json" \
    --argjson recent "$recent_json" \
    --argjson steps "$steps_json" \
    --argjson validation "$validation_json" '
      {agent:$agent, round:$round, recent:$recent}
      | if $loop == null then . else . + {loop:$loop} end
      | if $steps == null then . else . + {steps:$steps} end
      | if $validation == null then . else . + {validation:$validation} end
    '
}

checkpoint_print() { # <agent_id>
  local json
  json="$(checkpoint_json "$1")"
  jq -r '
    def clean: if . == null then "" else tostring | gsub("[\r\n\t]"; " ") end;
    def drift_text:
      (.drift | clean) as $d
      | if $d == "" then "-" else "\"" + $d + "\"" end;
    [
      ("CHECKPOINT\t\(.agent) @ r\(.round) " +
        (if .loop? then "(loop \(.loop.status), used \(.loop.rounds_used)/\(.loop.max_rounds))" else "(loop none)" end)),
      (if .loop? then "MISSION\t\(.loop.mission // "")" else empty end),
      (if .loop? then "NON_GOALS\t\((.loop.non_goals // []) | join("; "))" else empty end),
      (if .loop? then "SUCCESS_SIGNALS\t\((.loop.success_signals // []) | join("; "))" else empty end),
      (.recent[]? | "RECENT\tr\(.round) \(.status) delta=\"\(.delta | clean)\" drift=\(drift_text)"),
      (if .steps? then
        "STEPS\t\(.steps.counts.done) done, \(.steps.counts.in_progress) in_progress, \(.steps.counts.blocked) blocked, \(.steps.counts.pending) pending, \(.steps.counts.failed) failed (current: \(.steps.current_step // "-"))"
       else empty end),
      (if .validation? then
        "VERIFY\tr\(.validation.round) \(.validation.status)" +
        (if ((.validation.missing_signals // []) | length) > 0 then " - missing: \((.validation.missing_signals // []) | join("; "))" else "" end) +
        (if ((.validation.failed_validations // []) | length) > 0 then " - failed: \((.validation.failed_validations // []) | join("; "))" else "" end)
       else empty end)
    ] | .[]
  ' <<EOF
$json
EOF
}

gate_path() { # <gate_id>
  printf '%s/%s.json' "$(gates_dir)" "$1"
}

new_gate_id() { # <round>
  printf 'g%s-r%s-%s' "$(date -u '+%Y%m%dT%H%M%SZ')" "$1" "$$"
}

write_gate_json() {
  local path="$1" gate_id="$2" ts="$3" agent_id="$4" role="$5" round_s="$6"
  local title="$7" detail="$8" report_ref="$9" options_json="${10}"
  {
    printf '{"protocol":"1",'
    printf '"id":'; json_str "$gate_id"; printf ','
    printf '"status":"pending",'
    printf '"kind":"decision",'
    printf '"agent_id":'; json_str "$agent_id"; printf ','
    printf '"role":'; json_str "$role"; printf ','
    printf '"round":%s,' "$round_s"
    printf '"title":'; json_str "$title"; printf ','
    printf '"detail":'; json_nullable_str "$detail"; printf ','
    printf '"options":%s,' "$options_json"
    printf '"report_ref":'; json_nullable_str "$report_ref"; printf ','
    printf '"created_at":'; json_str "$ts"; printf ','
    printf '"resolved_at":null,"resolved_by":null,"choice":null,"note":null'
    printf '}\n'
  } > "$path"
}

append_decision_log() {
  local gate_id="$1" status="$2" agent="$3" summary="$4" choice="$5" note="$6"
  local log line
  mkdir -p "$(logs_dir)"
  log="$(logs_dir)/decisions.jsonl"
  line="$(
    printf '{"ts":'; json_str "$(iso_ts)"
    printf ',"gate":'; json_str "$gate_id"
    printf ',"status":'; json_str "$status"
    printf ',"agent":'; json_str "$agent"
    printf ',"summary":'; json_str "$summary"
    printf ',"choice":'; json_nullable_str "$choice"
    printf ',"note":'; json_nullable_str "$note"
    printf '}'
  )"
  printf '%s\n' "$line" >> "$log"
}

create_gate_record() { # <gate_id> <ts> <agent> <role> <round> <title> <detail> <report_ref> [option...]
  local gate_id="$1" ts="$2" agent="$3" role="$4" round_s="$5" title="$6" detail="$7" report_ref="$8"
  local dir path tmp options_json
  shift 8
  dir="$(gates_dir)"
  mkdir -p "$dir"
  path="$(gate_path "$gate_id")"
  if [[ -e "$path" ]]; then
    echo "错误: gate 已存在: $gate_id" >&2
    return 1
  fi
  options_json="$(json_array "$@")"
  tmp="$dir/.${gate_id}.json.$$"
  write_gate_json "$tmp" "$gate_id" "$ts" "$agent" "$role" "$round_s" "$title" "$detail" "$report_ref" "$options_json"
  mv "$tmp" "$path"
}

gate_pending_ids() {
  local dir file
  dir="$(gates_dir)"
  for file in "$dir"/*.json; do
    [[ -f "$file" ]] || continue
    jq -r 'select((.status // "pending") == "pending") | .id // empty' "$file" 2>/dev/null || true
  done
}

gate_pick_unique_pending() {
  local ids count
  ids="$(gate_pending_ids | sed '/^$/d')"
  if [[ -z "$ids" ]]; then
    count="0"
  else
    count="$(printf '%s\n' "$ids" | wc -l | tr -d ' ')"
  fi
  case "$count" in
    0) return 1 ;;
    1) printf '%s' "$ids"; return 0 ;;
    *)
      echo "错误: 存在多个 pending gate,请指定 gate id。可用 'peer gate ls' 查看。" >&2
      return 2
      ;;
  esac
}

gate_pending_ids_for_agent() { # <agent_id>
  local agent="$1" dir file
  dir="$(gates_dir)"
  for file in "$dir"/*.json; do
    [[ -f "$file" ]] || continue
    jq -r --arg agent "$agent" '
      select((.status // "pending") == "pending" and (.agent_id // "") == $agent) | .id // empty
    ' "$file" 2>/dev/null || true
  done
}

gate_pick_unique_pending_for_agent() { # <agent_id>
  local agent="$1" ids count
  ids="$(gate_pending_ids_for_agent "$agent" | sed '/^$/d')"
  if [[ -z "$ids" ]]; then
    count="0"
  else
    count="$(printf '%s\n' "$ids" | wc -l | tr -d ' ')"
  fi
  case "$count" in
    0) return 1 ;;
    1) printf '%s' "$ids"; return 0 ;;
    *)
      echo "错误: agent '$agent' 存在多个 pending gate,请指定 gate id。可用 'peer gate ls' 查看。" >&2
      return 2
      ;;
  esac
}

gate_print_list() { # <show_all:0|1>
  local show_all="$1" dir file row id status agent round title options any
  any=0
  dir="$(gates_dir)"
  for file in "$dir"/*.json; do
    [[ -f "$file" ]] || continue
    status="$(jq -r '.status // "pending"' "$file" 2>/dev/null || printf 'pending')"
    if [[ "$show_all" != "1" && "$status" != "pending" ]]; then
      continue
    fi
    if [[ "$any" == "0" ]]; then
      printf '%-24s %-10s %-10s %-8s %s\n' "ID" "STATUS" "AGENT" "ROUND" "TITLE"
    fi
    any=1
    row="$(jq -r '
      [
        (.id // ""),
        (.status // "pending"),
        (.agent_id // ""),
        ("r" + ((.round // 0) | tostring)),
        ((.title // .detail // "") | gsub("[\r\n\t]"; " ")),
        ((.options // []) | join(","))
      ] | @tsv
    ' "$file" 2>/dev/null || true)"
    IFS=$'\t' read -r id status agent round title options <<< "$row"
    printf '%-24s %-10s %-10s %-8s %s' "$id" "$status" "$agent" "$round" "$(printf '%s' "$title" | cut -c1-80)"
    if [[ -n "$options" ]]; then
      printf ' [options: %s]' "$options"
    fi
    printf '\n'
  done
  if [[ "$any" == "0" ]]; then
    if [[ "$show_all" == "1" ]]; then
      printf '没有 human gate。\n'
    else
      printf '没有待处理 human gate。\n'
    fi
  fi
}

gate_field() { # <gate_id> <jq_expr>
  local path
  path="$(gate_path "$1")"
  [[ -f "$path" ]] || return 1
  jq -r "$2 // empty" "$path"
}

gate_resolve_record() { # <gate_id> <choice> <note>
  local gate_id="$1" choice="$2" note="$3" path tmp agent summary
  path="$(gate_path "$gate_id")"
  if [[ ! -f "$path" ]]; then
    echo "错误: 找不到 gate '$gate_id'。" >&2
    return 1
  fi
  if [[ "$(jq -r '.status // "pending"' "$path")" != "pending" ]]; then
    echo "错误: gate '$gate_id' 不是 pending。" >&2
    return 1
  fi
  tmp="${path}.$$"
  jq -c --arg ts "$(iso_ts)" --arg by "$ME" --arg choice "$choice" --arg note "$note" '
    .status = "resolved"
    | .resolved_at = $ts
    | .resolved_by = $by
    | .choice = $choice
    | .note = (if $note == "" then null else $note end)
  ' "$path" > "$tmp"
  mv "$tmp" "$path"
  agent="$(jq -r '.agent_id // ""' "$path")"
  summary="$(jq -r '.detail // .title // ""' "$path")"
  append_decision_log "$gate_id" "resolved" "$agent" "$summary" "$choice" "$note"
}

screen_has_round_sentinel() { # <screen> <round> <agent_id> [codec_tag]
  local screen="$1" round="$2" agent_id="$3" tag="${4:-}"
  printf '%s\n' "$screen" | awk -v r="round=${round}" -v a="agent_id=${agent_id}" -v tag="$tag" '
    index($0, "«AGENTDUO:") {
      if (tag != "" && index($0, "«AGENTDUO:" tag "»") == 0) next
      has_round=0; has_agent=0; has_file=0; has_sha=0
      for (i = 1; i <= NF; i++) {
        if ($i == r) has_round=1
        if ($i == a) has_agent=1
        if (index($i, "file=") == 1 && length($i) > 5) has_file=1
        if (index($i, "sha=") == 1 && length($i) > 4) has_sha=1
      }
      if (has_round && has_agent && has_file && has_sha) found=1
    }
    END { exit found ? 0 : 1 }
  '
}

ensure_session() {
  local err
  if ! err="$(tmux list-panes -s -t "$SESSION" -F '#{pane_id}' 2>&1 >/dev/null)"; then
    echo "错误: tmux 会话 '$SESSION' 不存在或不可访问。" >&2
    if [[ -n "$err" ]]; then
      echo "tmux: $err" >&2
    fi
    exit 1
  fi
}

capture() { # <pane> <lines>
  local pane="$1" lines="${2:-80}"
  tmux capture-pane -p -J -t "$pane" -S "-$lines"
}

capture_visible() { # <pane>
  local pane="$1"
  tmux capture-pane -p -J -t "$pane"
}

matches_screen() {
  local screen="$1" pattern="$2"
  printf '%s\n' "$screen" | grep -Eiq "$pattern"
}

looks_like_prompt() {
  local screen="$1"

  # Claude/Codex option menus: a selector cursor plus explicit Yes/No choices.
  if matches_screen "$screen" '^[[:space:]]*(❯|›)[[:space:]]' &&
     matches_screen "$screen" '^[[:space:]]*[12]\.[[:space:]]*(yes|no)([[:space:]]|$)|^[[:space:]]*(yes|no)[[:space:]]*/[[:space:]]*(no|yes)([[:space:]]|$)|^[[:space:]]*(❯|›)[[:space:]]*([12]\.[[:space:]]*)?(yes|no)([[:space:]]|$)'; then
    return 0
  fi

  local pattern
  while IFS= read -r pattern; do
    [[ -z "$pattern" || "${pattern:0:1}" == "#" ]] && continue
    if matches_screen "$screen" "$pattern"; then
      return 0
    fi
  done <<'PATTERNS'
# Claude/Codex natural-language proceed prompts.
do you want to proceed
# Permission approval wording; avoid matching "approved" history.
(^|[^[:alpha:]])approve([^[:alpha:]]|$)
# Command permission prompt wording.
allow command
# Compact y/n prompts.
\([[:space:]]*y[[:space:]]*/[[:space:]]*n[[:space:]]*\)
# Bracketed y/n prompts.
\[[[:space:]]*y[[:space:]]*/[[:space:]]*n[[:space:]]*\]
# Confirmation UIs that ask Enter to accept/continue.
press enter to
# Chinese permission/confirmation wording.
是否|允许|确认|继续吗
PATTERNS
  return 1
}

check_safe_to_send_keys() { # <pane>
  local pane="$1"
  if [[ "$FORCE_SEND" == "1" || "${PEER_FORCE:-0}" == "1" ]]; then
    echo "提示: 已跳过对方权限弹窗检测(--force / PEER_FORCE=1)。" >&2
    return 0
  fi

  local screen
  screen="$(capture_visible "$pane")"
  if looks_like_prompt "$screen"; then
    echo "错误: 目标 agent 疑似正在等待权限确认/弹窗,peer 未发送按键。请人工查看;如确认强制发送,用 --force 或 PEER_FORCE=1。" >&2
    exit 3
  fi
}

paste_buffer_and_enter() { # <pane> <buffer_name>
  local pane="$1" buf="$2"
  # -p: bracketed paste,TUI 将其识别为一次完整粘贴(多行不会被逐行提交)
  # -d: 粘贴后删除缓冲区
  tmux paste-buffer -b "$buf" -t "$pane" -d -p
  # 给 TUI 一点处理粘贴的时间,立刻回车可能被吞掉。
  sleep 0.5
  tmux send-keys -t "$pane" Enter
}

send_text_to_pane() { # <pane> <buffer_name> <text>
  local pane="$1" buf="$2" text="$3"
  printf '%s' "$text" | tmux load-buffer -b "$buf" -
  paste_buffer_and_enter "$pane" "$buf"
}

write_agent_launch_script() { # <agent-id> <body>
  local agent_id="$1" body="$2" dir path tmp
  dir="$AGENT_DUO_DIR/state/$agent_id"
  path="$dir/launch.sh"
  mkdir -p "$dir"
  tmp="$path.$$"
  {
    printf '#!/usr/bin/env bash\n'
    printf 'set -uo pipefail\n'
    printf '%s\n' "$body"
    cat <<'EOF'
status=$?
printf '\n[agent-duo] launch exited with status %s\n' "$status" >&2
exec "${SHELL:-/bin/zsh}" -l
EOF
  } > "$tmp"
  chmod +x "$tmp"
  mv -f "$tmp" "$path"
  printf '%s' "$path"
}

launch_script_command() { # <script-path>
  printf '/bin/bash %q' "$1"
}

FORCE_SEND=0
if [[ "${1:-}" == "--force" ]]; then
  FORCE_SEND=1
  shift
fi

cmd="${1:-help}"
shift || true

case "$cmd" in
  agent)
    subcmd="${1:-}"
    shift || true
    case "$subcmd" in
      ls)
        if [[ $# -gt 0 ]]; then
          usage_agent >&2
          exit 1
        fi
        ensure_session
        printf '%-3s %-16s %-12s %-10s %s\n' '' 'ID' 'ROLE' 'PROVIDER' 'PANE'
        while IFS=$'\t' read -r pane id role provider; do
          [[ -z "$pane" ]] && continue
          mark=' '
          if [[ -n "$SELF_PANE" && "$pane" == "$SELF_PANE" ]] || [[ -z "$SELF_PANE" && -n "$id" && "$id" == "$ME" ]]; then
            mark='*'
          fi
          if [[ -z "$id" ]]; then
            printf '%-3s %-16s %-12s %-10s %s\n' "$mark" '(unregistered)' '-' '-' "$pane"
          else
            printf '%-3s %-16s %-12s %-10s %s\n' "$mark" "$id" "$role" "$provider" "$pane"
          fi
        done < <(list_agents)
        ;;
      add)
        ensure_session
        provider=""; role=""; want_id=""; use_worktree=0
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --provider) provider="${2:-}"; shift 2 ;;
            --role)     role="${2:-}"; shift 2 ;;
            --id)       want_id="${2:-}"; shift 2 ;;
            --worktree) use_worktree=1; shift ;;
            *) echo "错误: 未知参数 '$1'。用法: peer agent add --provider claude|codex --role <role> [--id <id>] [--worktree]" >&2; exit 1 ;;
          esac
        done
        if ! reg_validate_provider "$provider"; then
          echo "错误: provider 必须是 claude 或 codex,当前为 '$provider'。" >&2; exit 1
        fi
        if [[ -z "$role" ]]; then
          echo "错误: 必须用 --role 指定角色。" >&2; exit 1
        fi
        if ! is_role_token "$role"; then
          echo "错误: --role 只能包含字母、数字、点、下划线和连字符,且必须以字母或数字开头。" >&2; exit 1
        fi
        new_id="$want_id"
        if [[ -z "$new_id" ]]; then
          new_id="$(reg_derive_id "$role" "$(agent_ids)")"
        elif ! is_role_token "$new_id"; then
          echo "错误: --id 只能包含字母、数字、点、下划线和连字符,且必须以字母或数字开头。" >&2; exit 1
        elif agent_ids | grep -qx -- "$new_id"; then
          echo "错误: id '$new_id' 已被占用。" >&2; exit 1
        fi
        agent_worktree="${AGENT_DUO_WORKTREE:-$AGENT_DUO_ROOT}"
        if [[ "$use_worktree" == "1" ]]; then
          agent_worktree="$(reg_create_worktree "$new_id" "$AGENT_DUO_ROOT" "$SESSION")"
          reg_write_worktree_record "$AGENT_DUO_ROOT" "$new_id" "$agent_worktree" "$(reg_worktree_branch "$new_id")"
        fi
        approval_settings="$(install_approval_session_settings "$new_id" "$provider" "$agent_worktree")"
        launch="$(reg_provider_launch_cmd "$provider" "$PEER_INSTR")"
        bin_dir="$(dirname "$PEER_SRC")"
        if [[ "$provider" == "claude" ]]; then
          launch="$launch --settings $(printf '%q' "$approval_settings")"
        else
          hook_command="$(jq -r '.codex.managed_hook_command' "$approval_settings")"
          # Broker-as-single-gate: agent-duo's PreToolUse hook is the worker's only
          # approval gate, so skip Codex's own hook-trust modal (we inject and vet our
          # own hooks) and its native command-approval prompts. Without these, every
          # worker pane deadlocks on "Hooks need review" and then drowns in native
          # per-command modals that the supervisor cannot dismiss.
          launch="$launch --dangerously-bypass-hook-trust --ask-for-approval untrusted"
          launch="$launch $(codex_shell_env_args "$bin_dir")"
          launch="$launch $(codex_tmux_access_args)"
          launch="$launch -c $(printf '%q' "$(codex_hook_config PreToolUse "$hook_command" "*")")"
          launch="$launch -c $(printf '%q' "$(codex_hook_config PermissionRequest "$hook_command" "*")")"
        fi
        root_q="$(printf '%q' "$AGENT_DUO_ROOT")"
        agent_q="$(printf '%q' "$new_id")"
        role_q="$(printf '%q' "$role")"
        provider_q="$(printf '%q' "$provider")"
        worktree_q="$(printf '%q' "$agent_worktree")"
        hook_q="$(printf '%q' "$APPROVAL_HOOK")"
        settings_q="$(printf '%q' "$approval_settings")"
        launch_script="$(write_agent_launch_script "$new_id" \
          "export AGENT_SESSION=$(printf '%q' "$SESSION") AGENT_DUO_ROOT=$root_q AGENT_DUO_AGENT_ID=$agent_q AGENT_DUO_AGENT_ROLE=$role_q AGENT_DUO_AGENT_PROVIDER=$provider_q AGENT_DUO_WORKTREE=$worktree_q AGENT_DUO_APPROVAL_HOOK=$hook_q AGENT_DUO_APPROVAL_SETTINGS=$settings_q PATH=$(printf '%q' "$bin_dir"):\$PATH; $launch")"
        new_pane="$(tmux new-window -t "$SESSION" -n "$new_id" -c "$agent_worktree" -P -F '#{pane_id}' "$(launch_script_command "$launch_script")")"
        tmux set-option -p -t "$new_pane" @agent_id "$new_id"
        tmux set-option -p -t "$new_pane" @agent_role "$role"
        tmux set-option -p -t "$new_pane" @agent_provider "$provider"
        if [[ "$use_worktree" == "1" ]]; then
          tmux set-option -p -t "$new_pane" @agent_worktree "$agent_worktree"
        fi
        echo "已创建 agent '$new_id'(role=$role, provider=$provider, pane=$new_pane)。"
        run_approval_broker mark --agent-id "$new_id" --status unverified --root "$AGENT_DUO_ROOT" >/dev/null 2>&1 || true
        if role_is_gated "$role"; then
          echo "提示: '$new_id' 的 Approval Broker 起始为 unverified;派任务前先运行 'peer approval check $new_id' 验证 broker 生效,否则首次 'peer tell $new_id ...' 会被硬门 fail-closed 拒发。"
        fi
        if [[ "$provider" == "codex" ]]; then
          echo "Codex 已用 --dangerously-bypass-hook-trust --ask-for-approval untrusted 启动:agent-duo Approval Broker 是它唯一的门(不再弹 hooks need review / 原生审批)。"
        fi
        ;;
      rm)
        ensure_session
        rm_id=""
        rm_force="$FORCE_SEND"
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --force) rm_force=1; shift ;;
            *)
              if [[ -n "$rm_id" ]]; then
                echo "用法: peer agent rm [--force] <id>" >&2; exit 1
              fi
              rm_id="$1"
              shift
              ;;
          esac
        done
        if [[ -z "$rm_id" ]]; then
          echo "用法: peer agent rm [--force] <id>" >&2; exit 1
        fi
        if [[ "$rm_id" == "$ME" ]]; then
          echo "错误: 不能移除自己。" >&2; exit 1
        fi
        if ! rm_pane="$(pane_for_id "$rm_id")"; then
          echo "错误: 找不到 agent '$rm_id'。" >&2; exit 1
        fi
        tmux kill-window -t "$rm_pane"
        echo "已移除 agent '$rm_id'(pane=$rm_pane)。"
        if ! reg_remove_worktree "$AGENT_DUO_ROOT" "$rm_id" "$rm_force"; then
          rc="$?"
          if [[ "$rc" != "2" ]]; then
            exit "$rc"
          fi
        fi
        ;;
      ""|--help|-h)
        usage_agent
        ;;
      *)
        usage_agent >&2
        exit 1
        ;;
    esac
    ;;

  approval)
    subcmd="${1:-}"
    shift || true
    case "$subcmd" in
      ls)
        show_all=0
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --all) show_all=1; shift ;;
            *) echo "用法: peer approval ls [--all]" >&2; exit 1 ;;
          esac
        done
        if [[ "$show_all" == "1" ]]; then
          run_approval_broker list --root "$AGENT_DUO_ROOT" --all
        else
          run_approval_broker list --root "$AGENT_DUO_ROOT"
        fi
        ;;
      approve)
        approval_id="${1:-}"
        if [[ -z "$approval_id" ]]; then
          echo "用法: peer approval approve <id>" >&2
          exit 1
        fi
        shift
        if [[ $# -gt 0 ]]; then
          echo "用法: peer approval approve <id>" >&2
          exit 1
        fi
        run_approval_broker approve --root "$AGENT_DUO_ROOT" "$approval_id"
        ;;
      deny)
        approval_id="${1:-}"
        if [[ -z "$approval_id" ]]; then
          echo "用法: peer approval deny <id> [--reason \"...\"]" >&2
          exit 1
        fi
        shift
        deny_reason=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --reason) deny_reason="${2:-}"; shift 2 ;;
            *) echo "用法: peer approval deny <id> [--reason \"...\"]" >&2; exit 1 ;;
          esac
        done
        run_approval_broker deny --root "$AGENT_DUO_ROOT" --reason "$deny_reason" "$approval_id"
        ;;
      status)
        ensure_session
        maybe_id="${1:-}"
        if [[ -z "$maybe_id" ]]; then
          maybe_id="$(reg_pick_other "$(self_id)" "$(agent_ids)")" || {
            echo "用法: peer approval status <id>(多于两人时必须指定 id)" >&2; exit 1; }
        fi
        if [[ -n "${2:-}" ]]; then
          echo "用法: peer approval status [<id>]" >&2
          exit 1
        fi
        agent_ids | grep -qx -- "$maybe_id" || { echo "错误: 找不到 agent '$maybe_id'。" >&2; exit 1; }
        bs_json="$(run_approval_broker status --agent-id "$maybe_id" --root "$AGENT_DUO_ROOT")"
        printf '%s\n' "$bs_json"
        case "$bs_json" in
          *'"status":"ready"'*) ;;
          *) echo "提示: '$maybe_id' broker 非 fresh ready,派发需 broker 保护的任务前请先 'peer approval check $maybe_id'。" >&2 ;;
        esac
        ;;
      check)
        ensure_session
        maybe_id=""; nonce=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --nonce) nonce="${2:-}"; shift 2 ;;
            *) if [[ -z "$maybe_id" ]]; then maybe_id="$1"; shift; else
                 echo "用法: peer approval check <id> [--nonce <n>]" >&2; exit 1; fi ;;
          esac
        done
        if [[ -z "$maybe_id" ]]; then
          maybe_id="$(reg_pick_other "$(self_id)" "$(agent_ids)")" || {
            echo "用法: peer approval check <id>(多于两人时必须指定 id)" >&2; exit 1; }
        fi
        agent_ids | grep -qx -- "$maybe_id" || { echo "错误: 找不到 agent '$maybe_id'。" >&2; exit 1; }
        target="$(pane_for_id "$maybe_id")"
        [[ -n "$nonce" ]] || nonce="bc$(random_hex_tag)"
        probe_cmd="$(run_approval_broker selfcheck-cmd --nonce "$nonce")"
        prompt="agent-duo broker self-check。请立刻原样执行下面这条 shell 命令,不要解释、不要询问、不要改写: ${probe_cmd}"
        check_safe_to_send_keys "$target"
        buf="peer-brokercheck-${maybe_id}"
        send_text_to_pane "$target" "$buf" "$prompt"
        echo "已向 '$maybe_id' 投递 broker 自检探针(nonce=$nonce),等待 hook 拦截…"
        timeout="${AGENT_DUO_BROKER_CHECK_TIMEOUT:-60}"
        marker="$AGENT_DUO_DIR/state/$maybe_id/broker.json"
        i=0
        while [[ "$i" -lt "$timeout" ]]; do
          if [[ -f "$marker" ]] \
            && [[ "$(jq -r '.status // ""' "$marker" 2>/dev/null)" == "ready" ]] \
            && [[ "$(jq -r '.nonce // ""' "$marker" 2>/dev/null)" == "$nonce" ]]; then
            echo "✅ broker READY:'$maybe_id' 的 Approval Broker hook 已被 provider 实际调用并拦下探针。"
            exit 0
          fi
          sleep 1
          i=$(( i + 1 ))
        done
        run_approval_broker mark --agent-id "$maybe_id" --status fail-open --root "$AGENT_DUO_ROOT" >/dev/null 2>&1 || true
        echo "⚠️  broker FAIL-OPEN:${timeout}s 内未观察到 '$maybe_id' 的 hook 拦截探针。" >&2
        echo "    很可能 Codex hook 未被信任(/hooks 里 trust),或 worker 未执行该命令。" >&2
        echo "    在该 worker 生效前,不要派给它需要 Approval Broker 保护的任务。" >&2
        exit 1
        ;;
      ""|--help|-h)
        usage_approval
        ;;
      *)
        usage_approval >&2
        exit 1
        ;;
    esac
    ;;

  peek)
    ensure_session
    maybe_id=""
    if [[ -n "${1:-}" ]] && ! is_positive_int "$1"; then maybe_id="$1"; shift; fi
    lines="${1:-80}"
    if ! is_positive_int "$lines"; then
      echo "错误: peer peek 的行数必须是正整数。" >&2
      exit 1
    fi
    target="$(resolve_target_pane "$maybe_id")"
    echo "===== 终端最近输出 ====="
    capture "$target" "$lines"
    echo "===== 输出结束 ====="
    ;;

  tell)
    ensure_session
    if [[ "${1:-}" == "--force" ]]; then
      FORCE_SEND=1
      shift
    fi
    # 首参若精确匹配某已注册 id → 作为目标消费掉。
    maybe_id=""
    if [[ -n "${1:-}" ]] && agent_ids | grep -qx -- "$1"; then
      maybe_id="$1"; shift
    fi
    target="$(resolve_target_pane "$maybe_id")"
    # 目标 id(用于 buffer 命名);两人默认时回查 other。
    if [[ -n "$maybe_id" ]]; then
      target_id="$maybe_id"
    else
      target_id="$(reg_pick_other "$ME" "$(agent_ids)")"
    fi
    check_target_dispatch_allowed "$target_id" "$target" "tell"
    buf="peer-${ME}2${target_id}"
    if [[ $# -gt 0 ]]; then
      printf '%s' "$*" | tmux load-buffer -b "$buf" -
    elif [[ ! -t 0 ]]; then
      tmux load-buffer -b "$buf" -
    else
      echo "用法: peer tell [<id>] \"消息\"  或  echo \"消息\" | peer tell [<id>]" >&2
      exit 1
    fi
    paste_buffer_and_enter "$target" "$buf"
    echo "已投递。(提示: 'peer wait' 等它完成,再 'peer peek' 查看回复)"
    ;;

  ask)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      usage_ask
      exit 0
    fi
    ensure_session
    maybe_id=""
    ask_timeout="${PEER_ASK_TIMEOUT:-300}"
    ask_interval="${PEER_ASK_INTERVAL:-5}"
    ask_parts=()
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --timeout)
          ask_timeout="${2:-}"
          shift 2
          ;;
        --interval)
          ask_interval="${2:-}"
          shift 2
          ;;
        --force)
          FORCE_SEND=1
          shift
          ;;
        --)
          shift
          while [[ $# -gt 0 ]]; do ask_parts+=("$1"); shift; done
          ;;
        *)
          if [[ -z "$maybe_id" && ${#ask_parts[@]} -eq 0 ]] && agent_ids | grep -qx -- "$1"; then
            maybe_id="$1"
          else
            ask_parts+=("$1")
          fi
          shift
          ;;
      esac
    done
    if ! is_positive_int "$ask_timeout"; then
      echo "错误: peer ask --timeout 必须是正整数。" >&2
      exit 1
    fi
    if ! is_positive_int "$ask_interval"; then
      echo "错误: peer ask --interval 必须是正整数。" >&2
      exit 1
    fi
    if [[ ${#ask_parts[@]} -eq 0 ]]; then
      usage_ask >&2
      exit 1
    fi
    target="$(resolve_target_pane "$maybe_id")"
    if [[ -n "$maybe_id" ]]; then
      target_id="$maybe_id"
    else
      target_id="$(reg_pick_other "$ME" "$(agent_ids)")"
    fi
    if [[ "${FORCE_SEND:-0}" != "1" ]]; then
      loop_guard_ask "$target_id"
    fi
    pre_round="$(report_round_for_id "$target_id")"
    check_target_dispatch_allowed "$target_id" "$target" "ask"
    buf="peer-${ME}2${target_id}-ask"
    send_text_to_pane "$target" "$buf" "${ask_parts[*]}"

    elapsed=0
    while (( elapsed < ask_timeout )); do
      current_round="$(report_round_for_id "$target_id")"
      if (( current_round > pre_round )); then
        ask_print_report "$target_id" "$current_round"
        exit 0
      fi
      sleep "$ask_interval"
      elapsed="$(( elapsed + ask_interval ))"
    done
    echo "错误: peer ask 等待 '$target_id' 写出新 report 超时(${ask_timeout}s)。" >&2
    echo "===== 目标末屏(best-effort) =====" >&2
    capture "$target" 80 >&2 || true
    echo "===== 目标末屏结束 =====" >&2
    exit 2
    ;;

  reframe)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      usage_reframe
      exit 0
    fi
    ensure_session
    maybe_id=""
    reframe_parts=()
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --force)
          FORCE_SEND=1
          shift
          ;;
        --)
          shift
          while [[ $# -gt 0 ]]; do reframe_parts+=("$1"); shift; done
          ;;
        *)
          if [[ -z "$maybe_id" && ${#reframe_parts[@]} -eq 0 ]] && agent_ids | grep -qx -- "$1"; then
            maybe_id="$1"
          else
            reframe_parts+=("$1")
          fi
          shift
          ;;
      esac
    done
    if [[ ${#reframe_parts[@]} -eq 0 ]]; then
      usage_reframe >&2
      exit 1
    fi
    reframe_message="${reframe_parts[*]}"
    if [[ ! "$reframe_message" =~ [^[:space:]] ]]; then
      echo "错误: peer reframe 需要非空消息。" >&2
      exit 1
    fi
    target="$(resolve_target_pane "$maybe_id")"
    if [[ -n "$maybe_id" ]]; then
      target_id="$maybe_id"
    else
      target_id="$(reg_pick_other "$ME" "$(agent_ids)")"
    fi
    if [[ "${FORCE_SEND:-0}" != "1" ]]; then
      loop_guard_reframe "$target_id"
    fi
    check_target_dispatch_allowed "$target_id" "$target" "reframe"
    target_round="$(report_round_for_id "$target_id")"
    buf="peer-${ME}2${target_id}-reframe"
    send_text_to_pane "$target" "$buf" "«AGENTDUO verb=reframe»"$'\n'"$reframe_message"
    append_checkpoint_log "$target_id" "$target_round" "$reframe_message"
    echo "已发送 reframe 给 '$target_id'。"
    ;;

  checkpoint)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      usage_checkpoint
      exit 0
    fi
    ensure_session
    maybe_id=""
    checkpoint_json_mode=0
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --json)
          checkpoint_json_mode=1
          shift
          ;;
        *)
          if [[ -z "$maybe_id" ]]; then
            maybe_id="$1"
            shift
          else
            usage_checkpoint >&2
            exit 1
          fi
          ;;
      esac
    done
    target="$(resolve_target_pane "$maybe_id")"
    : "${target:-}"
    if [[ -n "$maybe_id" ]]; then
      target_id="$maybe_id"
    else
      target_id="$(reg_pick_other "$ME" "$(agent_ids)")"
    fi
    if [[ ! -e "$(loop_file_for_id "$target_id")" && ! -e "$AGENT_DUO_DIR/state/$target_id/report.json" ]]; then
      echo "错误: '$target_id' 无可汇报的方向状态(loop.json/report.json 都不存在)。" >&2
      exit 1
    fi
    if [[ "$checkpoint_json_mode" == "1" ]]; then
      checkpoint_json "$target_id"
    else
      checkpoint_print "$target_id"
    fi
    ;;

  wait)
    ensure_session
    maybe_id=""
    if [[ -n "${1:-}" && "${1:-}" != "--round" && "${1:-}" != "--timeout" && "${1:-}" != "--interval" ]] && ! is_positive_int "$1"; then maybe_id="$1"; shift; fi
    target="$(resolve_target_pane "$maybe_id")"

    round_wait=""
    round_timeout="${PEER_WAIT_TIMEOUT:-300}"
    round_interval="${PEER_WAIT_INTERVAL:-5}"
    if [[ "${1:-}" == --* ]]; then
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --round)
            round_wait="${2:-}"
            shift 2
            ;;
          --timeout)
            round_timeout="${2:-}"
            shift 2
            ;;
          --interval)
            round_interval="${2:-}"
            shift 2
            ;;
          *)
            echo "用法: peer wait [<id>] --round N [--timeout 秒] [--interval 秒]" >&2
            exit 1
            ;;
        esac
      done
    fi

    if [[ -n "$round_wait" ]]; then
      target_id="$maybe_id"
      if [[ -z "$target_id" ]]; then
        target_id="$(reg_pick_other "$ME" "$(agent_ids)")"
      fi
      if ! is_positive_int "$round_wait"; then
        echo "错误: peer wait --round 必须是正整数。" >&2
        exit 1
      fi
      if ! is_positive_int "$round_timeout"; then
        echo "错误: peer wait --timeout 必须是正整数。" >&2
        exit 1
      fi
      if ! is_positive_int "$round_interval"; then
        echo "错误: peer wait --interval 必须是正整数。" >&2
        exit 1
      fi
      lines="${PEER_WAIT_ROUND_LINES:-200}"
      if ! is_positive_int "$lines"; then
        echo "错误: PEER_WAIT_ROUND_LINES 必须是正整数。" >&2
        exit 1
      fi
      target_tag="$(tmux display-message -p -t "$target" '#{@agentduo_codec_tag}' 2>/dev/null || true)"
      elapsed=0
      while (( elapsed < round_timeout )); do
        cur="$(capture "$target" "$lines")"
        if screen_has_round_sentinel "$cur" "$round_wait" "$target_id" "$target_tag"; then
          echo "已看到 round=${round_wait} 的 sentinel。"
          exit 0
        fi
        sleep "$round_interval"
        (( elapsed += round_interval ))
      done
      echo "等待 round=${round_wait} 的 sentinel 超时(${round_timeout}s)。可稍后再 peer peek。" >&2
      exit 2
    fi

    if [[ $# -gt 3 ]]; then
      echo "用法: peer wait [<id>] [超时秒] [采样间隔秒] [连续稳定次数]" >&2
      exit 1
    fi
    timeout="${1:-${PEER_WAIT_TIMEOUT:-300}}"
    interval="${2:-${PEER_WAIT_INTERVAL:-5}}"
    stable_needed="${3:-${PEER_WAIT_STABLE_SAMPLES:-2}}"
    lines="${PEER_WAIT_LINES:-40}"
    if ! is_positive_int "$timeout"; then
      echo "错误: peer wait 的超时秒数必须是正整数。" >&2
      exit 1
    fi
    if ! is_positive_int "$interval"; then
      echo "错误: peer wait 的采样间隔秒必须是正整数。" >&2
      exit 1
    fi
    if ! is_positive_int "$stable_needed"; then
      echo "错误: peer wait 的连续稳定次数必须是正整数。" >&2
      exit 1
    fi
    if ! is_positive_int "$lines"; then
      echo "错误: PEER_WAIT_LINES 必须是正整数。" >&2
      exit 1
    fi
    elapsed=0
    stable_seen=0
    prev="$(capture "$target" "$lines")"
    while (( elapsed < timeout )); do
      # 先给对方一点启动时间,避免它还没开始输出就被判定为"稳定"
      sleep "$interval"
      (( elapsed += interval ))
      cur="$(capture "$target" "$lines")"
      if [[ "$cur" == "$prev" ]]; then
        (( stable_seen += 1 ))
        if (( stable_seen >= stable_needed )); then
          echo "目标输出已稳定(连续 ${stable_seen} 次采样一致),它可能已完成。"
          exit 0
        fi
      else
        stable_seen=0
      fi
      prev="$cur"
    done
    echo "等待超时(${timeout}s),目标仍在输出。可稍后再 peer peek。" >&2
    exit 2
    ;;

  task)
    subcmd="${1:-}"
    case "$subcmd" in
      init)
        shift
        target_id="$ME"
        if [[ -n "${1:-}" && "${1:-}" != --* ]]; then
          target_id="$1"
          shift
        fi
        task_title=""
        round="1"
        task_steps=()
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --task|--title)
              task_title="${2:-}"
              shift 2
              ;;
            --round)
              round="${2:-}"
              shift 2
              ;;
            --step)
              task_steps+=("${2:-}")
              shift 2
              ;;
            *)
              echo "用法: peer task init [<id>] --task \"...\" [--round N] --step s1:\"...\" [--step s2:\"...\"]" >&2
              exit 1
              ;;
          esac
        done
        task_init "$target_id" "$task_title" "$round" ${task_steps[@]+"${task_steps[@]}"}
        echo "已初始化 task.json: .agent-duo/state/$target_id/task.json"
        ;;
      next)
        shift
        target_id="${1:-$ME}"
        if [[ -n "${2:-}" ]]; then
          echo "用法: peer task next [<id>]" >&2
          exit 1
        fi
        task_next "$target_id"
        ;;
      show)
        shift
        target_id="${1:-$ME}"
        if [[ -n "${2:-}" ]]; then
          usage_task >&2
          exit 1
        fi
        task_print "$target_id"
        ;;
      ""|--help|-h)
        usage_task
        ;;
      *)
        echo "已移除: 'peer task <id>' → 改用 'peer task show <id>'" >&2
        exit 1
        ;;
    esac
    ;;

  loop)
    subcmd="${1:-}"
    case "$subcmd" in
      init)
        shift
        target_id="$ME"
        if [[ -n "${1:-}" && "${1:-}" != --* ]]; then
          target_id="$1"
          shift
        fi
        loop_mission=""
        loop_max_rounds=""
        loop_round=""
        loop_non_goals=()
        loop_success=()
        loop_validations=()
        loop_validation_satisfies=()
        loop_validation_timeouts=()
        loop_reviews=()
        loop_detail_trap_rounds="3"
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --mission)
              loop_mission="${2:-}"
              shift 2
              ;;
            --max-rounds)
              if [[ -z "${2:-}" ]]; then
                usage_loop >&2
                exit 1
              fi
              loop_max_rounds="${2:-}"
              shift 2
              ;;
            --non-goal)
              loop_non_goals+=("${2:-}")
              shift 2
              ;;
            --success)
              loop_success+=("${2:-}")
              shift 2
              ;;
            --verify)
              loop_validations+=("${2:-}")
              shift 2
              ;;
            --verify-satisfies)
              loop_validation_satisfies+=("${2:-}")
              shift 2
              ;;
            --verify-timeout)
              loop_validation_timeouts+=("${2:-}")
              shift 2
              ;;
            --judge)
              loop_reviews+=("${2:-}")
              shift 2
              ;;
            --detail-trap-rounds)
              loop_detail_trap_rounds="${2:-}"
              shift 2
              ;;
            --round)
              loop_round="${2:-}"
              shift 2
              ;;
            --validation|--validation-satisfies|--validation-timeout)
              echo "已移除: '$1' → 改用 '${1/--validation/--verify}'" >&2
              exit 1
              ;;
            --review)
              echo "已移除: '--review' → 改用 '--judge'" >&2
              exit 1
              ;;
            *)
              usage_loop >&2
              exit 1
              ;;
          esac
        done
        if [[ -z "$loop_round" ]]; then
          loop_round="$(report_round_for_id "$target_id")"
          if [[ "$loop_round" == "0" ]]; then loop_round="1"; fi
        fi
        loop_non_goals_json="$(json_array ${loop_non_goals[@]+"${loop_non_goals[@]}"})"
        loop_success_json="$(json_array ${loop_success[@]+"${loop_success[@]}"})"
        if ! loop_validation_json="$(build_validation_json)"; then
          exit 1
        fi
        if ! loop_acceptance_json="$(build_acceptance_json)"; then
          exit 1
        fi
        loop_init "$target_id" "$loop_mission" "$loop_max_rounds" "$loop_round" "$loop_non_goals_json" "$loop_success_json" "$loop_validation_json" "$loop_acceptance_json" "$loop_detail_trap_rounds"
        echo "已初始化 loop.json: .agent-duo/state/$target_id/loop.json"
        ;;
      reset)
        shift
        target_id="$ME"
        if [[ -n "${1:-}" && "${1:-}" != --* ]]; then
          target_id="$1"
          shift
        fi
        loop_max_rounds=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --max-rounds)
              if [[ -z "${2:-}" ]]; then
                echo "用法: peer loop reset [<id>] [--max-rounds N]" >&2
                exit 1
              fi
              loop_max_rounds="${2:-}"
              shift 2
              ;;
            *)
              echo "用法: peer loop reset [<id>] [--max-rounds N]" >&2
              exit 1
              ;;
          esac
        done
        loop_reset "$target_id" "$loop_max_rounds"
        ;;
      show)
        shift
        target_id="${1:-$ME}"
        if [[ -z "$target_id" || -n "${2:-}" ]]; then
          usage_loop >&2
          exit 1
        fi
        loop_print "$target_id"
        ;;
      ""|--help|-h)
        usage_loop
        ;;
      *)
        echo "已移除: 'peer loop <id>' → 改用 'peer loop show <id>'" >&2
        exit 1
        ;;
    esac
    ;;

  judge)
    subcmd="${1:-}"
    if [[ "$subcmd" == "ls" ]]; then
      shift
      if [[ -z "${1:-}" || "${1:-}" == --* ]]; then
        usage_judge >&2
        exit 1
      fi
      target_id="$1"
      shift
      json_mode=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --json) json_mode=1; shift ;;
          *) usage_judge >&2; exit 1 ;;
        esac
      done
      if ! judge_json="$(judge_records_json "$target_id")"; then
        exit 1
      fi
      if [[ "$json_mode" == "1" ]]; then
        printf '%s\n' "$judge_json"
      else
        judge_print_records "$judge_json"
      fi
      exit 0
    fi
    if [[ "$subcmd" == "--help" || "$subcmd" == "-h" || -z "$subcmd" ]]; then
      usage_judge
      exit 0
    fi
    target_ref="$subcmd"
    shift
    report_type="result"
    report_status="done"
    step_ref=""
    round=""
    delta=""
    next_text=""
    goal_ref=""
    drift=""
    evidence_cmd=""
    evidence_result=""
    evidence_ref=""
    needs_kind=""
    needs_detail=""
    needs_options=()
    verdict=""
    findings=()
    verdict_seen=0
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --verdict)
          verdict_seen=1
          verdict="${2:-}"
          shift 2
          ;;
        --round)
          round="${2:-}"
          shift 2
          ;;
        --status)
          report_status="${2:-}"
          shift 2
          ;;
        --finding)
          findings+=("${2:-}")
          shift 2
          ;;
        --delta)
          delta="${2:-}"
          shift 2
          ;;
        --evidence-cmd)
          evidence_cmd="${2:-}"
          shift 2
          ;;
        --evidence-result)
          evidence_result="${2:-}"
          shift 2
          ;;
        --evidence-ref)
          evidence_ref="${2:-}"
          shift 2
          ;;
        --step|--step-ref)
          step_ref="${2:-}"
          shift 2
          ;;
        --goal|--goal-ref)
          goal_ref="${2:-}"
          shift 2
          ;;
        --drift)
          drift="${2:-}"
          shift 2
          ;;
        --next)
          next_text="${2:-}"
          shift 2
          ;;
        --needs|--needs-kind|--needs-detail|--needs-option|--type|--target-ref)
          echo "错误: '$1' 不属于 peer judge；verdict 目标请用位置参数 <target-ref>，阻塞诉求请用 peer report --type request。" >&2
          exit 1
          ;;
        *)
          usage_judge >&2
          exit 1
          ;;
      esac
    done
    if [[ "$verdict_seen" != "1" ]]; then
      echo "错误: peer judge 需要 --verdict V。" >&2
      exit 1
    fi
    findings_json="$(build_findings_json ${findings[@]+"${findings[@]}"})"
    _emit_report "$report_type" "$report_status" "$step_ref" "$round" "$delta" "$next_text" "$goal_ref" "$drift" \
      "$evidence_cmd" "$evidence_result" "$evidence_ref" "$needs_kind" "$needs_detail" \
      "$verdict" "$target_ref" "$findings_json" ${needs_options[@]+"${needs_options[@]}"}
    ;;

  verify)
    subcmd="${1:-}"
    shift || true
    case "$subcmd" in
      ls|show)
        if [[ -z "${1:-}" || "${1:-}" == --* ]]; then
          usage_verify >&2
          exit 1
        fi
        target_id="$1"
        shift
        round=""
        json_mode=0
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --round)
              round="${2:-}"
              shift 2
              ;;
            --json)
              json_mode=1
              shift
              ;;
            *)
              usage_verify >&2
              exit 1
              ;;
          esac
        done
        if [[ -z "$round" ]]; then
          round="$(report_round_for_id "$target_id")"
        fi
        if ! verify_json="$(verify_state_json "$target_id" "$round")"; then
          exit 1
        fi
        if [[ "$json_mode" == "1" ]]; then
          printf '%s\n' "$verify_json"
        elif [[ "$subcmd" == "ls" ]]; then
          verify_print_ls "$verify_json"
        else
          verify_print_show "$verify_json"
        fi
        ;;
      ""|--help|-h)
        usage_verify
        ;;
      *)
        usage_verify >&2
        exit 1
        ;;
    esac
    ;;

  budget)
    subcmd="${1:-}"
    shift || true
    case "$subcmd" in
      status)
        if [[ $# -gt 0 ]]; then
          usage_budget >&2
          exit 1
        fi
        echo "budget 护栏为预留能力，当前未启用。"
        ;;
      ""|--help|-h)
        usage_budget
        ;;
      *)
        usage_budget >&2
        exit 1
        ;;
    esac
    ;;

  report)
    report_type=""
    report_status=""
    step_ref=""
    round=""
    delta=""
    next_text=""
    goal_ref=""
    drift=""
    evidence_cmd=""
    evidence_result=""
    evidence_ref=""
    needs_kind=""
    needs_detail=""
    needs_options=()

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --type)
          report_type="${2:-}"
          shift 2
          ;;
        --status)
          report_status="${2:-}"
          shift 2
          ;;
        --step|--step-ref)
          step_ref="${2:-}"
          shift 2
          ;;
        --round)
          round="${2:-}"
          shift 2
          ;;
        --delta)
          delta="${2:-}"
          shift 2
          ;;
        --next)
          next_text="${2:-}"
          shift 2
          ;;
        --goal|--goal-ref)
          goal_ref="${2:-}"
          shift 2
          ;;
        --drift)
          drift="${2:-}"
          shift 2
          ;;
        --evidence-cmd)
          evidence_cmd="${2:-}"
          shift 2
          ;;
        --evidence-result)
          evidence_result="${2:-}"
          shift 2
          ;;
        --evidence-ref)
          evidence_ref="${2:-}"
          shift 2
          ;;
        --needs|--needs-kind)
          needs_kind="${2:-}"
          shift 2
          ;;
        --needs-detail)
          needs_detail="${2:-}"
          shift 2
          ;;
        --needs-option)
          needs_options+=("${2:-}")
          shift 2
          ;;
        --verdict|--target-ref|--finding)
          echo "已移除: 'peer report --verdict/--target-ref/--finding' → 改用 'peer judge <target-ref> --verdict V'" >&2
          exit 1
          ;;
        *)
          usage_report >&2
          exit 1
          ;;
      esac
	    done

	    findings_json="[]"
	    _emit_report "$report_type" "$report_status" "$step_ref" "$round" "$delta" "$next_text" "$goal_ref" "$drift" \
	      "$evidence_cmd" "$evidence_result" "$evidence_ref" "$needs_kind" "$needs_detail" \
	      "" "" "$findings_json" ${needs_options[@]+"${needs_options[@]}"}
	    ;;

  gate)
    subcmd="${1:-}"
    if [[ "$subcmd" == "ls" ]]; then
      shift
      show_all=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --all) show_all=1; shift ;;
          *) echo "用法: peer gate ls [--all]" >&2; exit 1 ;;
        esac
      done
      gate_print_list "$show_all"
      exit 0
    fi
    if [[ "$subcmd" != "open" && "$subcmd" != "resolve" ]]; then
      usage_gate >&2
      exit 1
    fi
    shift
    case "$subcmd" in
      open)
        maybe_id=""
        if [[ -n "${1:-}" && "${1:-}" != --* ]]; then
          maybe_id="$1"
          shift
        fi
        gate_title=""
        gate_detail=""
        round="0"
        needs_options=()
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --title) gate_title="${2:-}"; shift 2 ;;
            --detail) gate_detail="${2:-}"; shift 2 ;;
            --option) needs_options+=("${2:-}"); shift 2 ;;
            --round) round="${2:-}"; shift 2 ;;
            *) echo "用法: peer gate open [<target>] --title \"...\" [--detail \"...\"] [--option \"...\"] [--round N]" >&2; exit 1 ;;
          esac
        done
        if [[ -z "$gate_title" ]]; then
          echo "错误: peer gate open 需要 --title。" >&2
          exit 1
        fi
        if [[ -n "$round" && "$round" != "0" ]] && ! is_positive_int "$round"; then
          echo "错误: --round 必须是正整数。" >&2
          exit 1
        fi
        ensure_session
        target="$(resolve_target_pane "$maybe_id")"
        if [[ -n "$maybe_id" ]]; then
          target_id="$maybe_id"
        else
          target_id="$(reg_pick_other "$ME" "$(agent_ids)")"
        fi
        target_role="$(role_for_id "$target_id")"
        gate_id="$(new_gate_id "$round")"
        ts="$(iso_ts)"
        create_gate_record "$gate_id" "$ts" "$target_id" "$target_role" "$round" "$gate_title" "$gate_detail" "" ${needs_options[@]+"${needs_options[@]}"}
        gate_summary="$gate_detail"
        if [[ -z "$gate_summary" ]]; then gate_summary="$gate_title"; fi
        append_decision_log "$gate_id" "opened" "$target_id" "$gate_summary" "" ""
        echo "已打开 human gate $gate_id (target=$target_id)。"
        ;;
      resolve)
        maybe_id=""
        if [[ -n "${1:-}" && "${1:-}" != --* ]]; then
          maybe_id="$1"
          shift
        fi
        choice=""
        note=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --choice) choice="${2:-}"; shift 2 ;;
            --note) note="${2:-}"; shift 2 ;;
            *) echo "用法: peer gate resolve [<gate-id>|<target-id>] --choice <choice> [--note \"...\"]" >&2; exit 1 ;;
          esac
        done
        if [[ -z "$choice" ]]; then
          echo "错误: peer gate resolve 需要 --choice。" >&2
          exit 1
        fi
        if [[ ! "$choice" =~ ^[A-Za-z0-9._:-]+$ ]]; then
          echo "错误: --choice 只能包含字母、数字、点、下划线、冒号和连字符；补充说明请用 --note。" >&2
          exit 1
        fi
        gate_id=""
        if [[ -n "$maybe_id" && -f "$(gate_path "$maybe_id")" ]]; then
          gate_id="$maybe_id"
        elif [[ -n "$maybe_id" ]]; then
          if gate_id="$(gate_pick_unique_pending_for_agent "$maybe_id")"; then
            :
          else
            rc="$?"
            if [[ "$rc" == "2" ]]; then exit 1; fi
            gate_id=""
          fi
        elif [[ -z "$maybe_id" ]]; then
          if gate_id="$(gate_pick_unique_pending)"; then
            :
          else
            rc="$?"
            if [[ "$rc" == "2" ]]; then exit 1; fi
            gate_id=""
          fi
        fi
        ensure_session
        if [[ -n "$gate_id" ]]; then
          target_id="$(gate_field "$gate_id" '.agent_id')"
          if [[ -z "$target_id" ]]; then
            echo "错误: gate '$gate_id' 缺少 agent_id,无法发送 decision。" >&2
            exit 1
          fi
          target="$(resolve_target_pane "$target_id")"
        else
          target="$(resolve_target_pane "$maybe_id")"
          if [[ -n "$maybe_id" ]]; then
            target_id="$maybe_id"
          else
            target_id="$(reg_pick_other "$ME" "$(agent_ids)")"
          fi
        fi
        check_safe_to_send_keys "$target"
        if [[ -n "$gate_id" ]]; then
          gate_resolve_record "$gate_id" "$choice" "$note"
        fi
        buf="peer-${ME}2${target_id}-gate"
        gate_text="«AGENTDUO verb=decision choice=${choice}»"
        if [[ -n "$note" ]]; then
          gate_text="${gate_text}"$'\n'"$note"
        fi
        send_text_to_pane "$target" "$buf" "$gate_text"
        if [[ -n "$gate_id" ]]; then
          echo "已解决 human gate $gate_id 并发送 decision(choice=$choice)。"
        else
          echo "已发送 gate decision(choice=$choice)。"
        fi
        ;;
    esac
    ;;

  loopd)
    ensure_session
    exec /bin/bash "$PEER_ROOT/scripts/loopd" "$@"
    ;;

  status)
    ensure_session
    target="$(resolve_target_pane "" 2>/dev/null || true)"
    echo "我是: $ME    会话: $SESSION"
    [[ -n "$target" ]] && echo "目标(默认): $target"
    printf '%s\n' "--- agents ---"
    "$0" agent ls
    ;;

  esc)
    ensure_session
    if [[ "${1:-}" == "--force" ]]; then FORCE_SEND=1; shift; fi
    maybe_id=""
    if [[ -n "${1:-}" && "${1:-}" != "--force" ]]; then maybe_id="$1"; shift; fi
    if [[ "${1:-}" == "--force" ]]; then FORCE_SEND=1; shift; fi
    target="$(resolve_target_pane "$maybe_id")"
    check_safe_to_send_keys "$target"
    tmux send-keys -t "$target" Escape
    echo "已发送 Escape。"
    ;;

  help|*)
    print_top_help
    ;;
esac
