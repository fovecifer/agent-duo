#!/usr/bin/env bash
# peer — 让同一 tmux 会话里的多个编码 agent(claude / codex)互相观察和发送指令
#
# 用法:
#   peer ls                 列出本会话所有 agent(id / role / provider / pane)
#   peer add --provider claude|codex --role <role> [--id <id>]
#                           新建并注册一个可见队友(新窗口),返回其 id
#   peer rm <id>            移除一个队友(关闭其窗口)
#   peer peek [<id>] [行数]  查看某个 agent 终端最近 N 行输出(默认 80)
#   peer tell [--force] [<id>] "消息"
#                           发送单行消息到目标输入框并回车
#   ... | peer tell [<id>]  从 stdin 投递多行消息(经 tmux buffer + bracketed paste,引号换行安全)
#   peer wait [<id>] [超时秒] [采样间隔秒] [连续稳定次数]
#                           等待目标屏幕输出稳定(认为它已完成当前任务),默认最长 300s
#   peer wait <id> --round N [--timeout 秒] [--interval 秒]
#                           等待目标屏幕出现指定 round 的 agent-duo sentinel
#   peer report --type <plan|checkpoint|request|result>
#               --status <in_progress|blocked|partial|done|failed|unknown>
#               [--step sN] [--round N] [--delta ...] [--next ...]
#               [--needs <approval|decision|info|scope|discovery>
#                  [--needs-detail ...] [--needs-option ...]]
#                           写结构化 report、追加 runtime event、打印 sentinel
#                           --needs 把阻塞诉求写入 needs[],决定 supervisor stall 路由
#   peer task [<id>]        查看某 agent 的 task.json 步骤账本(默认自己)
#   peer task next [<id>]   打印 blocked / in_progress / pending 的下一个 resume step
#   peer task init [<id>] --task "..." [--round N] --step s1:"..." [--step s2:"..."]
#                           初始化/冻结某 agent 的 task.json 步骤账本
#   peer loop [<id>]        查看某 agent 的 loop.json 契约与当前预算
#   peer loop init [<id>] --mission "..." --max-rounds N [--non-goal "..."] [--success "..."] [--round N]
#                  [--validation id:"cmd"] [--validation-satisfies id:"signal"] [--validation-timeout id:N]
#                           初始化/冻结某 agent 的 supervisor loop 契约
#   peer ask [<id>] "消息" [--timeout N] [--interval N] [--force]
#                           原子 tell + 等待 target 写出新 report,并打印该 report 摘要
#   peer approvals          列出待审批的 Approval Broker 请求
#   peer approve <id>       批准一次待审批请求(worker 重跑同一工具调用时放行一次)
#   peer deny <id> [--reason "..."]
#                           拒绝一次待审批请求
#   peer broker-status [<id>]
#                           查看某 worker 的 Approval Broker 就绪状态(ready/unverified/fail-open)
#   peer broker-check [<id>] 向 worker 投递自检探针,验证 broker hook 真的被 provider 调用;
#                           未验证(fail-open)时不要派给它需要 broker 保护的任务
#   peer gate [--all]       列出待处理 Human Decision Gate
#   peer gate open [<id>] --title "..." [--detail "..."] [--option "..."]
#                           创建一个 Decision Packet,供 supervisor 向人类升级
#   peer gate resolve [<id>] --choice <choice> [--note "..."]
#                           向 worker 答复 human gate 决策
#   peer loopd              在当前 pane 运行 loop daemon 看板/轮询
#   peer status             显示自己/默认目标的身份与会话内全员
#   peer esc [<id>] [--force] 向目标发送 Escape(打断它当前的生成)
#   peer --force tell/esc   跳过权限弹窗检测并强制发送
#
# 寻址:正好两个 agent 时可省略 <id>(默认发给"另一个");三个及以上必须显式指定 id。
#
# 依赖环境变量:
#   AGENT_SESSION  tmux 会话名,默认 agents
#   AGENT_NAME     迁移兼容:当 pane @agent_id 缺失时回退为自身身份
#   PEER_FORCE=1   跳过 tell/esc 的权限弹窗检测

set -euo pipefail

SESSION="${AGENT_SESSION:-agents}"

# 定位仓库根,source 纯函数库。
PEER_SRC="${BASH_SOURCE[0]}"
while [ -L "$PEER_SRC" ]; do PEER_SRC="$(readlink "$PEER_SRC")"; done
PEER_ROOT="$(cd "$(dirname "$PEER_SRC")/.." && pwd)"
# shellcheck source=lib/registry.sh
source "$PEER_ROOT/lib/registry.sh"

PEER_INSTR="$PEER_ROOT/docs/AGENT-INSTRUCTIONS.md"
APPROVAL_BROKER="$PEER_ROOT/lib/approval_broker.sh"
APPROVAL_HOOK="$PEER_ROOT/bin/agent-duo-approval-hook"
AGENT_DUO_ROOT="${AGENT_DUO_ROOT:-$PWD}"
AGENT_DUO_DIR="$AGENT_DUO_ROOT/.agent-duo"

SELF_PANE="${TMUX_PANE:-}"

# 自识别:优先读自己 pane 的 @agent_id;缺失则回退 AGENT_NAME(迁移兼容)。
self_id() {
  local id=""
  if [[ -n "$SELF_PANE" ]]; then
    id="$(tmux display-message -p -t "$SELF_PANE" '#{@agent_id}' 2>/dev/null || true)"
  fi
  if [[ -z "$id" ]]; then
    id="${AGENT_NAME:-}"
  fi
  printf '%s' "$id"
}

self_role() {
  local role=""
  if [[ -n "$SELF_PANE" ]]; then
    role="$(tmux display-message -p -t "$SELF_PANE" '#{@agent_role}' 2>/dev/null || true)"
  fi
  if [[ -z "$role" ]]; then
    role="${AGENT_ROLE:-worker}"
  fi
  printf '%s' "$role"
}

ME="$(self_id)"
if [[ -z "$ME" ]]; then
  echo "错误: 无法确定自身身份(既无 pane @agent_id 也无 AGENT_NAME)。请通过 start.sh 启动。" >&2
  exit 1
fi

# list_agents → 每行: pane_id<TAB>agent_id<TAB>role<TAB>provider(原样来自 tmux)。
list_agents() {
  tmux list-panes -s -t "$SESSION" \
    -F '#{pane_id}	#{@agent_id}	#{@agent_role}	#{@agent_provider}' 2>/dev/null
}

# agent_ids → 已注册(@agent_id 非空)的 id,每行一个。
agent_ids() {
  list_agents | awk -F'\t' '$2 != "" { print $2 }'
}

# pane_for_id <id> → 打印该 id 的 pane;找不到返回 1。
pane_for_id() {
  local want="$1"
  list_agents | awk -F'\t' -v w="$want" '$2==w { print $1; found=1 } END{ exit found?0:1 }'
}

# resolve_target_pane <maybe_id> → 打印目标 pane,出错时写 stderr 并 exit。
#   maybe_id 非空 → 必须是已注册 id;否则报错。
#   maybe_id 为空 → reg_pick_other(self, ids):两人取另一个;0 人/≥2 候选报错。
resolve_target_pane() {
  local maybe_id="$1"
  local pane other ids rc
  if [[ -n "$maybe_id" ]]; then
    if ! pane="$(pane_for_id "$maybe_id")"; then
      echo "错误: 找不到 agent '$maybe_id'。用 'peer ls' 查看在线 agent。" >&2
      exit 1
    fi
    printf '%s' "$pane"
    return 0
  fi
  ids="$(agent_ids)"
  if other="$(reg_pick_other "$ME" "$ids")"; then
    pane_for_id "$other"
    return 0
  fi
  rc=$?
  if [[ "$rc" == "2" ]]; then
    echo "错误: 会话里没有其他 agent 可作为目标。" >&2
  else
    echo "错误: 会话内有多个 agent,请指定目标。可用: $(printf '%s ' $(printf '%s\n' "$ids" | grep -vx "$ME"))" >&2
  fi
  exit 1
}

is_positive_int() {
  [[ "$1" =~ ^[1-9][0-9]*$ ]]
}

is_nonnegative_int() {
  [[ "$1" =~ ^[0-9]+$ ]]
}

is_report_type() {
  case "$1" in
    plan|checkpoint|request|result) return 0 ;;
    *) return 1 ;;
  esac
}

is_report_status() {
  case "$1" in
    in_progress|blocked|partial|done|failed|unknown) return 0 ;;
    *) return 1 ;;
  esac
}

# needs[].kind 枚举:决定 stall 路由到谁(见 worker-supervisor-contract §2.2)。
is_needs_kind() {
  case "$1" in
    approval|decision|info|scope|discovery) return 0 ;;
    *) return 1 ;;
  esac
}

# 工作型角色(受 broker 派发硬门保护):除 supervisor/daemon/loopd 外的所有角色。
# 单一真相:tell 门控与 add 提示都用它,避免两处豁免名单漂移。
role_is_gated() {
  case "$1" in
    supervisor|daemon|loopd) return 1 ;;
    *) return 0 ;;
  esac
}

run_approval_broker() {
  bash "$APPROVAL_BROKER" "$@"
}

# role_for_id <id> → 打印该 id 的 @agent_role;读不到时打印 "worker"(fail-closed)。
role_for_id() {
  local want="$1" role
  role="$(list_agents | awk -F'\t' -v w="$want" '$2==w { print $3; found=1 } END{ exit found?0:1 }')" || role=""
  [[ -n "$role" ]] || role="worker"
  printf '%s' "$role"
}

install_approval_session_settings() { # <agent_id> <provider> <worktree>
  local agent_id="$1" provider="$2" worktree="$3"
  run_approval_broker install \
    --agent-id "$agent_id" \
    --provider "$provider" \
    --hook "$APPROVAL_HOOK" \
    --root "$AGENT_DUO_ROOT" \
    --worktree "$worktree"
}

iso_ts() {
  date -u '+%Y-%m-%dT%H:%M:%SZ'
}

sha256_file() { # <file>
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$1" | awk '{print $1}'
  elif command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  else
    echo "错误: 需要 shasum 或 sha256sum 计算 report sha。" >&2
    exit 1
  fi
}

random_hex_tag() {
  local tag
  tag="$(od -An -N4 -tx1 /dev/urandom 2>/dev/null | tr -d ' \n' || true)"
  if [[ -z "$tag" ]]; then
    tag="$(printf '%04x' "$$")"
  fi
  printf '%s' "$tag"
}

codec_tag() {
  local tag=""
  if [[ -n "$SELF_PANE" ]]; then
    tag="$(tmux display-message -p -t "$SELF_PANE" '#{@agentduo_codec_tag}' 2>/dev/null || true)"
  fi
  if [[ -z "$tag" ]]; then
    tag="$(random_hex_tag)"
    if [[ -n "$SELF_PANE" ]]; then
      tmux set-option -p -t "$SELF_PANE" @agentduo_codec_tag "$tag" 2>/dev/null || true
    fi
  fi
  printf '%s' "$tag"
}

next_report_round() { # <state_dir>
  local dir="$1" max=0 f base n
  for f in "$dir"/r*.json; do
    [[ -e "$f" ]] || continue
    base="${f##*/}"
    base="${base#r}"
    base="${base%.json}"
    if is_positive_int "$base"; then
      n="$base"
      if (( n > max )); then max="$n"; fi
    fi
  done
  printf '%s' "$(( max + 1 ))"
}

report_round_for_id() { # <agent_id>
  local report round
  report="$AGENT_DUO_DIR/state/$1/report.json"
  if [[ ! -e "$report" ]]; then
    printf '0'
    return 0
  fi
  round="$(jq -r '.round // 0' "$report" 2>/dev/null || true)"
  if ! is_nonnegative_int "$round"; then
    round="0"
  fi
  printf '%s' "$round"
}

report_file_for_round() { # <agent_id> <round>
  printf '%s/state/%s/r%s.json' "$AGENT_DUO_DIR" "$1" "$2"
}

one_line() {
  printf '%s' "$1" | tr '\r\n' '  '
}

event_type_for_report() { # <report_type> <status>
  local report_type="$1" status="$2"
  if [[ "$report_type" == "request" || "$status" == "blocked" ]]; then
    printf 'blocked'
  else
    case "$report_type" in
      plan)       printf 'plan' ;;
      result)     printf 'result' ;;
      checkpoint) printf 'checkpoint' ;;
      *)          printf '%s' "$report_type" ;;
    esac
  fi
}

toml_string() { # <value>
  jq -Rn --arg s "$1" '$s | @json'
}

codex_hook_config() { # <event> <command> [matcher]
  local event="$1" command="$2" matcher="${3:-}" command_toml
  command_toml="$(toml_string "$command")"
  if [[ -n "$matcher" ]]; then
    printf 'hooks.%s=[{matcher="%s",hooks=[{type="command",command=%s}]}]' "$event" "$matcher" "$command_toml"
  else
    printf 'hooks.%s=[{hooks=[{type="command",command=%s}]}]' "$event" "$command_toml"
  fi
}

json_escape() {
  local s="${1:-}"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  s="${s//$'\b'/\\b}"
  s="${s//$'\f'/\\f}"
  # 其余 < 0x20 控制字符按 JSON 规范转为 \u00XX，否则会产出非法 JSON 让下游 jq 解析失败。
  # 极少见(NUL 无法存于 bash 变量);多字节 UTF-8 字符码 > 0x1f，原样保留。
  if [[ "$s" == *[$'\x01'-$'\x1f']* ]]; then
    local out="" i ch code
    for (( i=0; i<${#s}; i++ )); do
      ch="${s:i:1}"
      printf -v code '%d' "'$ch"
      if (( code >= 1 && code <= 31 )); then
        printf -v ch '\\u%04x' "$code"
      fi
      out+="$ch"
    done
    s="$out"
  fi
  printf '%s' "$s"
}

json_str() {
  printf '"'
  json_escape "${1:-}"
  printf '"'
}

json_nullable_str() {
  if [[ -z "${1:-}" ]]; then
    printf 'null'
  else
    json_str "$1"
  fi
}

# build_needs_json <kind> <detail> [option...] → 打印 needs[] 数组(JSON)。
# kind 为空 → "[]"(无阻塞诉求);否则一条 {kind,detail,options[]}。options 始终是数组。
build_needs_json() {
  local kind="$1" detail="${2:-}"
  shift 2 2>/dev/null || shift $#
  if [[ -z "$kind" ]]; then
    printf '[]'
    return
  fi
  printf '[{"kind":'; json_str "$kind"
  printf ',"detail":'; json_nullable_str "$detail"
  printf ',"options":['
  local first=1 opt
  for opt in "$@"; do
    if [[ $first -eq 1 ]]; then first=0; else printf ','; fi
    json_str "$opt"
  done
  printf ']}]'
}

write_report_json() {
  local path="$1" round_s="$2" agent_id="$3" role="$4" report_type="$5" status="$6"
  local goal_ref="$7" step_ref="$8" delta="$9" drift="${10}" next_text="${11}"
  local evidence_cmd="${12}" evidence_result="${13}" evidence_ref="${14}" needs_json="${15:-[]}"
  {
    printf '{"protocol":"1","round":%s,' "$round_s"
    printf '"agent_id":'; json_str "$agent_id"; printf ','
    printf '"role":'; json_str "$role"; printf ','
    printf '"type":'; json_str "$report_type"; printf ','
    printf '"status":'; json_str "$status"; printf ','
    printf '"goal_ref":'; json_nullable_str "$goal_ref"; printf ','
    printf '"step_ref":'; json_nullable_str "$step_ref"; printf ','
    printf '"delta":'; json_str "$delta"; printf ','
    printf '"drift":'; json_nullable_str "$drift"; printf ','
    printf '"evidence":'
    if [[ -n "$evidence_cmd" || -n "$evidence_result" || -n "$evidence_ref" ]]; then
      printf '[{"cmd":'; json_str "$evidence_cmd"
      printf ',"result":'; json_str "$evidence_result"
      printf ',"ref":'; json_str "$evidence_ref"
      printf '}]'
    else
      printf '[]'
    fi
    printf ',"needs":%s,"next":' "$needs_json"; json_str "$next_text"
    printf '}\n'
  } > "$path"
}

task_file_for_id() { # <agent_id>
  printf '%s/state/%s/task.json' "$AGENT_DUO_DIR" "$1"
}

is_step_status() {
  case "$1" in
    pending|in_progress|blocked|done|failed|kept) return 0 ;;
    *) return 1 ;;
  esac
}

parse_step_spec() { # <id:desc>; sets STEP_ID STEP_DESC
  local spec="$1"
  if [[ "$spec" != *:* ]]; then
    echo "错误: --step 必须形如 <id>:<desc>。" >&2
    return 1
  fi
  STEP_ID="${spec%%:*}"
  STEP_DESC="${spec#*:}"
  if [[ -z "$STEP_ID" || -z "$STEP_DESC" ]]; then
    echo "错误: --step 的 id 和 desc 都不能为空。" >&2
    return 1
  fi
  if [[ ! "$STEP_ID" =~ ^[A-Za-z0-9._-]+$ ]]; then
    echo "错误: step id 只能包含字母、数字、点、下划线和连字符。" >&2
    return 1
  fi
}

write_task_json() { # <path> <agent_id> <task_title> <frozen_round> [step_spec...]
  local path="$1" agent_id="$2" task_title="$3" frozen_round="$4" spec first=1 now
  shift 4
  now="$(iso_ts)"
  {
    printf '{"protocol":"1",'
    printf '"agent_id":'; json_str "$agent_id"; printf ','
    printf '"task":'; json_str "$task_title"; printf ','
    printf '"frozen_at_round":%s,' "$frozen_round"
    printf '"current_step":null,'
    printf '"created_at":'; json_str "$now"; printf ','
    printf '"updated_at":'; json_str "$now"; printf ','
    printf '"steps":['
    for spec in "$@"; do
      parse_step_spec "$spec" || return 1
      if [[ $first -eq 1 ]]; then first=0; else printf ','; fi
      printf '{"id":'; json_str "$STEP_ID"
      printf ',"desc":'; json_str "$STEP_DESC"
      printf ',"deps":[],"done_when":null,"gate":null,"status":"pending","evidence":[]}'
    done
    printf ']}\n'
  } > "$path"
}

task_init() { # <agent_id> <task_title> <frozen_round> [step_spec...]
  local agent_id="$1" task_title="$2" frozen_round="$3" task_file task_dir tmp
  shift 3
  if [[ -z "$task_title" ]]; then
    echo "错误: peer task init 需要 --task。" >&2
    return 1
  fi
  if [[ $# -eq 0 ]]; then
    echo "错误: peer task init 至少需要一个 --step <id>:<desc>。" >&2
    return 1
  fi
  if ! is_positive_int "$frozen_round"; then
    echo "错误: --round 必须是正整数。" >&2
    return 1
  fi
  task_file="$(task_file_for_id "$agent_id")"
  task_dir="${task_file%/*}"
  mkdir -p "$task_dir"
  if [[ -e "$task_file" ]]; then
    echo "错误: task.json 已存在: .agent-duo/state/$agent_id/task.json" >&2
    return 1
  fi
  tmp="$task_dir/.task.json.$$"
  if ! write_task_json "$tmp" "$agent_id" "$task_title" "$frozen_round" "$@"; then
    rm -f "$tmp"
    return 1
  fi
  mv "$tmp" "$task_file"
}

task_print() { # <agent_id>
  local agent_id="$1" task_file
  task_file="$(task_file_for_id "$agent_id")"
  if [[ ! -f "$task_file" ]]; then
    echo "没有 task.json: .agent-duo/state/$agent_id/task.json" >&2
    return 1
  fi
  jq -r '
    "TASK\t\(.task // "")",
    "FROZEN_AT_ROUND\t\(.frozen_at_round // "")",
    "CURRENT_STEP\t\(.current_step // "")",
    (.steps[]? | "\(.id)\t\(.status // "pending")\t\(.desc // "")")
  ' "$task_file"
}

task_next() { # <agent_id>
  local agent_id="$1" task_file
  task_file="$(task_file_for_id "$agent_id")"
  if [[ ! -f "$task_file" ]]; then
    echo "没有 task.json: .agent-duo/state/$agent_id/task.json" >&2
    return 1
  fi
  jq -r '
    def one($s): [.steps[]? | select((.status // "pending") == $s)][0];
    (one("blocked") // one("in_progress") // one("pending")) as $step
    | if $step == null then "done" else "\($step.id)\t\($step.status // "pending")\t\($step.desc // "")" end
  ' "$task_file"
}

loop_file_for_id() { # <agent_id>
  printf '%s/state/%s/loop.json' "$AGENT_DUO_DIR" "$1"
}

is_validation_id() {
  [[ "${1:-}" =~ ^[A-Za-z0-9._-]+$ ]]
}

parse_validation_pair() { # <option_name> <id:value>; sets VALIDATION_ID VALIDATION_VALUE
  local opt="$1" spec="${2:-}"
  if [[ "$spec" != *:* ]]; then
    echo "错误: $opt 需要 id:value 格式。" >&2
    return 1
  fi
  VALIDATION_ID="${spec%%:*}"
  VALIDATION_VALUE="${spec#*:}"
  if ! is_validation_id "$VALIDATION_ID"; then
    echo "错误: $opt 的 id 只能包含字母、数字、点、下划线和连字符。" >&2
    return 1
  fi
  if [[ -z "$VALIDATION_VALUE" ]]; then
    echo "错误: $opt 的 value 不能为空。" >&2
    return 1
  fi
}

validation_id_in_list() { # <id> [id...]
  local needle="$1" item
  shift || true
  for item in "$@"; do
    [[ "$item" == "$needle" ]] && return 0
  done
  return 1
}

build_validation_json() {
  local spec id cmd timeout signal first_val first_signal seen_signal i
  local -a ids cmds
  ids=()
  cmds=()
  if (( ${#loop_validations[@]} == 0 )); then
    printf '[]'
    return 0
  fi
  for spec in "${loop_validations[@]}"; do
    parse_validation_pair "--validation" "$spec" || return 1
    id="$VALIDATION_ID"
    cmd="$VALIDATION_VALUE"
    if validation_id_in_list "$id" "${ids[@]+"${ids[@]}"}"; then
      echo "错误: --validation id 重复: $id" >&2
      return 1
    fi
    ids+=("$id")
    cmds+=("$cmd")
  done
  for spec in ${loop_validation_satisfies[@]+"${loop_validation_satisfies[@]}"}; do
    parse_validation_pair "--validation-satisfies" "$spec" || return 1
    if ! validation_id_in_list "$VALIDATION_ID" "${ids[@]+"${ids[@]}"}"; then
      echo "错误: --validation-satisfies 引用了不存在的 validation id: $VALIDATION_ID" >&2
      return 1
    fi
  done
  for spec in ${loop_validation_timeouts[@]+"${loop_validation_timeouts[@]}"}; do
    parse_validation_pair "--validation-timeout" "$spec" || return 1
    if ! validation_id_in_list "$VALIDATION_ID" "${ids[@]+"${ids[@]}"}"; then
      echo "错误: --validation-timeout 引用了不存在的 validation id: $VALIDATION_ID" >&2
      return 1
    fi
    if ! is_positive_int "$VALIDATION_VALUE"; then
      echo "错误: --validation-timeout 的秒数必须是正整数。" >&2
      return 1
    fi
  done

  printf '['
  first_val=1
  for (( i=0; i<${#ids[@]}; i++ )); do
    id="${ids[$i]}"
    cmd="${cmds[$i]}"
    timeout="${AGENT_DUO_VALIDATION_TIMEOUT:-120}"
    if ! is_positive_int "$timeout"; then
      timeout="120"
    fi
    for spec in ${loop_validation_timeouts[@]+"${loop_validation_timeouts[@]}"}; do
      parse_validation_pair "--validation-timeout" "$spec" >/dev/null || return 1
      if [[ "$VALIDATION_ID" == "$id" ]]; then
        timeout="$VALIDATION_VALUE"
      fi
    done
    if [[ $first_val -eq 1 ]]; then first_val=0; else printf ','; fi
    printf '{"id":'; json_str "$id"
    printf ',"cmd":'; json_str "$cmd"
    printf ',"timeout_seconds":%s' "$timeout"
    printf ',"satisfies":['
    first_signal=1
    seen_signal=0
    for spec in ${loop_validation_satisfies[@]+"${loop_validation_satisfies[@]}"}; do
      parse_validation_pair "--validation-satisfies" "$spec" >/dev/null || return 1
      if [[ "$VALIDATION_ID" == "$id" ]]; then
        signal="$VALIDATION_VALUE"
        if [[ $first_signal -eq 1 ]]; then first_signal=0; else printf ','; fi
        json_str "$signal"
        seen_signal=1
      fi
    done
    if [[ $seen_signal -eq 0 ]]; then
      json_str "$id"
    fi
    printf ']}'
  done
  printf ']'
}

write_loop_json() { # <path> <agent_id> <mission> <max_rounds> <frozen_round> <non_goals_json> <success_json> <validation_json>
  local path="$1" agent_id="$2" mission="$3" max_rounds="$4" frozen_round="$5" non_goals_json="$6" success_json="$7" validation_json="$8" now
  now="$(iso_ts)"
  {
    printf '{"protocol":"1",'
    printf '"agent_id":'; json_str "$agent_id"; printf ','
    printf '"mission":'; json_str "$mission"; printf ','
    printf '"non_goals":%s,' "$non_goals_json"
    printf '"success_signals":%s,' "$success_json"
    printf '"validation":%s,' "$validation_json"
    printf '"max_rounds":%s,' "$max_rounds"
    printf '"frozen_at_round":%s,' "$frozen_round"
    printf '"status":"active",'
    printf '"stop":{"on_terminal":true,"reason":null,"stopped_at_round":null,"stopped_at":null},'
    printf '"created_at":'; json_str "$now"; printf ','
    printf '"updated_at":'; json_str "$now"
    printf '}\n'
  } > "$path"
}

loop_init() { # <agent_id> <mission> <max_rounds> <frozen_round> <non_goals_json> <success_json> <validation_json>
  local agent_id="$1" mission="$2" max_rounds="$3" frozen_round="$4" non_goals_json="$5" success_json="$6" validation_json="$7"
  local loop_file loop_dir tmp
  if [[ -z "$mission" ]]; then
    echo "错误: peer loop init 需要 --mission。" >&2
    return 1
  fi
  if ! is_positive_int "$max_rounds"; then
    echo "错误: --max-rounds 必须是正整数。" >&2
    return 1
  fi
  if ! is_positive_int "$frozen_round"; then
    echo "错误: --round 必须是正整数。" >&2
    return 1
  fi
  loop_file="$(loop_file_for_id "$agent_id")"
  loop_dir="${loop_file%/*}"
  mkdir -p "$loop_dir"
  if [[ -e "$loop_file" ]]; then
    echo "错误: loop.json 已存在: .agent-duo/state/$agent_id/loop.json" >&2
    return 1
  fi
  tmp="$loop_dir/.loop.json.$$"
  if ! write_loop_json "$tmp" "$agent_id" "$mission" "$max_rounds" "$frozen_round" "$non_goals_json" "$success_json" "$validation_json"; then
    rm -f "$tmp"
    return 1
  fi
  mv "$tmp" "$loop_file"
}

loop_print() { # <agent_id>
  local agent_id="$1" loop_file current_round
  loop_file="$(loop_file_for_id "$agent_id")"
  if [[ ! -f "$loop_file" ]]; then
    echo "没有 loop.json: .agent-duo/state/$agent_id/loop.json" >&2
    return 1
  fi
  current_round="$(report_round_for_id "$agent_id")"
  jq -r --argjson current_round "$current_round" '
    (.frozen_at_round // 1) as $frozen
    | (.max_rounds // 0) as $max
    | ($current_round - $frozen + 1) as $used
    | "MISSION\t\(.mission // "")",
      "STATUS\t\(.status // "active")",
      "ROUND\t\($current_round)",
      "FROZEN_AT_ROUND\t\($frozen)",
      "MAX_ROUNDS\t\($max)",
      "ROUNDS_USED\t\($used)",
      "REMAINING\t\($max - $used)",
      "STOP_REASON\t\(.stop.reason // "")",
      "NON_GOALS\t\((.non_goals // []) | join("; "))",
      "SUCCESS_SIGNALS\t\((.success_signals // []) | join("; "))",
      "VALIDATION\t\((.validation // []) | map(((.id // "") | tostring) + ":" + ((.cmd // "") | tostring)) | join("; "))"
  ' "$loop_file"
}

loop_guard_ask() { # <agent_id>
  local agent_id="$1" loop_file loop_json status reason max_rounds frozen_round current_round rounds_used
  loop_file="$(loop_file_for_id "$agent_id")"
  [[ -e "$loop_file" ]] || return 0
  if ! loop_json="$(jq -c '.' "$loop_file" 2>/dev/null)"; then
    echo "警告: 无法读取 .agent-duo/state/$agent_id/loop.json，loop 边界本次 fail-open；broker 门仍会照常执行。" >&2
    return 0
  fi
  status="$(jq -r '.status // "active"' <<EOF
$loop_json
EOF
)"
  max_rounds="$(jq -r '.max_rounds // empty' <<EOF
$loop_json
EOF
)"
  frozen_round="$(jq -r '.frozen_at_round // empty' <<EOF
$loop_json
EOF
)"
  if [[ "$status" == "stopped" ]]; then
    reason="$(jq -r '.stop.reason // "unknown"' <<EOF
$loop_json
EOF
)"
    echo "错误: worker '$agent_id' 的 loop 已到界(reason=$reason),已拒绝继续派发。" >&2
    echo "      经人确认后用 'peer ask --force $agent_id \"...\"' 越界,或后续用 peer loop reset(待实现)。" >&2
    return 1
  fi
  if ! is_positive_int "$max_rounds" || ! is_positive_int "$frozen_round"; then
    echo "警告: .agent-duo/state/$agent_id/loop.json 边界字段无效，loop 边界本次 fail-open；broker 门仍会照常执行。" >&2
    return 0
  fi
  current_round="$(report_round_for_id "$agent_id")"
  rounds_used="$(( current_round - frozen_round + 1 ))"
  if (( rounds_used > 0 && rounds_used >= max_rounds )); then
    echo "错误: worker '$agent_id' 的 loop 已到界(reason=max_rounds, ${rounds_used}/${max_rounds}),已拒绝继续派发。" >&2
    echo "      经人确认后用 'peer ask --force $agent_id \"...\"' 越界,或后续用 peer loop reset(待实现)。" >&2
    return 1
  fi
}

report_summary_from_file() { # <report_file>
  jq -r '
    def clean: if . == null then "" else tostring | gsub("[\r\n\t]"; " ") end;
    (.delta | clean) as $delta
    | (.next | clean) as $next
    | ((.needs // [])[0] // {}) as $need
    | ($need.detail | clean) as $detail
    | ($need.kind | clean) as $kind
    | if $delta != "" then $delta
      elif $next != "" then $next
      elif $detail != "" then $detail
      elif $kind != "" then "needs:\($kind)"
      else "\(.type // "report")/\(.status // "unknown")"
      end
  ' "$1"
}

ask_print_report() { # <agent_id> <round>
  local agent_id="$1" round="$2" file ref status delta next_text needs summary
  file="$(report_file_for_round "$agent_id" "$round")"
  ref=".agent-duo/state/$agent_id/r${round}.json"
  if [[ ! -f "$file" ]]; then
    file="$AGENT_DUO_DIR/state/$agent_id/report.json"
    ref=".agent-duo/state/$agent_id/report.json"
  fi
  if [[ ! -f "$file" ]]; then
    echo "错误: 找不到新 report 文件: .agent-duo/state/$agent_id/r${round}.json" >&2
    return 1
  fi
  status="$(jq -r '.status // "unknown"' "$file")"
  delta="$(jq -r '.delta // ""' "$file")"
  next_text="$(jq -r '.next // ""' "$file")"
  needs="$(jq -c '.needs // []' "$file")"
  summary="$(report_summary_from_file "$file")"
  printf 'ROUND\t%s\n' "$round"
  printf 'STATUS\t%s\n' "$status"
  printf 'SUMMARY\t%s\n' "$summary"
  printf 'DELTA\t%s\n' "$delta"
  printf 'NEXT\t%s\n' "$next_text"
  printf 'NEEDS\t%s\n' "$needs"
  printf 'REF\t%s\n' "$ref"
}

check_target_dispatch_allowed() { # <target_id> <target_pane>
  local target_id="$1" target="$2" gate_role bg_out bg_status
  # Broker 硬门:发给工作型角色(非 supervisor/daemon/loopd)时,broker 必须 fresh ready,否则拒发
  # (fail-closed)。worker/reviewer/自定义工作角色都受保护,与 lib/loop.sh 的 active-worker 模型一致。
  # 豁免:--force(FORCE_SEND)或 AGENT_DUO_NO_BROKER_GATE=1。broker-check 探针不经 tell,天然豁免。
  gate_role="$(role_for_id "$target_id")"
  if role_is_gated "$gate_role" \
     && [[ "${FORCE_SEND:-0}" != "1" && "${AGENT_DUO_NO_BROKER_GATE:-0}" != "1" ]]; then
    bg_out="$(run_approval_broker status --agent-id "$target_id" --root "$AGENT_DUO_ROOT" 2>/dev/null)"
    case "$bg_out" in
      *'"status":"ready"'*) ;;  # fresh ready → 放行
      *)
        bg_status="$(printf '%s' "$bg_out" | grep -o '"status":"[^"]*"' | head -1)"
        echo "错误: '$target_id' 的 Approval Broker 非 fresh ready（${bg_status:-未知}），已拒绝派发。" >&2
        echo "      先运行 'peer broker-check $target_id' 验证 broker 生效，或用 'peer tell --force $target_id ...' 强制发送。" >&2
        return 1
        ;;
    esac
  fi
  check_safe_to_send_keys "$target"
}

task_step_exists() { # <task_file> <step_id>
  jq -e --arg id "$2" 'any(.steps[]?; .id == $id)' "$1" >/dev/null 2>&1
}

task_all_steps_done() { # <task_file>
  jq -e '
    ((.steps // []) | length) > 0 and
    ([.steps[]? | select((.status // "pending") != "done" and (.status // "pending") != "kept")] | length) == 0
  ' "$1" >/dev/null 2>&1
}

task_evidence_json() { # <cmd> <result> <ref>
  local cmd="$1" result="$2" ref="$3"
  if [[ -z "$cmd" && -z "$result" && -z "$ref" ]]; then
    printf '[]'
    return
  fi
  printf '[{"cmd":'; json_str "$cmd"
  printf ',"result":'; json_str "$result"
  printf ',"ref":'; json_str "$ref"
  printf '}]'
}

task_step_status_for_report() { # <report_type> <report_status> <effective_status>
  local report_type="$1" report_status="$2" effective_status="$3"
  if [[ "$report_status" == "done" && "$effective_status" != "unknown" ]]; then
    printf 'done'
    return 0
  fi
  if [[ "$report_type" == "request" || "$effective_status" == "blocked" ]]; then
    printf 'blocked'
    return 0
  fi
  case "$effective_status" in
    in_progress|failed) printf '%s' "$effective_status" ;;
    *) return 1 ;;
  esac
}

task_prepare_update() { # <task_file> <tmp_file> <step_id> <step_status> <round> <evidence_json>
  local task_file="$1" tmp_file="$2" step_id="$3" step_status="$4" round_s="$5" evidence_json="$6"
  if ! task_step_exists "$task_file" "$step_id"; then
    echo "错误: task.json 中不存在 step '$step_id'。" >&2
    return 1
  fi
  if ! is_step_status "$step_status"; then
    echo "错误: 非法 step 状态 '$step_status'。" >&2
    return 1
  fi
  jq -c \
    --arg id "$step_id" \
    --arg status "$step_status" \
    --arg ts "$(iso_ts)" \
    --argjson round "$round_s" \
    --argjson evidence "$evidence_json" '
      .updated_at = $ts
      | .current_step = (if ($status == "done" or $status == "kept") then null else $id end)
      | .steps |= map(
          if .id == $id then
            .status = $status
            | .last_round = $round
            | if $status == "done" then .evidence = ((.evidence // []) + $evidence) else . end
          else . end
        )
    ' "$task_file" > "$tmp_file"
}

append_event_json() {
  local queue="$1" event_id="$2" ts="$3" agent="$4" event_type="$5" round_s="$6" summary="$7" ref="$8"
  # 先把整行拼好，再单次 printf 追加：queue.jsonl 是多进程共享(loopd / 各 agent /
  # approval broker)，多次 printf 共享 append 重定向会在并发下交错损坏行。
  local line
  line="$(
    printf '{"id":'; json_str "$event_id"
    printf ',"ts":'; json_str "$ts"
    printf ',"agent":'; json_str "$agent"
    printf ',"type":'; json_str "$event_type"
    printf ',"round":%s' "$round_s"
    printf ',"summary":'; json_str "$summary"
    printf ',"ref":'; json_str "$ref"
    printf '}'
  )"
  printf '%s\n' "$line" >> "$queue"
}

json_array() {
  local first=1 item
  printf '['
  for item in "$@"; do
    if [[ $first -eq 1 ]]; then first=0; else printf ','; fi
    json_str "$item"
  done
  printf ']'
}

gates_dir() {
  printf '%s/gates' "$AGENT_DUO_DIR"
}

logs_dir() {
  printf '%s/logs' "$AGENT_DUO_DIR"
}

gate_path() { # <gate_id>
  printf '%s/%s.json' "$(gates_dir)" "$1"
}

new_gate_id() { # <round>
  printf 'g%s-r%s-%s' "$(date -u '+%Y%m%dT%H%M%SZ')" "$1" "$$"
}

write_gate_json() {
  local path="$1" gate_id="$2" ts="$3" agent_id="$4" role="$5" round_s="$6"
  local title="$7" detail="$8" report_ref="$9" options_json="${10}"
  {
    printf '{"protocol":"1",'
    printf '"id":'; json_str "$gate_id"; printf ','
    printf '"status":"pending",'
    printf '"kind":"decision",'
    printf '"agent_id":'; json_str "$agent_id"; printf ','
    printf '"role":'; json_str "$role"; printf ','
    printf '"round":%s,' "$round_s"
    printf '"title":'; json_str "$title"; printf ','
    printf '"detail":'; json_nullable_str "$detail"; printf ','
    printf '"options":%s,' "$options_json"
    printf '"report_ref":'; json_nullable_str "$report_ref"; printf ','
    printf '"created_at":'; json_str "$ts"; printf ','
    printf '"resolved_at":null,"resolved_by":null,"choice":null,"note":null'
    printf '}\n'
  } > "$path"
}

append_decision_log() {
  local gate_id="$1" status="$2" agent="$3" summary="$4" choice="$5" note="$6"
  local log line
  mkdir -p "$(logs_dir)"
  log="$(logs_dir)/decisions.jsonl"
  line="$(
    printf '{"ts":'; json_str "$(iso_ts)"
    printf ',"gate":'; json_str "$gate_id"
    printf ',"status":'; json_str "$status"
    printf ',"agent":'; json_str "$agent"
    printf ',"summary":'; json_str "$summary"
    printf ',"choice":'; json_nullable_str "$choice"
    printf ',"note":'; json_nullable_str "$note"
    printf '}'
  )"
  printf '%s\n' "$line" >> "$log"
}

create_gate_record() { # <gate_id> <ts> <agent> <role> <round> <title> <detail> <report_ref> [option...]
  local gate_id="$1" ts="$2" agent="$3" role="$4" round_s="$5" title="$6" detail="$7" report_ref="$8"
  local dir path tmp options_json
  shift 8
  dir="$(gates_dir)"
  mkdir -p "$dir"
  path="$(gate_path "$gate_id")"
  if [[ -e "$path" ]]; then
    echo "错误: gate 已存在: $gate_id" >&2
    return 1
  fi
  options_json="$(json_array "$@")"
  tmp="$dir/.${gate_id}.json.$$"
  write_gate_json "$tmp" "$gate_id" "$ts" "$agent" "$role" "$round_s" "$title" "$detail" "$report_ref" "$options_json"
  mv "$tmp" "$path"
}

gate_pending_ids() {
  local dir file
  dir="$(gates_dir)"
  for file in "$dir"/*.json; do
    [[ -f "$file" ]] || continue
    jq -r 'select((.status // "pending") == "pending") | .id // empty' "$file" 2>/dev/null || true
  done
}

gate_pick_unique_pending() {
  local ids count
  ids="$(gate_pending_ids | sed '/^$/d')"
  if [[ -z "$ids" ]]; then
    count="0"
  else
    count="$(printf '%s\n' "$ids" | wc -l | tr -d ' ')"
  fi
  case "$count" in
    0) return 1 ;;
    1) printf '%s' "$ids"; return 0 ;;
    *)
      echo "错误: 存在多个 pending gate,请指定 gate id。可用 'peer gate' 查看。" >&2
      return 2
      ;;
  esac
}

gate_pending_ids_for_agent() { # <agent_id>
  local agent="$1" dir file
  dir="$(gates_dir)"
  for file in "$dir"/*.json; do
    [[ -f "$file" ]] || continue
    jq -r --arg agent "$agent" '
      select((.status // "pending") == "pending" and (.agent_id // "") == $agent) | .id // empty
    ' "$file" 2>/dev/null || true
  done
}

gate_pick_unique_pending_for_agent() { # <agent_id>
  local agent="$1" ids count
  ids="$(gate_pending_ids_for_agent "$agent" | sed '/^$/d')"
  if [[ -z "$ids" ]]; then
    count="0"
  else
    count="$(printf '%s\n' "$ids" | wc -l | tr -d ' ')"
  fi
  case "$count" in
    0) return 1 ;;
    1) printf '%s' "$ids"; return 0 ;;
    *)
      echo "错误: agent '$agent' 存在多个 pending gate,请指定 gate id。可用 'peer gate' 查看。" >&2
      return 2
      ;;
  esac
}

gate_print_list() { # <show_all:0|1>
  local show_all="$1" dir file row id status agent round title options any
  any=0
  dir="$(gates_dir)"
  for file in "$dir"/*.json; do
    [[ -f "$file" ]] || continue
    status="$(jq -r '.status // "pending"' "$file" 2>/dev/null || printf 'pending')"
    if [[ "$show_all" != "1" && "$status" != "pending" ]]; then
      continue
    fi
    if [[ "$any" == "0" ]]; then
      printf '%-24s %-10s %-10s %-8s %s\n' "ID" "STATUS" "AGENT" "ROUND" "TITLE"
    fi
    any=1
    row="$(jq -r '
      [
        (.id // ""),
        (.status // "pending"),
        (.agent_id // ""),
        ("r" + ((.round // 0) | tostring)),
        ((.title // .detail // "") | gsub("[\r\n\t]"; " ")),
        ((.options // []) | join(","))
      ] | @tsv
    ' "$file" 2>/dev/null || true)"
    IFS=$'\t' read -r id status agent round title options <<< "$row"
    printf '%-24s %-10s %-10s %-8s %s' "$id" "$status" "$agent" "$round" "$(printf '%s' "$title" | cut -c1-80)"
    if [[ -n "$options" ]]; then
      printf ' [options: %s]' "$options"
    fi
    printf '\n'
  done
  if [[ "$any" == "0" ]]; then
    if [[ "$show_all" == "1" ]]; then
      printf '没有 human gate。\n'
    else
      printf '没有待处理 human gate。\n'
    fi
  fi
}

gate_field() { # <gate_id> <jq_expr>
  local path
  path="$(gate_path "$1")"
  [[ -f "$path" ]] || return 1
  jq -r "$2 // empty" "$path"
}

gate_resolve_record() { # <gate_id> <choice> <note>
  local gate_id="$1" choice="$2" note="$3" path tmp agent summary
  path="$(gate_path "$gate_id")"
  if [[ ! -f "$path" ]]; then
    echo "错误: 找不到 gate '$gate_id'。" >&2
    return 1
  fi
  if [[ "$(jq -r '.status // "pending"' "$path")" != "pending" ]]; then
    echo "错误: gate '$gate_id' 不是 pending。" >&2
    return 1
  fi
  tmp="${path}.$$"
  jq -c --arg ts "$(iso_ts)" --arg by "$ME" --arg choice "$choice" --arg note "$note" '
    .status = "resolved"
    | .resolved_at = $ts
    | .resolved_by = $by
    | .choice = $choice
    | .note = (if $note == "" then null else $note end)
  ' "$path" > "$tmp"
  mv "$tmp" "$path"
  agent="$(jq -r '.agent_id // ""' "$path")"
  summary="$(jq -r '.detail // .title // ""' "$path")"
  append_decision_log "$gate_id" "resolved" "$agent" "$summary" "$choice" "$note"
}

screen_has_round_sentinel() { # <screen> <round> <agent_id> [codec_tag]
  local screen="$1" round="$2" agent_id="$3" tag="${4:-}"
  printf '%s\n' "$screen" | awk -v r="round=${round}" -v a="agent_id=${agent_id}" -v tag="$tag" '
    index($0, "«AGENTDUO:") {
      if (tag != "" && index($0, "«AGENTDUO:" tag "»") == 0) next
      has_round=0; has_agent=0; has_file=0; has_sha=0
      for (i = 1; i <= NF; i++) {
        if ($i == r) has_round=1
        if ($i == a) has_agent=1
        if (index($i, "file=") == 1 && length($i) > 5) has_file=1
        if (index($i, "sha=") == 1 && length($i) > 4) has_sha=1
      }
      if (has_round && has_agent && has_file && has_sha) found=1
    }
    END { exit found ? 0 : 1 }
  '
}

ensure_session() {
  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "错误: tmux 会话 '$SESSION' 不存在。" >&2
    exit 1
  fi
}

capture() { # <pane> <lines>
  local pane="$1" lines="${2:-80}"
  tmux capture-pane -p -J -t "$pane" -S "-$lines"
}

matches_screen() {
  local screen="$1" pattern="$2"
  printf '%s\n' "$screen" | grep -Eiq "$pattern"
}

looks_like_prompt() {
  local screen="$1"

  # Claude/Codex option menus: a selector cursor plus explicit Yes/No choices.
  if matches_screen "$screen" '^[[:space:]]*(❯|›)[[:space:]]' &&
     matches_screen "$screen" '^[[:space:]]*[12]\.[[:space:]]*(yes|no)([[:space:]]|$)|^[[:space:]]*(yes|no)[[:space:]]*/[[:space:]]*(no|yes)([[:space:]]|$)|^[[:space:]]*(❯|›)[[:space:]]*([12]\.[[:space:]]*)?(yes|no)([[:space:]]|$)'; then
    return 0
  fi

  local pattern
  while IFS= read -r pattern; do
    [[ -z "$pattern" || "${pattern:0:1}" == "#" ]] && continue
    if matches_screen "$screen" "$pattern"; then
      return 0
    fi
  done <<'PATTERNS'
# Claude/Codex natural-language proceed prompts.
do you want to proceed
# Permission approval wording; avoid matching "approved" history.
(^|[^[:alpha:]])approve([^[:alpha:]]|$)
# Command permission prompt wording.
allow command
# Compact y/n prompts.
\([[:space:]]*y[[:space:]]*/[[:space:]]*n[[:space:]]*\)
# Bracketed y/n prompts.
\[[[:space:]]*y[[:space:]]*/[[:space:]]*n[[:space:]]*\]
# Confirmation UIs that ask Enter to accept/continue.
press enter to
# Chinese permission/confirmation wording.
是否|允许|确认|继续吗
PATTERNS
  return 1
}

check_safe_to_send_keys() { # <pane>
  local pane="$1"
  if [[ "$FORCE_SEND" == "1" || "${PEER_FORCE:-0}" == "1" ]]; then
    echo "提示: 已跳过对方权限弹窗检测(--force / PEER_FORCE=1)。" >&2
    return 0
  fi

  local lines="${PEER_PROMPT_CHECK_LINES:-80}"
  if ! is_positive_int "$lines"; then
    echo "错误: PEER_PROMPT_CHECK_LINES 必须是正整数。" >&2
    exit 1
  fi

  local screen
  screen="$(capture "$pane" "$lines")"
  if looks_like_prompt "$screen"; then
    echo "错误: 目标 agent 疑似正在等待权限确认/弹窗,peer 未发送按键。请人工查看;如确认强制发送,用 --force 或 PEER_FORCE=1。" >&2
    exit 3
  fi
}

paste_buffer_and_enter() { # <pane> <buffer_name>
  local pane="$1" buf="$2"
  # -p: bracketed paste,TUI 将其识别为一次完整粘贴(多行不会被逐行提交)
  # -d: 粘贴后删除缓冲区
  tmux paste-buffer -b "$buf" -t "$pane" -d -p
  # 给 TUI 一点处理粘贴的时间,立刻回车可能被吞掉。
  sleep 0.5
  tmux send-keys -t "$pane" Enter
}

send_text_to_pane() { # <pane> <buffer_name> <text>
  local pane="$1" buf="$2" text="$3"
  printf '%s' "$text" | tmux load-buffer -b "$buf" -
  paste_buffer_and_enter "$pane" "$buf"
}

FORCE_SEND=0
if [[ "${1:-}" == "--force" ]]; then
  FORCE_SEND=1
  shift
fi

cmd="${1:-help}"
shift || true

case "$cmd" in
  ls)
    if ! tmux has-session -t "$SESSION" 2>/dev/null; then
      echo "错误: tmux 会话 '$SESSION' 不存在。" >&2
      exit 1
    fi
    printf '%-3s %-16s %-12s %-10s %s\n' '' 'ID' 'ROLE' 'PROVIDER' 'PANE'
    while IFS=$'\t' read -r pane id role provider; do
      [[ -z "$pane" ]] && continue
      mark=' '
      [[ "$pane" == "$SELF_PANE" ]] && mark='*'
      if [[ -z "$id" ]]; then
        printf '%-3s %-16s %-12s %-10s %s\n' "$mark" '(unregistered)' '-' '-' "$pane"
      else
        printf '%-3s %-16s %-12s %-10s %s\n' "$mark" "$id" "$role" "$provider" "$pane"
      fi
    done < <(list_agents)
    ;;

  add)
    ensure_session
    provider=""; role=""; want_id=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --provider) provider="${2:-}"; shift 2 ;;
        --role)     role="${2:-}"; shift 2 ;;
        --id)       want_id="${2:-}"; shift 2 ;;
        *) echo "错误: 未知参数 '$1'。用法: peer add --provider claude|codex --role <role> [--id <id>]" >&2; exit 1 ;;
      esac
    done
    if ! reg_validate_provider "$provider"; then
      echo "错误: provider 必须是 claude 或 codex,当前为 '$provider'。" >&2; exit 1
    fi
    if [[ -z "$role" ]]; then
      echo "错误: 必须用 --role 指定角色。" >&2; exit 1
    fi
    new_id="$want_id"
    if [[ -z "$new_id" ]]; then
      new_id="$(reg_derive_id "$role" "$(agent_ids)")"
    elif agent_ids | grep -qx "$new_id"; then
      echo "错误: id '$new_id' 已被占用。" >&2; exit 1
    fi
    # 新建 window(裸 shell),捕获 pane;按 start.sh 模式 send-keys 导出环境并启动 provider。
    new_pane="$(tmux new-window -t "$SESSION" -n "$new_id" -c "$PWD" -P -F '#{pane_id}')"
    tmux set-option -p -t "$new_pane" @agent_id "$new_id"
    tmux set-option -p -t "$new_pane" @agent_role "$role"
    tmux set-option -p -t "$new_pane" @agent_provider "$provider"
    approval_settings="$(install_approval_session_settings "$new_id" "$provider" "$PWD")"
    launch="$(reg_provider_launch_cmd "$provider" "$PEER_INSTR")"
    if [[ "$provider" == "claude" ]]; then
      launch="$launch --settings $(printf '%q' "$approval_settings")"
    else
      hook_command="$(jq -r '.codex.managed_hook_command' "$approval_settings")"
      launch="$launch -c $(printf '%q' "$(codex_hook_config PreToolUse "$hook_command" "*")")"
      launch="$launch -c $(printf '%q' "$(codex_hook_config PermissionRequest "$hook_command" "*")")"
    fi
    bin_dir="$(dirname "$PEER_SRC")"
    root_q="$(printf '%q' "$AGENT_DUO_ROOT")"
    agent_q="$(printf '%q' "$new_id")"
    worktree_q="$(printf '%q' "$PWD")"
    hook_q="$(printf '%q' "$APPROVAL_HOOK")"
    settings_q="$(printf '%q' "$approval_settings")"
    tmux send-keys -t "$new_pane" \
      "export AGENT_SESSION=$(printf '%q' "$SESSION") AGENT_DUO_ROOT=$root_q AGENT_DUO_AGENT_ID=$agent_q AGENT_DUO_WORKTREE=$worktree_q AGENT_DUO_APPROVAL_HOOK=$hook_q AGENT_DUO_APPROVAL_SETTINGS=$settings_q PATH=$(printf '%q' "$bin_dir"):\$PATH; $launch" Enter
    echo "已创建 agent '$new_id'(role=$role, provider=$provider, pane=$new_pane)。"
    # broker 起始为 unverified:hook 未被 provider 实际调用前不得假设其生效。
    run_approval_broker mark --agent-id "$new_id" --status unverified --root "$AGENT_DUO_ROOT" >/dev/null 2>&1 || true
    # 工作型角色(任何 provider)都受派发硬门保护:派任务前必须先 broker-check,否则首次 peer tell 被拒发。
    if role_is_gated "$role"; then
      echo "提示: '$new_id' 的 Approval Broker 起始为 unverified;派任务前先运行 'peer broker-check $new_id' 验证 broker 生效,否则首次 'peer tell $new_id ...' 会被硬门 fail-closed 拒发。"
    fi
    if [[ "$provider" == "codex" ]]; then
      echo "Codex hook 提示: 若该 pane 提示 hooks need review，请运行 /hooks 并信任 agent-duo hook(信任前 broker-check 不会通过)。"
    fi
    ;;

  broker-status)
    ensure_session
    maybe_id="${1:-}"
    if [[ -z "$maybe_id" ]]; then
      maybe_id="$(reg_pick_other "$(self_id)" "$(agent_ids)")" || {
        echo "用法: peer broker-status <id>(多于两人时必须指定 id)" >&2; exit 1; }
    fi
    agent_ids | grep -qx "$maybe_id" || { echo "错误: 找不到 agent '$maybe_id'。" >&2; exit 1; }
    bs_json="$(run_approval_broker status --agent-id "$maybe_id" --root "$AGENT_DUO_ROOT")"
    printf '%s\n' "$bs_json"
    case "$bs_json" in
      *'"status":"ready"'*) ;;
      *) echo "提示: '$maybe_id' broker 非 fresh ready,派发需 broker 保护的任务前请先 'peer broker-check $maybe_id'。" >&2 ;;
    esac
    ;;

  broker-check)
    ensure_session
    maybe_id=""; nonce=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --nonce) nonce="${2:-}"; shift 2 ;;   # 测试用:固定 nonce
        *) if [[ -z "$maybe_id" ]]; then maybe_id="$1"; shift; else
             echo "用法: peer broker-check <id> [--nonce <n>]" >&2; exit 1; fi ;;
      esac
    done
    if [[ -z "$maybe_id" ]]; then
      maybe_id="$(reg_pick_other "$(self_id)" "$(agent_ids)")" || {
        echo "用法: peer broker-check <id>(多于两人时必须指定 id)" >&2; exit 1; }
    fi
    agent_ids | grep -qx "$maybe_id" || { echo "错误: 找不到 agent '$maybe_id'。" >&2; exit 1; }
    target="$(pane_for_id "$maybe_id")"
    [[ -n "$nonce" ]] || nonce="bc$(random_hex_tag)"
    probe_cmd="$(run_approval_broker selfcheck-cmd --nonce "$nonce")"
    # 把 probe 作为一条祈使提示投递给 worker;worker 跑该命令 → 触发 hook → 写 ready+nonce。
    prompt="agent-duo broker self-check。请立刻原样执行下面这条 shell 命令,不要解释、不要询问、不要改写: ${probe_cmd}"
    check_safe_to_send_keys "$target"
    buf="peer-brokercheck-${maybe_id}"
    send_text_to_pane "$target" "$buf" "$prompt"
    echo "已向 '$maybe_id' 投递 broker 自检探针(nonce=$nonce),等待 hook 拦截…"
    timeout="${AGENT_DUO_BROKER_CHECK_TIMEOUT:-60}"
    marker="$AGENT_DUO_DIR/state/$maybe_id/broker.json"
    i=0
    while [[ "$i" -lt "$timeout" ]]; do
      if [[ -f "$marker" ]] \
        && [[ "$(jq -r '.status // ""' "$marker" 2>/dev/null)" == "ready" ]] \
        && [[ "$(jq -r '.nonce // ""' "$marker" 2>/dev/null)" == "$nonce" ]]; then
        echo "✅ broker READY:'$maybe_id' 的 Approval Broker hook 已被 provider 实际调用并拦下探针。"
        exit 0
      fi
      sleep 1
      i=$(( i + 1 ))
    done
    run_approval_broker mark --agent-id "$maybe_id" --status fail-open --root "$AGENT_DUO_ROOT" >/dev/null 2>&1 || true
    echo "⚠️  broker FAIL-OPEN:${timeout}s 内未观察到 '$maybe_id' 的 hook 拦截探针。" >&2
    echo "    很可能 Codex hook 未被信任(/hooks 里 trust),或 worker 未执行该命令。" >&2
    echo "    在该 worker 生效前,不要派给它需要 Approval Broker 保护的任务。" >&2
    exit 1
    ;;

  peek)
    ensure_session
    maybe_id=""
    if [[ -n "${1:-}" ]] && ! is_positive_int "$1"; then maybe_id="$1"; shift; fi
    lines="${1:-80}"
    if ! is_positive_int "$lines"; then
      echo "错误: peer peek 的行数必须是正整数。" >&2
      exit 1
    fi
    target="$(resolve_target_pane "$maybe_id")"
    echo "===== 终端最近输出 ====="
    capture "$target" "$lines"
    echo "===== 输出结束 ====="
    ;;

  tell)
    ensure_session
    if [[ "${1:-}" == "--force" ]]; then
      FORCE_SEND=1
      shift
    fi
    # 首参若精确匹配某已注册 id → 作为目标消费掉。
    maybe_id=""
    if [[ -n "${1:-}" ]] && agent_ids | grep -qx "$1"; then
      maybe_id="$1"; shift
    fi
    target="$(resolve_target_pane "$maybe_id")"
    # 目标 id(用于 buffer 命名);两人默认时回查 other。
    if [[ -n "$maybe_id" ]]; then
      target_id="$maybe_id"
    else
      target_id="$(reg_pick_other "$ME" "$(agent_ids)")"
    fi
    check_target_dispatch_allowed "$target_id" "$target"
    buf="peer-${ME}2${target_id}"
    if [[ $# -gt 0 ]]; then
      printf '%s' "$*" | tmux load-buffer -b "$buf" -
    elif [[ ! -t 0 ]]; then
      tmux load-buffer -b "$buf" -
    else
      echo "用法: peer tell [<id>] \"消息\"  或  echo \"消息\" | peer tell [<id>]" >&2
      exit 1
    fi
    paste_buffer_and_enter "$target" "$buf"
    echo "已投递。(提示: 'peer wait' 等它完成,再 'peer peek' 查看回复)"
    ;;

  ask)
    ensure_session
    maybe_id=""
    ask_timeout="${PEER_ASK_TIMEOUT:-300}"
    ask_interval="${PEER_ASK_INTERVAL:-5}"
    ask_parts=()
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --timeout)
          ask_timeout="${2:-}"
          shift 2
          ;;
        --interval)
          ask_interval="${2:-}"
          shift 2
          ;;
        --force)
          FORCE_SEND=1
          shift
          ;;
        --)
          shift
          while [[ $# -gt 0 ]]; do ask_parts+=("$1"); shift; done
          ;;
        *)
          if [[ -z "$maybe_id" && ${#ask_parts[@]} -eq 0 ]] && agent_ids | grep -qx "$1"; then
            maybe_id="$1"
          else
            ask_parts+=("$1")
          fi
          shift
          ;;
      esac
    done
    if ! is_positive_int "$ask_timeout"; then
      echo "错误: peer ask --timeout 必须是正整数。" >&2
      exit 1
    fi
    if ! is_positive_int "$ask_interval"; then
      echo "错误: peer ask --interval 必须是正整数。" >&2
      exit 1
    fi
    if [[ ${#ask_parts[@]} -eq 0 ]]; then
      echo "用法: peer ask [<id>] \"消息\" [--timeout N] [--interval N] [--force]" >&2
      exit 1
    fi
    target="$(resolve_target_pane "$maybe_id")"
    if [[ -n "$maybe_id" ]]; then
      target_id="$maybe_id"
    else
      target_id="$(reg_pick_other "$ME" "$(agent_ids)")"
    fi
    if [[ "${FORCE_SEND:-0}" != "1" ]]; then
      loop_guard_ask "$target_id"
    fi
    pre_round="$(report_round_for_id "$target_id")"
    check_target_dispatch_allowed "$target_id" "$target"
    buf="peer-${ME}2${target_id}-ask"
    send_text_to_pane "$target" "$buf" "${ask_parts[*]}"

    elapsed=0
    while (( elapsed < ask_timeout )); do
      current_round="$(report_round_for_id "$target_id")"
      if (( current_round > pre_round )); then
        ask_print_report "$target_id" "$current_round"
        exit 0
      fi
      sleep "$ask_interval"
      elapsed="$(( elapsed + ask_interval ))"
    done
    echo "错误: peer ask 等待 '$target_id' 写出新 report 超时(${ask_timeout}s)。" >&2
    echo "===== 目标末屏(best-effort) =====" >&2
    capture "$target" 80 >&2 || true
    echo "===== 目标末屏结束 =====" >&2
    exit 2
    ;;

  wait)
    ensure_session
    maybe_id=""
    if [[ -n "${1:-}" && "${1:-}" != "--round" && "${1:-}" != "--timeout" && "${1:-}" != "--interval" ]] && ! is_positive_int "$1"; then maybe_id="$1"; shift; fi
    target="$(resolve_target_pane "$maybe_id")"

    round_wait=""
    round_timeout="${PEER_WAIT_TIMEOUT:-300}"
    round_interval="${PEER_WAIT_INTERVAL:-5}"
    if [[ "${1:-}" == --* ]]; then
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --round)
            round_wait="${2:-}"
            shift 2
            ;;
          --timeout)
            round_timeout="${2:-}"
            shift 2
            ;;
          --interval)
            round_interval="${2:-}"
            shift 2
            ;;
          *)
            echo "用法: peer wait [<id>] --round N [--timeout 秒] [--interval 秒]" >&2
            exit 1
            ;;
        esac
      done
    fi

    if [[ -n "$round_wait" ]]; then
      target_id="$maybe_id"
      if [[ -z "$target_id" ]]; then
        target_id="$(reg_pick_other "$ME" "$(agent_ids)")"
      fi
      if ! is_positive_int "$round_wait"; then
        echo "错误: peer wait --round 必须是正整数。" >&2
        exit 1
      fi
      if ! is_positive_int "$round_timeout"; then
        echo "错误: peer wait --timeout 必须是正整数。" >&2
        exit 1
      fi
      if ! is_positive_int "$round_interval"; then
        echo "错误: peer wait --interval 必须是正整数。" >&2
        exit 1
      fi
      lines="${PEER_WAIT_ROUND_LINES:-200}"
      if ! is_positive_int "$lines"; then
        echo "错误: PEER_WAIT_ROUND_LINES 必须是正整数。" >&2
        exit 1
      fi
      target_tag="$(tmux display-message -p -t "$target" '#{@agentduo_codec_tag}' 2>/dev/null || true)"
      elapsed=0
      while (( elapsed < round_timeout )); do
        cur="$(capture "$target" "$lines")"
        if screen_has_round_sentinel "$cur" "$round_wait" "$target_id" "$target_tag"; then
          echo "已看到 round=${round_wait} 的 sentinel。"
          exit 0
        fi
        sleep "$round_interval"
        (( elapsed += round_interval ))
      done
      echo "等待 round=${round_wait} 的 sentinel 超时(${round_timeout}s)。可稍后再 peer peek。" >&2
      exit 2
    fi

    if [[ $# -gt 3 ]]; then
      echo "用法: peer wait [<id>] [超时秒] [采样间隔秒] [连续稳定次数]" >&2
      exit 1
    fi
    timeout="${1:-${PEER_WAIT_TIMEOUT:-300}}"
    interval="${2:-${PEER_WAIT_INTERVAL:-5}}"
    stable_needed="${3:-${PEER_WAIT_STABLE_SAMPLES:-2}}"
    lines="${PEER_WAIT_LINES:-40}"
    if ! is_positive_int "$timeout"; then
      echo "错误: peer wait 的超时秒数必须是正整数。" >&2
      exit 1
    fi
    if ! is_positive_int "$interval"; then
      echo "错误: peer wait 的采样间隔秒必须是正整数。" >&2
      exit 1
    fi
    if ! is_positive_int "$stable_needed"; then
      echo "错误: peer wait 的连续稳定次数必须是正整数。" >&2
      exit 1
    fi
    if ! is_positive_int "$lines"; then
      echo "错误: PEER_WAIT_LINES 必须是正整数。" >&2
      exit 1
    fi
    elapsed=0
    stable_seen=0
    prev="$(capture "$target" "$lines")"
    while (( elapsed < timeout )); do
      # 先给对方一点启动时间,避免它还没开始输出就被判定为"稳定"
      sleep "$interval"
      (( elapsed += interval ))
      cur="$(capture "$target" "$lines")"
      if [[ "$cur" == "$prev" ]]; then
        (( stable_seen += 1 ))
        if (( stable_seen >= stable_needed )); then
          echo "目标输出已稳定(连续 ${stable_seen} 次采样一致),它可能已完成。"
          exit 0
        fi
      else
        stable_seen=0
      fi
      prev="$cur"
    done
    echo "等待超时(${timeout}s),目标仍在输出。可稍后再 peer peek。" >&2
    exit 2
    ;;

  task)
    subcmd="${1:-}"
    case "$subcmd" in
      init)
        shift
        target_id="$ME"
        if [[ -n "${1:-}" && "${1:-}" != --* ]]; then
          target_id="$1"
          shift
        fi
        task_title=""
        round="1"
        task_steps=()
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --task|--title)
              task_title="${2:-}"
              shift 2
              ;;
            --round)
              round="${2:-}"
              shift 2
              ;;
            --step)
              task_steps+=("${2:-}")
              shift 2
              ;;
            *)
              echo "用法: peer task init [<id>] --task \"...\" [--round N] --step s1:\"...\" [--step s2:\"...\"]" >&2
              exit 1
              ;;
          esac
        done
        task_init "$target_id" "$task_title" "$round" ${task_steps[@]+"${task_steps[@]}"}
        echo "已初始化 task.json: .agent-duo/state/$target_id/task.json"
        ;;
      next)
        shift
        target_id="${1:-$ME}"
        if [[ -n "${2:-}" ]]; then
          echo "用法: peer task next [<id>]" >&2
          exit 1
        fi
        task_next "$target_id"
        ;;
      ""|--help|-h)
        if [[ "$subcmd" == "--help" || "$subcmd" == "-h" ]]; then
          echo "用法: peer task [<id>] | peer task next [<id>] | peer task init [<id>] --task \"...\" --step s1:\"...\"" >&2
          exit 0
        fi
        task_print "$ME"
        ;;
      *)
        if [[ -n "${2:-}" ]]; then
          echo "用法: peer task [<id>] | peer task next [<id>] | peer task init [<id>] --task \"...\" --step s1:\"...\"" >&2
          exit 1
        fi
        task_print "$subcmd"
        ;;
    esac
    ;;

  loop)
    subcmd="${1:-}"
    case "$subcmd" in
      init)
        shift
        target_id="$ME"
        if [[ -n "${1:-}" && "${1:-}" != --* ]]; then
          target_id="$1"
          shift
        fi
        loop_mission=""
        loop_max_rounds=""
        loop_round=""
        loop_non_goals=()
        loop_success=()
        loop_validations=()
        loop_validation_satisfies=()
        loop_validation_timeouts=()
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --mission)
              loop_mission="${2:-}"
              shift 2
              ;;
            --max-rounds)
              loop_max_rounds="${2:-}"
              shift 2
              ;;
            --non-goal)
              loop_non_goals+=("${2:-}")
              shift 2
              ;;
            --success)
              loop_success+=("${2:-}")
              shift 2
              ;;
            --validation)
              loop_validations+=("${2:-}")
              shift 2
              ;;
            --validation-satisfies)
              loop_validation_satisfies+=("${2:-}")
              shift 2
              ;;
            --validation-timeout)
              loop_validation_timeouts+=("${2:-}")
              shift 2
              ;;
            --round)
              loop_round="${2:-}"
              shift 2
              ;;
            *)
              echo "用法: peer loop init [<id>] --mission \"...\" --max-rounds N [--non-goal \"...\"] [--success \"...\"] [--round N] [--validation id:\"cmd\"] [--validation-satisfies id:\"signal\"] [--validation-timeout id:N]" >&2
              exit 1
              ;;
          esac
        done
        if [[ -z "$loop_round" ]]; then
          loop_round="$(report_round_for_id "$target_id")"
          if [[ "$loop_round" == "0" ]]; then loop_round="1"; fi
        fi
        loop_non_goals_json="$(json_array ${loop_non_goals[@]+"${loop_non_goals[@]}"})"
        loop_success_json="$(json_array ${loop_success[@]+"${loop_success[@]}"})"
        if ! loop_validation_json="$(build_validation_json)"; then
          exit 1
        fi
        loop_init "$target_id" "$loop_mission" "$loop_max_rounds" "$loop_round" "$loop_non_goals_json" "$loop_success_json" "$loop_validation_json"
        echo "已初始化 loop.json: .agent-duo/state/$target_id/loop.json"
        ;;
      ""|--help|-h)
        if [[ "$subcmd" == "--help" || "$subcmd" == "-h" ]]; then
          echo "用法: peer loop [<id>] | peer loop init [<id>] --mission \"...\" --max-rounds N [--non-goal \"...\"] [--success \"...\"] [--round N] [--validation id:\"cmd\"] [--validation-satisfies id:\"signal\"] [--validation-timeout id:N]" >&2
          exit 0
        fi
        loop_print "$ME"
        ;;
      *)
        if [[ -n "${2:-}" ]]; then
          echo "用法: peer loop [<id>] | peer loop init [<id>] --mission \"...\" --max-rounds N [--non-goal \"...\"] [--success \"...\"] [--round N] [--validation id:\"cmd\"] [--validation-satisfies id:\"signal\"] [--validation-timeout id:N]" >&2
          exit 1
        fi
        loop_print "$subcmd"
        ;;
    esac
    ;;

  report)
    report_type=""
    report_status=""
    step_ref=""
    round=""
    delta=""
    next_text=""
    goal_ref=""
    drift=""
    evidence_cmd=""
    evidence_result=""
    evidence_ref=""
    needs_kind=""
    needs_detail=""
    needs_options=()

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --type)
          report_type="${2:-}"
          shift 2
          ;;
        --status)
          report_status="${2:-}"
          shift 2
          ;;
        --step|--step-ref)
          step_ref="${2:-}"
          shift 2
          ;;
        --round)
          round="${2:-}"
          shift 2
          ;;
        --delta)
          delta="${2:-}"
          shift 2
          ;;
        --next)
          next_text="${2:-}"
          shift 2
          ;;
        --goal|--goal-ref)
          goal_ref="${2:-}"
          shift 2
          ;;
        --drift)
          drift="${2:-}"
          shift 2
          ;;
        --evidence-cmd)
          evidence_cmd="${2:-}"
          shift 2
          ;;
        --evidence-result)
          evidence_result="${2:-}"
          shift 2
          ;;
        --evidence-ref)
          evidence_ref="${2:-}"
          shift 2
          ;;
        --needs|--needs-kind)
          needs_kind="${2:-}"
          shift 2
          ;;
        --needs-detail)
          needs_detail="${2:-}"
          shift 2
          ;;
        --needs-option)
          needs_options+=("${2:-}")
          shift 2
          ;;
        *)
          echo "用法: peer report --type <plan|checkpoint|request|result> --status <in_progress|blocked|partial|done|failed|unknown> [--step sN] [--round N] [--delta ...] [--next ...] [--needs <approval|decision|info|scope|discovery> [--needs-detail ...] [--needs-option ...]]" >&2
          exit 1
          ;;
      esac
    done

    if ! is_report_type "$report_type"; then
      echo "错误: --type 必须是 plan、checkpoint、request 或 result。" >&2
      exit 1
    fi
    if ! is_report_status "$report_status"; then
      echo "错误: --status 必须是 in_progress、blocked、partial、done、failed 或 unknown。" >&2
      exit 1
    fi
    if [[ -n "$round" ]] && ! is_positive_int "$round"; then
      echo "错误: --round 必须是正整数。" >&2
      exit 1
    fi
    if [[ -n "$needs_kind" ]] && ! is_needs_kind "$needs_kind"; then
      echo "错误: --needs 必须是 approval、decision、info、scope 或 discovery。" >&2
      exit 1
    fi
    # detail/option 离开 kind 无处安放:fail-closed,别把阻塞诉求悄悄丢成空 needs[]。
    if [[ -z "$needs_kind" && ( -n "$needs_detail" || ${#needs_options[@]} -gt 0 ) ]]; then
      echo "错误: --needs-detail / --needs-option 需要同时指定 --needs <approval|decision|info|scope|discovery>。" >&2
      exit 1
    fi

    role="$(self_role)"
    state_dir="$AGENT_DUO_DIR/state/$ME"
    events_dir="$AGENT_DUO_DIR/events"
    mkdir -p "$state_dir" "$events_dir"

    if [[ -z "$round" ]]; then
      round="$(next_report_round "$state_dir")"
    fi

    effective_status="$report_status"
    if [[ "$report_status" == "done" || "$report_status" == "partial" ]]; then
      if [[ -z "$evidence_cmd" && -z "$evidence_result" && -z "$evidence_ref" ]]; then
        effective_status="unknown"
      fi
    fi

    task_file="$state_dir/task.json"
    tmp_task=""
    if [[ -f "$task_file" ]]; then
      if [[ -n "$step_ref" ]]; then
        if ! task_step_exists "$task_file" "$step_ref"; then
          echo "错误: task.json 中不存在 step '$step_ref'。" >&2
          exit 1
        fi
        step_status=""
        step_status="$(task_step_status_for_report "$report_type" "$report_status" "$effective_status" 2>/dev/null || true)"
        if [[ -n "$step_status" ]]; then
          evidence_json="$(task_evidence_json "$evidence_cmd" "$evidence_result" "$evidence_ref")"
          tmp_task="${state_dir}/.task.json.$$"
          if ! task_prepare_update "$task_file" "$tmp_task" "$step_ref" "$step_status" "$round" "$evidence_json"; then
            rm -f "$tmp_task"
            exit 1
          fi
        fi
      fi
      task_candidate="$task_file"
      if [[ -n "$tmp_task" ]]; then task_candidate="$tmp_task"; fi
      if [[ "$report_type" == "result" && "$effective_status" == "done" ]]; then
        if ! task_all_steps_done "$task_candidate"; then
          effective_status="partial"
        fi
      fi
    fi

    report_file="$state_dir/r${round}.json"
    latest_file="$state_dir/report.json"
    if [[ -e "$report_file" ]]; then
      echo "错误: report round 已存在: .agent-duo/state/$ME/r${round}.json" >&2
      exit 1
    fi

    # 写临时文件 + rename：保证读者只看到完整文件(原子可见性)。
    # 注意:不再 fsync —— 去掉 Python 运行时依赖后放弃了跨崩溃耐久性。单机断电/内核崩溃
    # 极端情形下，已返回成功的 report/event 可能丢失;原子性与正常读写不受影响。
    needs_json="$(build_needs_json "$needs_kind" "$needs_detail" ${needs_options[@]+"${needs_options[@]}"})"
    tmp_report="$state_dir/.r${round}.json.$$"
    write_report_json "$tmp_report" "$round" "$ME" "$role" "$report_type" "$effective_status" \
      "$goal_ref" "$step_ref" "$delta" "$drift" "$next_text" \
      "$evidence_cmd" "$evidence_result" "$evidence_ref" "$needs_json"
    mv "$tmp_report" "$report_file"

    sha="$(sha256_file "$report_file")"
    ts="$(iso_ts)"
    tag="$(codec_tag)"
    ref=".agent-duo/state/$ME/r${round}.json"
    event_ref="$ref"
    gate_created_file=""

    queue="$events_dir/queue.jsonl"
    event_type="$(event_type_for_report "$report_type" "$effective_status")"
    summary="$(one_line "$delta")"
    if [[ -z "$summary" ]]; then summary="$(one_line "$next_text")"; fi
    # 阻塞诉求要带进 event summary,否则 Stop/loop 注入只能给 supervisor 一个泛化 request/blocked。
    if [[ -z "$summary" && -n "$needs_detail" ]]; then summary="$(one_line "$needs_detail")"; fi
    if [[ -z "$summary" && -n "$needs_kind" ]]; then summary="needs:${needs_kind}"; fi
    if [[ -z "$summary" ]]; then summary="${report_type}/${effective_status}"; fi
    if [[ "$needs_kind" == "decision" && "$event_type" == "blocked" ]]; then
      gate_id="$(new_gate_id "$round")"
      gate_title="$needs_detail"
      if [[ -z "$gate_title" ]]; then gate_title="Human decision required"; fi
      if ! create_gate_record "$gate_id" "$ts" "$ME" "$role" "$round" "$gate_title" "$needs_detail" "$ref" ${needs_options[@]+"${needs_options[@]}"}; then
        rm -f "$report_file"
        if [[ -n "$tmp_task" ]]; then rm -f "$tmp_task"; fi
        exit 1
      fi
      gate_created_file="$(gate_path "$gate_id")"
      event_ref=".agent-duo/gates/${gate_id}.json"
    fi
    event_id="$(printf 'e%s-%s-%s' "$(date -u '+%Y%m%dT%H%M%SZ')" "$round" "$$")"
    if ! append_event_json "$queue" "$event_id" "$ts" "$ME" "$event_type" "$round" "$summary" "$event_ref"; then
      rm -f "$report_file"
      if [[ -n "$gate_created_file" ]]; then rm -f "$gate_created_file"; fi
      if [[ -n "$tmp_task" ]]; then rm -f "$tmp_task"; fi
      exit 1
    fi
    if [[ -n "$tmp_task" ]]; then
      mv "$tmp_task" "$task_file"
    fi
    if [[ -n "$gate_created_file" ]]; then
      append_decision_log "$gate_id" "opened" "$ME" "$summary" "" ""
    fi

    tmp_latest="$state_dir/.report.json.$$"
    rm -f "$tmp_latest"
    ln -s "r${round}.json" "$tmp_latest"
    mv -f "$tmp_latest" "$latest_file"

    printf '«AGENTDUO:%s» agent_id=%s round=%s type=%s status=%s file=%s sha=%s ts=%s\n' \
      "$tag" "$ME" "$round" "$report_type" "$effective_status" "$ref" "$sha" "$ts"
    ;;

  gate)
    subcmd="${1:-}"
    if [[ -z "$subcmd" || "$subcmd" == "--all" ]]; then
      show_all=0
      if [[ "$subcmd" == "--all" ]]; then show_all=1; fi
      gate_print_list "$show_all"
      exit 0
    fi
    if [[ "$subcmd" != "open" && "$subcmd" != "resolve" ]]; then
      echo "用法: peer gate [--all] | peer gate open [<target>] --title \"...\" [--detail \"...\"] [--option \"...\"] | peer gate resolve [<gate-id>|<target-id>] --choice <choice> [--note \"...\"]" >&2
      exit 1
    fi
    shift
    case "$subcmd" in
      open)
        maybe_id=""
        if [[ -n "${1:-}" && "${1:-}" != --* ]]; then
          maybe_id="$1"
          shift
        fi
        gate_title=""
        gate_detail=""
        round="0"
        needs_options=()
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --title) gate_title="${2:-}"; shift 2 ;;
            --detail) gate_detail="${2:-}"; shift 2 ;;
            --option) needs_options+=("${2:-}"); shift 2 ;;
            --round) round="${2:-}"; shift 2 ;;
            *) echo "用法: peer gate open [<target>] --title \"...\" [--detail \"...\"] [--option \"...\"] [--round N]" >&2; exit 1 ;;
          esac
        done
        if [[ -z "$gate_title" ]]; then
          echo "错误: peer gate open 需要 --title。" >&2
          exit 1
        fi
        if [[ -n "$round" && "$round" != "0" ]] && ! is_positive_int "$round"; then
          echo "错误: --round 必须是正整数。" >&2
          exit 1
        fi
        ensure_session
        target="$(resolve_target_pane "$maybe_id")"
        if [[ -n "$maybe_id" ]]; then
          target_id="$maybe_id"
        else
          target_id="$(reg_pick_other "$ME" "$(agent_ids)")"
        fi
        target_role="$(role_for_id "$target_id")"
        gate_id="$(new_gate_id "$round")"
        ts="$(iso_ts)"
        create_gate_record "$gate_id" "$ts" "$target_id" "$target_role" "$round" "$gate_title" "$gate_detail" "" ${needs_options[@]+"${needs_options[@]}"}
        gate_summary="$gate_detail"
        if [[ -z "$gate_summary" ]]; then gate_summary="$gate_title"; fi
        append_decision_log "$gate_id" "opened" "$target_id" "$gate_summary" "" ""
        echo "已打开 human gate $gate_id (target=$target_id)。"
        ;;
      resolve)
        maybe_id=""
        if [[ -n "${1:-}" && "${1:-}" != --* ]]; then
          maybe_id="$1"
          shift
        fi
        choice=""
        note=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --choice) choice="${2:-}"; shift 2 ;;
            --note) note="${2:-}"; shift 2 ;;
            *) echo "用法: peer gate resolve [<gate-id>|<target-id>] --choice <choice> [--note \"...\"]" >&2; exit 1 ;;
          esac
        done
        if [[ -z "$choice" ]]; then
          echo "错误: peer gate resolve 需要 --choice。" >&2
          exit 1
        fi
        if [[ ! "$choice" =~ ^[A-Za-z0-9._:-]+$ ]]; then
          echo "错误: --choice 只能包含字母、数字、点、下划线、冒号和连字符；补充说明请用 --note。" >&2
          exit 1
        fi
        gate_id=""
        if [[ -n "$maybe_id" && -f "$(gate_path "$maybe_id")" ]]; then
          gate_id="$maybe_id"
        elif [[ -n "$maybe_id" ]]; then
          if gate_id="$(gate_pick_unique_pending_for_agent "$maybe_id")"; then
            :
          else
            rc="$?"
            if [[ "$rc" == "2" ]]; then exit 1; fi
            gate_id=""
          fi
        elif [[ -z "$maybe_id" ]]; then
          if gate_id="$(gate_pick_unique_pending)"; then
            :
          else
            rc="$?"
            if [[ "$rc" == "2" ]]; then exit 1; fi
            gate_id=""
          fi
        fi
        ensure_session
        if [[ -n "$gate_id" ]]; then
          target_id="$(gate_field "$gate_id" '.agent_id')"
          if [[ -z "$target_id" ]]; then
            echo "错误: gate '$gate_id' 缺少 agent_id,无法发送 decision。" >&2
            exit 1
          fi
          target="$(resolve_target_pane "$target_id")"
        else
          target="$(resolve_target_pane "$maybe_id")"
          if [[ -n "$maybe_id" ]]; then
            target_id="$maybe_id"
          else
            target_id="$(reg_pick_other "$ME" "$(agent_ids)")"
          fi
        fi
        check_safe_to_send_keys "$target"
        if [[ -n "$gate_id" ]]; then
          gate_resolve_record "$gate_id" "$choice" "$note"
        fi
        buf="peer-${ME}2${target_id}-gate"
        gate_text="«AGENTDUO verb=decision choice=${choice}»"
        if [[ -n "$note" ]]; then
          gate_text="${gate_text}"$'\n'"$note"
        fi
        send_text_to_pane "$target" "$buf" "$gate_text"
        if [[ -n "$gate_id" ]]; then
          echo "已解决 human gate $gate_id 并发送 decision(choice=$choice)。"
        else
          echo "已发送 gate decision(choice=$choice)。"
        fi
        ;;
    esac
    ;;

  approvals)
    show_all=0
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --all) show_all=1; shift ;;
        *) echo "用法: peer approvals [--all]" >&2; exit 1 ;;
      esac
    done
    if [[ "$show_all" == "1" ]]; then
      run_approval_broker list --root "$AGENT_DUO_ROOT" --all
    else
      run_approval_broker list --root "$AGENT_DUO_ROOT"
    fi
    ;;

  approve)
    approval_id="${1:-}"
    if [[ -z "$approval_id" ]]; then
      echo "用法: peer approve <id>" >&2
      exit 1
    fi
    shift
    if [[ $# -gt 0 ]]; then
      echo "用法: peer approve <id>" >&2
      exit 1
    fi
    run_approval_broker approve --root "$AGENT_DUO_ROOT" "$approval_id"
    ;;

  deny)
    approval_id="${1:-}"
    if [[ -z "$approval_id" ]]; then
      echo "用法: peer deny <id> [--reason \"...\"]" >&2
      exit 1
    fi
    shift
    deny_reason=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --reason) deny_reason="${2:-}"; shift 2 ;;
        *) echo "用法: peer deny <id> [--reason \"...\"]" >&2; exit 1 ;;
      esac
    done
    run_approval_broker deny --root "$AGENT_DUO_ROOT" --reason "$deny_reason" "$approval_id"
    ;;

  loopd)
    ensure_session
    exec bash "$PEER_ROOT/scripts/loopd" "$@"
    ;;

  status)
    ensure_session
    target="$(resolve_target_pane "" 2>/dev/null || true)"
    echo "我是: $ME    会话: $SESSION"
    [[ -n "$target" ]] && echo "目标(默认): $target"
    printf '%s\n' "--- agents ---"
    "$0" ls
    ;;

  rm)
    ensure_session
    rm_id="${1:-}"
    if [[ -z "$rm_id" ]]; then
      echo "用法: peer rm <id>" >&2; exit 1
    fi
    if [[ "$rm_id" == "$ME" ]]; then
      echo "错误: 不能移除自己。" >&2; exit 1
    fi
    if ! rm_pane="$(pane_for_id "$rm_id")"; then
      echo "错误: 找不到 agent '$rm_id'。" >&2; exit 1
    fi
    tmux kill-window -t "$rm_pane"
    echo "已移除 agent '$rm_id'(pane=$rm_pane)。"
    ;;

  esc)
    ensure_session
    if [[ "${1:-}" == "--force" ]]; then FORCE_SEND=1; shift; fi
    maybe_id=""
    if [[ -n "${1:-}" && "${1:-}" != "--force" ]]; then maybe_id="$1"; shift; fi
    if [[ "${1:-}" == "--force" ]]; then FORCE_SEND=1; shift; fi
    target="$(resolve_target_pane "$maybe_id")"
    check_safe_to_send_keys "$target"
    tmux send-keys -t "$target" Escape
    echo "已发送 Escape。"
    ;;

  help|*)
    sed -n '2,28p' "$0" | sed 's/^# \{0,1\}//'
    ;;
esac
